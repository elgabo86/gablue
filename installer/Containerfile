# Exécuter avec : podman build --cap-add sys_admin --security-opt label=disable
# Image de construction du payload Live ISO Gablue
# Basée sur l'image Gablue elle-même (déjà bootc-compatible via fedora-ostree-desktops/kinoite)

ARG BASE_IMAGE=${BASE_IMAGE:-ghcr.io/elgabo86/gablue-main:latest}
ARG INSTALL_IMAGE_PAYLOAD=${INSTALL_IMAGE_PAYLOAD:-ghcr.io/elgabo86/gablue-main:latest}

FROM $BASE_IMAGE
ARG BASE_IMAGE
ARG INSTALL_IMAGE_PAYLOAD
ARG SKIP_FLATPAKS
RUN --mount=type=bind,source=./.,target=/src \
    env \
    BASE_IMAGE="$BASE_IMAGE" \
    INSTALL_IMAGE_PAYLOAD="$INSTALL_IMAGE_PAYLOAD" \
    SKIP_FLATPAKS="${SKIP_FLATPAKS:-}" \
    /src/build.sh
