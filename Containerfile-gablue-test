# Arguments pour configurer l'image de base et ses variantes, tous fournis par le workflow
ARG VARIANT
ARG SOURCE_IMAGE
ARG SOURCE_SUFFIX
ARG FEDORA_VERSION
ARG KERNEL_TYPE
ARG KERNEL_VERSION
ARG KERNEL_FLAVOR
ARG NVIDIA_VERSION
ARG DX_MODE

# Étape intermédiaire : récupération du kernel et des akmods depuis ublue-os
# Utilise le système d'akmods de Bazzite unstable (kernel ogc)
FROM ghcr.io/ublue-os/akmods:${KERNEL_FLAVOR}-${FEDORA_VERSION}-${KERNEL_VERSION} AS akmods
FROM ghcr.io/ublue-os/akmods-extra:${KERNEL_FLAVOR}-${FEDORA_VERSION}-${KERNEL_VERSION} AS akmods-extra

# Étape intermédiaire : récupération des pilotes NVIDIA depuis le conteneur OCI bazzite avec version spécifique
FROM ghcr.io/bazzite-org/nvidia-drivers:${NVIDIA_VERSION}-f${FEDORA_VERSION}-x86_64 AS nvidia

# Étape intermédiaire : récupérer les pilotes NVIDIA Open (même source, on filtre plus tard)
FROM ghcr.io/bazzite-org/nvidia-drivers:${NVIDIA_VERSION}-f${FEDORA_VERSION}-x86_64 AS nvidia-open

# Image de base pour la construction finale
FROM ghcr.io/ublue-os/${SOURCE_IMAGE}${SOURCE_SUFFIX}:${FEDORA_VERSION}

# Redéfinition des arguments après le FROM pour les rendre disponibles
ARG VARIANT
ARG SOURCE_IMAGE
ARG DX_MODE
ARG KERNEL_FLAVOR
ARG KERNEL_VERSION

# Copie des fichiers système dans l'image
COPY files/scripts /ctx/

COPY files/system/all /
COPY files/system/${SOURCE_IMAGE} /
COPY files/system/${VARIANT} /
COPY files/system/test /

# Définition des variables d'environnement pour les scripts
ENV VARIANT=${VARIANT}
ENV SOURCE_IMAGE=${SOURCE_IMAGE}
ENV DX_MODE=${DX_MODE}
ENV KERNEL_FLAVOR=${KERNEL_FLAVOR}
ENV KERNEL_VERSION=${KERNEL_VERSION}

# Installation du kernel ogc avec akmods (avant les dépôts COPR pour éviter les conflits)
RUN --mount=type=cache,dst=/var/cache \
    --mount=type=cache,dst=/var/log \
    --mount=type=bind,from=akmods,src=/kernel-rpms,dst=/tmp/kernel-rpms \
    --mount=type=bind,from=akmods,src=/rpms/common,dst=/tmp/rpms/common \
    --mount=type=bind,from=akmods,src=/rpms/kmods,dst=/tmp/rpms/kmods \
    --mount=type=bind,from=akmods-extra,src=/rpms/extra,dst=/tmp/rpms/extra \
    --mount=type=bind,from=akmods-extra,src=/rpms/kmods,dst=/tmp/rpms/kmods-extra \
    sh /ctx/kernel-test && \
    sh /ctx/cleanup

# Configuration des dépôts Copr (version test avec exclusions supplémentaires)
RUN --mount=type=cache,dst=/var/cache \
    --mount=type=cache,dst=/var/log \
    sh /ctx/copr-test && \
    sh /ctx/cleanup

# Installation Mesa Terra
RUN --mount=type=cache,dst=/var/cache \
    --mount=type=cache,dst=/var/log \
    sh /ctx/mesa && \
    sh /ctx/cleanup

    # Installation des pilotes NVIDIA (pour la variante nvidia uniquement)
RUN --mount=type=cache,dst=/var/cache \
    --mount=type=cache,dst=/var/log \
    --mount=type=bind,from=nvidia,src=/,dst=/rpms/nvidia \
    if [ "$VARIANT" = "nvidia" ]; then \
        sh /ctx/nvidia; \
    fi && \
    sh /ctx/cleanup

# Installation des pilotes NVIDIA Open (pour la variante nvidia-open uniquement)
RUN --mount=type=cache,dst=/var/cache \
    --mount=type=cache,dst=/var/log \
    --mount=type=bind,from=nvidia-open,src=/,dst=/rpms/nvidia \
    if [ "$VARIANT" = "nvidia-open" ]; then \
        sh /ctx/nvidia; \
    fi && \
    sh /ctx/cleanup

# Installation des paquets RPM (version test sans libs 32-bit sauf Mesa)
RUN --mount=type=cache,dst=/var/cache \
    --mount=type=cache,dst=/var/log \
    sh /ctx/rpm-test && \
    sh /ctx/cleanup

# Post-installation : configuration finale (version test avec OpenGamepadUI)
RUN --mount=type=cache,dst=/var/cache \
    --mount=type=cache,dst=/var/log \
    sh /ctx/systemd-test && \
    sh /ctx/post-install-test && \
    sh /ctx/initramfs && \
    sh /ctx/finalize && \
    rm -rf /ctx

# Valider l'image bootc
RUN --mount=type=tmpfs,target=/run --network=none bootc container lint
