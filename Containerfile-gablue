# Arguments pour configurer l'image de base et ses variantes, tous fournis par le workflow
ARG VARIANT
ARG SOURCE_IMAGE
ARG FEDORA_VERSION
ARG KERNEL_VERSION
ARG KERNEL_FLAVOR
ARG NVIDIA_FLAVOR="nvidia-open"
ARG DX_MODE

# Étape intermédiaire : scripts de build (bind-mountés dans chaque RUN, jamais dans l'image finale)
FROM scratch AS ctx
COPY --chmod=755 files/scripts /

# Étape intermédiaire : récupération du kernel et des akmods depuis ublue-os
FROM ghcr.io/ublue-os/akmods:${KERNEL_FLAVOR}-${FEDORA_VERSION}-${KERNEL_VERSION} AS akmods
FROM ghcr.io/ublue-os/akmods-extra:${KERNEL_FLAVOR}-${FEDORA_VERSION}-${KERNEL_VERSION} AS akmods-extra

# Étape intermédiaire : récupération des pilotes NVIDIA (nvidia-lts ou nvidia-open)
# Monté conditionnellement selon la variante, toujours tiré pour résoudre les mounts
FROM ghcr.io/ublue-os/akmods-${NVIDIA_FLAVOR}:${KERNEL_FLAVOR}-${FEDORA_VERSION}-${KERNEL_VERSION} AS akmods-nvidia

# Étape intermédiaire : fichiers spécifiques NVIDIA (communs aux variantes nvidia et nvidia-open)
FROM scratch AS nvidia-common-files
COPY files/system/nvidia-common /

# Image de base pour la construction finale
FROM quay.io/fedora-ostree-desktops/${SOURCE_IMAGE}:${FEDORA_VERSION}

# Redéfinition des arguments après le FROM pour les rendre disponibles
ARG VARIANT
ARG SOURCE_IMAGE
ARG DX_MODE
ARG KERNEL_FLAVOR
ARG KERNEL_VERSION

# Copie des sources pour compilation et assemblage
COPY src/gamepadshortcuts /src/gamepadshortcuts
COPY src/ds2xbox /src/ds2xbox
COPY src/gablue-isomount /src/gablue-isomount
COPY src/gwine-launcher /src/gwine-launcher

# Copie des fichiers système dans l'image
COPY files/system/all /

# Supprimer le plugin natif dolphin-plugins mountisoaction (bug KDE #471487)
# Remplace par gablue-isomount (compilation dans build-c)
RUN rm -f /usr/lib64/qt6/plugins/kf6/kfileitemaction/mountisoaction.so

# Définition des variables d'environnement pour les scripts
ENV VARIANT=${VARIANT}
ENV SOURCE_IMAGE=${SOURCE_IMAGE}
ENV DX_MODE=${DX_MODE}
ENV KERNEL_FLAVOR=${KERNEL_FLAVOR}
ENV KERNEL_VERSION=${KERNEL_VERSION}

# Configuration des dépôts Copr (avant le kernel pour fournir les dépendances des kmods)
RUN --mount=type=cache,dst=/var/cache \
    --mount=type=cache,dst=/var/log \
    --mount=type=bind,from=ctx,source=/,target=/ctx \
    --mount=type=tmpfs,dst=/tmp \
    /ctx/copr && \
    /ctx/cleanup

# Installation du kernel ogc avec akmods
RUN --mount=type=cache,dst=/var/cache \
    --mount=type=cache,dst=/var/log \
    --mount=type=bind,from=ctx,source=/,target=/ctx \
    --mount=type=bind,from=akmods,src=/kernel-rpms,dst=/tmp/kernel-rpms \
    --mount=type=bind,from=akmods,src=/rpms/common,dst=/tmp/rpms/common \
    --mount=type=bind,from=akmods,src=/rpms/kmods,dst=/tmp/rpms/kmods \
    --mount=type=bind,from=akmods,src=/rpms/ublue-os,dst=/tmp/rpms/ublue-os \
    --mount=type=bind,from=akmods-extra,src=/rpms/extra,dst=/tmp/rpms/extra \
    --mount=type=bind,from=akmods-extra,src=/rpms/kmods,dst=/tmp/rpms/kmods-extra \
    --mount=type=tmpfs,dst=/tmp \
    /ctx/kernel && \
    /ctx/cleanup

# Installation Mesa Terra
RUN --mount=type=cache,dst=/var/cache \
    --mount=type=cache,dst=/var/log \
    --mount=type=bind,from=ctx,source=/,target=/ctx \
    --mount=type=tmpfs,dst=/tmp \
    /ctx/mesa && \
    /ctx/cleanup

# Installation des pilotes NVIDIA (uniquement pour les variantes nvidia et nvidia-open)
# Monte aussi les fichiers nvidia-common (modprobe, SELinux, CDI, distrobox)
RUN --mount=type=cache,dst=/var/cache \
    --mount=type=cache,dst=/var/log \
    --mount=type=bind,from=ctx,source=/,target=/ctx \
    --mount=type=bind,from=akmods-nvidia,src=/rpms,dst=/tmp/rpms/nvidia \
    --mount=type=bind,from=nvidia-common-files,src=/,dst=/tmp/nvidia-files \
    --mount=type=tmpfs,dst=/tmp \
    if [ "$VARIANT" = "nvidia" ] || [ "$VARIANT" = "nvidia-open" ]; then \
        cp -r /tmp/nvidia-files/* / && \
        /ctx/nvidia; \
    fi && \
    /ctx/cleanup

# Installation des paquets RPM
RUN --mount=type=cache,dst=/var/cache \
    --mount=type=cache,dst=/var/log \
    --mount=type=bind,from=ctx,source=/,target=/ctx \
    --mount=type=tmpfs,dst=/tmp \
    /ctx/rpm && \
    /ctx/cleanup

# Compilation des sources C
RUN --mount=type=cache,dst=/var/cache \
    --mount=type=cache,dst=/var/log \
    --mount=type=bind,from=ctx,source=/,target=/ctx \
    --mount=type=tmpfs,dst=/tmp \
    /ctx/build-c && \
    /ctx/cleanup

# Assemblage du script gwine standalone
RUN --mount=type=cache,dst=/var/cache \
    --mount=type=cache,dst=/var/log \
    --mount=type=bind,from=ctx,source=/,target=/ctx \
    --mount=type=tmpfs,dst=/tmp \
    /ctx/build-gwine && \
    /ctx/cleanup

# Post-installation : configuration finale
RUN --mount=type=cache,dst=/var/cache \
    --mount=type=cache,dst=/var/log \
    --mount=type=bind,from=ctx,source=/,target=/ctx \
    --mount=type=tmpfs,dst=/tmp \
    /ctx/systemd && \
    /ctx/post-install && \
    /ctx/initramfs && \
    /ctx/finalize

# Valider l'image bootc
RUN --mount=type=tmpfs,target=/run --network=none bootc container lint
