#!/usr/bin/bash

# Script d'installation des paquets RPM pour Gablue (version test)
# Installe tous les paquets nécessaires : outils CLI, applications graphiques, polices, drivers et dépendances de développement
# Version test avec toutes les libs 32-bit pour compatibilité Wine/Proton

set -eoux pipefail

# =============================================================================
# PRÉPARATION ET VERROUILLAGES
# =============================================================================

# Verrouiller la version de plasma-desktop pour éviter les conflits de version
# Cela empêche plasma-desktop d'être mis à niveau pendant l'installation de paquets
if [ "$SOURCE_IMAGE" == "kinoite" ]; then
    dnf5 versionlock add plasma-desktop
fi

# =============================================================================
# OUTILS EN LIGNE DE COMMANDE (CLI)
# =============================================================================

# Outils système et monitoring
dnf5 -y install \
    ublue-brew \
    fswatch \
    iotop-c \
    wol \
    duperemove \
    speedtest-cli \
    btop \
    amdsmi \
    intel-undervolt \
    ncdu \
    mc \
    lm_sensors \
    fastfetch \
    stress-ng \
    powertop \
    android-tools \
    byobu \
    ripgrep \
    testdisk \
    gh \
    ryzenadj \
    yq \
    trash-cli \
    inotify-tools \
    atuin \
    tldr \
    git \
    nmap \
    plocate \
    squashfuse \
    funionfs \
    icoutils \
    evtest

# Outils SELinux pour compilation des modules personnalisés
dnf5 -y install \
    checkpolicy \
    selinux-policy-devel

# Outils réseau
dnf5 -y --setopt=install_weak_deps=False install \
    tailscale \
    samba-winbind \
    samba-winbind-clients \
    libwbclient.i686

# Outils d'archivage et compression
dnf5 -y install \
    cabextract \
    unzip \
    rar

# Outils multimédia
dnf5 -y install yt-dlp

# =============================================================================
# VIRTUALISATION ET CONTENEURS (MODE DX)
# =============================================================================

# Installation des outils de virtualisation uniquement en mode DX
if [ "${DX_MODE:-false}" == "true" ]; then
    # Docker et composants associés pour le développement conteneurisé
    dnf5 -y install docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin

    # Libvirt et QEMU pour la virtualisation complète
    # Installation complète pour machines virtuelles et développement
    dnf5 -y install \
        libvirt \
        libvirt-nss \
        edk2-ovmf \
        qemu-char-spice \
        qemu-device-display-virtio-gpu \
        qemu-device-display-virtio-vga \
        qemu-device-usb-redirect \
        qemu-img \
        qemu-system-x86-core \
        qemu-user-binfmt \
        qemu-user-static \
        qemu \
        virt-manager \
        ublue-os-libvirt-workarounds
fi

# =============================================================================
# UTILITAIRES TERMINAL AMUSANTS
# =============================================================================

# Améliorations visuelles du terminal
dnf5 -y install \
    bash-color-prompt \
    asciiquarium \
    figlet \
    toilet \
    cmatrix \
    cool-retro-term

# =============================================================================
# APPLICATIONS GRAPHIQUES
# =============================================================================

# Outil de streaming et contrôle système
dnf5 -y install \
    sunshine \
    corectrl \
    solaar

# Utilitaires système et bureautique
dnf5 -y install \
    gnome-disk-utility \
    skanpage \
    x2goclient

# Gaming et performance (depuis terra-mesa)
dnf5 -y --enable-repo=terra-mesa install \
    gamescope \
    gamescope-libs.i686 \
    mangohud \
    mangohud.i686

# Autres outils gaming (Fedora)
dnf5 -y install \
    gamemode \
    gamemode.i686

# =============================================================================
# EXTENSIONS KDE (UNIQUEMENT KINOITE)
# =============================================================================

# Extensions et applications KDE
if [ "$SOURCE_IMAGE" == "kinoite" ]; then
    dnf5 -y install \
        okular \
        gwenview \
        kcalc \
        yakuake \
        papirus-icon-theme \
        papirus-icon-theme-dark \
        langpacks-fr \
        kdenetwork-filesharing \
        kde-runtime-docs \
        kdeplasma-addons
fi

# =============================================================================
# EXTENSIONS SHELL
# =============================================================================

# Extension rom-properties pour navigateur de fichiers (Dolphin)
if [ "$SOURCE_IMAGE" == "kinoite" ]; then
    dnf5 -y install rom-properties-kf6
fi

# Utilitaires rom-properties (CLI, indépendant de l'environnement)
dnf5 -y install rom-properties-utils

# =============================================================================
# POLICES
# =============================================================================

# Polices de Bazzite (aligné sur le Containerfile upstream)
dnf5 -y --setopt=install_weak_deps=False install \
    nerd-fonts \
    twitter-twemoji-fonts \
    google-noto-sans-cjk-fonts \
    lato-fonts \
    fira-code-fonts

# =============================================================================
# PILOTES ET SUPPORT MATÉRIEL
# =============================================================================

# Support HDMI-CEC pour contrôle TV via télécommande
dnf5 -y install libcec

# Pilotes d'impression et support mobile
dnf5 -y install \
    hplip \
    printer-driver-brlaser \
    ifuse \
    libimobiledevice

# =============================================================================
# DÉPENDANCES DE DÉVELOPPEMENT
# =============================================================================

# Compilateurs et outils de développement
dnf5 -y install \
    gcc \
    gcc-c++ \
    libffi-devel \
    readline-devel \
    bzip2-devel \
    openssl-devel \
    sqlite-devel \
    xz-devel \
    tk-devel \
    patch \
    bzip2 \
    sqlite \
    libuuid-devel \
    gdbm-libs \
    libnsl2

# =============================================================================
# MODULES PYTHON ET OUTILS ASSOCIÉS
# =============================================================================

# Modules Python pour gaming et développement
dnf5 -y install \
    python3-evdev \
    python3-uinput \
    python3-tqdm \
    python3-beautifulsoup4 \
    python3-pyside6 \
    python3-dbus \
    python3-setuptools \
    python3-pip

# =============================================================================
# PAQUETS SPÉCIFIQUES AUX VARIANTES
# =============================================================================

# Paquets supplémentaires pour la variante main
if [ "$VARIANT" == "main" ]; then
    dnf5 -y install \
        radeontop
fi

# =============================================================================
# CORRECTIONS TEMPORAIRES
# =============================================================================

# Correction temporaire pour tesseract (nécessaire pour certaines fonctionnalités)
dnf5 -y install \
    tesseract-devel \
    tesseract-langpack-fra

# =============================================================================
# NETTOYAGE DES PAQUETS SUPERFLUS
# =============================================================================

# Suppression des paquets non désirés
dnf5 -y remove \
    firefox \
    firefox-langpacks \
    htop

# Suppression spécifique à Kinoite
if [ "$SOURCE_IMAGE" == "kinoite" ]; then
    dnf5 -y remove plasma-discover-rpm-ostree
fi

# =============================================================================
# BIBLIOTHÈQUES 32-BIT POUR WINE/PROTON
# =============================================================================

# Note: Mesa i686 déjà installé depuis le script mesa-test
# Note: gamescope-libs.i686 et mangohud.i686 déjà installés depuis terra-mesa ci-dessus

# -----------------------------------------------------------------------------
# Rendu de polices (REQUIS pour l'affichage texte dans Wine 32-bit)
# fontconfig et freetype tirent harfbuzz, pango, cairo, glib2, pixman, etc.
# -----------------------------------------------------------------------------

dnf5 -y --setopt=install_weak_deps=False install \
    fontconfig.i686 \
    freetype.i686

# -----------------------------------------------------------------------------
# X11 libs (REQUIS pour le rendu fenêtré Wine 32-bit)
# Sans ces libs : écrans noirs, crashs, fenêtres invisibles
# -----------------------------------------------------------------------------

dnf5 -y --setopt=install_weak_deps=False install \
    libXcomposite.i686 \
    libXcursor.i686 \
    libXdamage.i686 \
    libXfixes.i686 \
    libXi.i686 \
    libXinerama.i686 \
    libXrandr.i686 \
    libXrender.i686 \
    libXtst.i686 \
    libXv.i686

# -----------------------------------------------------------------------------
# Wayland et OpenGL (REQUIS pour le rendu Wayland Wine 32-bit)
# -----------------------------------------------------------------------------

dnf5 -y --setopt=install_weak_deps=False install \
    libepoxy.i686 \
    libdecor.i686 \
    libwayland-cursor.i686 \
    libwayland-egl.i686

# -----------------------------------------------------------------------------
# Core Wine 32-bit (réseau, SSL, débogage, impression)
# -----------------------------------------------------------------------------

dnf5 -y --setopt=install_weak_deps=False install \
    gnutls.i686 \
    libunwind.i686 \
    cups-libs.i686 \
    openldap.i686

# -----------------------------------------------------------------------------
# Audio 32-bit (REQUIS pour le son dans les jeux Wine/Proton)
# -----------------------------------------------------------------------------

# PulseAudio 32-bit (REQUIS pour l'audio Wine)
dnf5 -y --setopt=install_weak_deps=False install \
    pulseaudio-libs.i686

# PipeWire 32-bit (REQUIS pour l'audio PipeWire)
# pipewire-libs.i686 vient de Fedora updates (les dépôts bazzite sont exclus)
# Sur fc44 : la version x86_64 de l'image de base (1.6.2) est en retard sur updates (1.6.4)
# Il faut upgrader x86_64 d'abord pour aligner les versions et éviter les conflits de fichiers
dnf5 -y upgrade \
    pipewire-libs

dnf5 -y --setopt=install_weak_deps=False install \
    pipewire-libs.i686 \
    pipewire-gstreamer.i686

# FAudio pour XAudio2 dans Wine (REQUIS pour les jeux Xbox Audio)
dnf5 -y --setopt=install_weak_deps=False install \
    libFAudio \
    libFAudio.i686

# ALSA 32-bit (REQUIS pour l'audio Wine natif)
dnf5 -y --setopt=install_weak_deps=False install \
    alsa-lib.i686

# OpenAL pour l'audio des jeux 32-bit
dnf5 -y --setopt=install_weak_deps=False install \
    openal-soft.i686

# Librairies audio complémentaires (REQUISES par de nombreux jeux)
dnf5 -y --setopt=install_weak_deps=False install \
    libogg.i686 \
    libvorbis.i686 \
    flac-libs.i686 \
    libsndfile.i686

# -----------------------------------------------------------------------------
# Vulkan 32-bit
# -----------------------------------------------------------------------------

# Vulkan loader pour les applications 32-bit
dnf5 -y --enable-repo=terra-mesa --setopt=install_weak_deps=False install \
    vulkan-loader.i686

# -----------------------------------------------------------------------------
# Vidéo 32-bit (accélération matérielle pour décodage dans Wine)
# -----------------------------------------------------------------------------

dnf5 -y --setopt=install_weak_deps=False install \
    libva.i686 \
    libvdpau.i686

# -----------------------------------------------------------------------------
# GStreamer x86_64 (gestion des codecs système)
# Les plugins full (bad, ugly, ffmpeg) ne sont PAS installés :
# Proton/Wine utilisent leur propre copie de GStreamer et FFmpeg
# -----------------------------------------------------------------------------

# bad (Negatorio17) x86_64 : codecs propriétaires supplémentaires
# (dtsdec, mpeghdec, svtjpegxs, vmaf, voaacenc, voamrwbenc, mpeg2enc, etc.)
# rpm -i --replacepkgs --nodeps : coexiste avec bad-free.x86_64
mkdir -p /tmp/neg17
dnf5 -y --enable-repo=fedora-multimedia download --destdir=/tmp/neg17 --arch=x86_64 \
    gstreamer1-plugins-bad
rpm -i --replacepkgs --nodeps /tmp/neg17/gstreamer1-plugins-bad-*.x86_64.rpm
rm -rf /tmp/neg17

# =============================================================================
# OPENGAMEPADUI - INTERFACE GAMING (EXPERIMENTAL - TEST UNIQUEMENT)
# =============================================================================

# Interface gaming OpenGamepadUI avec session Gamescope
# Paquets disponibles sur le dépôt Terra (FyraLabs)
dnf5 -y --setopt=install_weak_deps=False install \
    opengamepadui \
    gamescope-session-opengamepadui \
    powerstation \
    inputplumber
