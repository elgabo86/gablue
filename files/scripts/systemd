#!/usr/bin/bash

set -eoux pipefail


systemctl enable -f system-flatpak-setup.service

systemctl disable -f scx_loader.service
systemctl disable -f tailscaled.service
systemctl disable -f displaylink.service

systemctl mask systemd-remount-fs.service

# Services supplémentaires pour le mode DX
if [ "${DX_MODE:-false}" == "true" ]; then
    systemctl enable -f ublue-os-libvirt-workarounds.service
    systemctl enable -f gablue-dx-groups.service
fi

if [ "$SOURCE_IMAGE" == "kinoite" ]; then
    systemctl enable -f usr-share-sddm-themes.mount
fi

systemctl enable rpm-ostreed-automatic.timer
systemctl enable flatpak-system-update.timer
systemctl --global enable flatpak-user-update.timer

# Services HDMI-CEC pour contrôle TV
systemctl enable cec-poweroff-tv.service
systemctl enable cec-active-source.timer
