#!/usr/bin/bash

# Installation des pilotes NVIDIA via akmods
# Ce script installe les pilotes NVIDIA depuis les akmods ublue-os
# Supporte NVIDIA Open (nvidia-open) et NVIDIA Closed (nvidia)
# Le script nvidia-install.sh de ublue-os gère : driver, kmod, container-toolkit,
# supergfxctl, SELinux, dracut force_drivers, staging

set -eoux pipefail

# =============================================================================
# PRÉPARATION
# =============================================================================

# Supprimer le firmware NVIDIA de Fedora qui entre en conflit avec les pilotes propriétaires
dnf5 -y remove nvidia-gpu-firmware

# Activation du dépôt Terra Mesa temporairement pour egl-wayland et Mesa i686
dnf5 -y config-manager setopt "terra-mesa".enabled=1

# Activation explicite du staging (nécessaire pour supergfxctl)
# Alignement avec Bazzite : enable staging avant nvidia-install.sh
# car le sed interne du script utilise l'ancien format de nom dnf4
dnf5 -y copr enable ublue-os/staging

# =============================================================================
# INSTALLATION EGL-WAYLAND
# =============================================================================

# Installation des bibliothèques EGL Wayland (32 et 64 bits)
dnf5 -y install \
    egl-wayland.x86_64 \
    egl-wayland.i686 \
    egl-wayland2.x86_64 \
    egl-wayland2.i686

# =============================================================================
# INSTALLATION PILOTES NVIDIA
# =============================================================================

# Détermination de IMAGE_NAME pour le script nvidia-install.sh
export IMAGE_NAME="kinoite"
if [[ "$SOURCE_IMAGE" == "silverblue" ]]; then
    export IMAGE_NAME="silverblue"
fi

AKMODS_PATH="/tmp/rpms/nvidia"

# Installation via le script ublue-os
# AKMODNV_PATH : chemin des RPMs NVIDIA
# MULTILIB=1 : activation des libs 32-bit
# IMAGE_NAME : détection KDE/GNOME pour supergfxctl/plasmoid
if [[ -d "$AKMODS_PATH" ]]; then
    AKMODNV_PATH="$AKMODS_PATH" MULTILIB=1 IMAGE_NAME="$IMAGE_NAME" "$AKMODS_PATH/ublue-os/nvidia-install.sh"
else
    echo "Erreur : Les pilotes NVIDIA n'ont pas été trouvés dans $AKMODS_PATH"
    exit 1
fi

# =============================================================================
# CONFIGURATION POST-INSTALLATION
# =============================================================================

# Suppression du fichier ICD Nouveau (pour éviter les conflits)
rm -f /usr/share/vulkan/icd.d/nouveau_icd.*.json || true

# Création du lien symbolique pour libnvidia-ml
ln -sf libnvidia-ml.so.1 /usr/lib64/libnvidia-ml.so

# Désactivation de supergfxd (comme sur Bazzite NVIDIA)
systemctl disable supergfxd.service

# =============================================================================
# VK_HDR_LAYER (PILOTES CLOSED UNIQUEMENT)
# =============================================================================

# VK_hdr_layer uniquement pour les pilotes NVIDIA closed (pas nvidia-open)
# nvidia-open (595+) a un modeset automatique et ne nécessite pas ce hack
if [[ "$VARIANT" != "nvidia-open" ]]; then
    if [ -f /etc/modprobe.d/nvidia-modeset.conf ]; then
        cp /etc/modprobe.d/nvidia-modeset.conf /usr/lib/modprobe.d/nvidia-modeset.conf
    fi

    # Hack d'installation pour restaurer VK_hdr_layer
    PKG="VK_hdr_layer"
    TMPDIR="$(mktemp -d)"

    dnf5 download "${PKG}" --destdir "$TMPDIR"

    RPM_FILE=$(ls "$TMPDIR"/*.rpm)
    mkdir "$TMPDIR/$PKG"
    cd "$TMPDIR/$PKG"

    # Extraction du RPM
    rpm2cpio "$RPM_FILE" | cpio -idmv

    # Librairies
    mkdir -p /usr/lib64/${PKG}
    cp -v usr/lib64/${PKG}/* /usr/lib64/${PKG}/

    # Vulkan implicit layer
    mkdir -p /usr/share/vulkan/implicit_layer.d
    cp -v usr/share/vulkan/implicit_layer.d/VkLayer_hdr_wsi.*.json \
        /usr/share/vulkan/implicit_layer.d/

    # Licence et documentation
    mkdir -p /usr/share/licenses/${PKG}
    cp -v usr/share/licenses/${PKG}/* /usr/share/licenses/${PKG}/
    mkdir -p /usr/share/doc/${PKG}
    cp -v usr/share/doc/${PKG}/* /usr/share/doc/${PKG}/
fi

# =============================================================================
# DÉSACTIVATION DES DÉPÔTS
# =============================================================================

# Désactivation du dépôt Terra Mesa
dnf5 -y config-manager setopt "terra-mesa".enabled=0
