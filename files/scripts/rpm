#!/usr/bin/bash

# Script d'installation des paquets RPM pour Gablue
# Installe tous les paquets nécessaires : outils CLI, applications graphiques, polices, drivers et dépendances de développement
# Inclut les libs 32-bit complètes pour compatibilité Wine/Proton

set -eoux pipefail

# =============================================================================
# PRÉPARATION ET VERROUILLAGES
# =============================================================================

# Mise à jour des paquets de base (Fedora uniquement) avant toute installation
# L'image Kinoite de base peut avoir jusqu'à 48h de retard sur les mises à jour
# Restreint aux dépôts officiels pour ne pas toucher Mesa, kernel ou NVIDIA
dnf5 -y upgrade --refresh --repo=fedora --repo=updates

# Verrouiller la version de plasma-desktop pour éviter les conflits de version
# Cela empêche plasma-desktop d'être mis à niveau pendant l'installation de paquets
if [ "$SOURCE_IMAGE" == "kinoite" ]; then
    dnf5 versionlock add plasma-desktop
fi

# =============================================================================
# PAQUETS UBLUE-OS (précédemment hérités de l'image intermédiaire kinoite-main)
# =============================================================================

# Fix packaging OpenCL (conflit OpenCL-ICD-Loader vs ocl-icd, bugzilla #2375547)
dnf5 -y swap --repo='fedora' OpenCL-ICD-Loader ocl-icd

# Infrastructure uBlue nécessaire au fonctionnement de ujust et des services
dnf5 -y install \
    just \
    ublue-os-just \
    ublue-os-signing \
    ublue-os-udev-rules \
    ublue-os-update-services \
    ublue-os-luks \
    distrobox \
    fedora-repos-archive

# Paquets multimédia, utilitaires et matériel (précédemment hérités de kinoite-main)
dnf5 -y install \
    ffmpeg \
    ffmpeg-libs \
    fdk-aac \
    libfdk-aac \
    fuse \
    fzf \
    tmux \
    vim \
    nvtop \
    nvme-cli \
    lshw \
    net-tools \
    libcamera \
    libcamera-gstreamer \
    libcamera-ipa \
    libcamera-tools \
    pipewire-libs-extra \
    pipewire-plugin-libcamera \
    heif-pixbuf-loader \
    wl-clipboard \
    flatpak-spawn \
    openrgb-udev-rules \
    alsa-firmware \
    intel-vaapi-driver \
    libva-utils \
    squashfs-tools \
    smartmontools \
    grub2-tools-extra \
    ksshaskpass \
    kate

# =============================================================================
# OUTILS EN LIGNE DE COMMANDE (CLI)
# =============================================================================

# Outils système et monitoring
dnf5 -y install \
    ublue-brew \
    fswatch \
    iotop-c \
    wol \
    bees \
    duperemove \
    speedtest-cli \
    btop \
    amdsmi \
    intel-undervolt \
    ncdu \
    mc \
    lm_sensors \
    fastfetch \
    stress-ng \
    powertop \
    android-tools \
    byobu \
    ripgrep \
    testdisk \
    gh \
    ryzenadj \
    yq \
    jq \
    zoxide \
    trash-cli \
    inotify-tools \
    atuin \
    tldr \
    git \
    nmap \
    plocate \
    squashfuse \
    fuse-libs \
    icoutils \
    evtest \
    symlinks \
    tcpdump \
    traceroute

# Outils SELinux pour compilation des modules personnalisés
dnf5 -y install \
    checkpolicy \
    selinux-policy-devel

# Outils réseau
dnf5 -y --setopt=install_weak_deps=False install \
    tailscale \
    samba-winbind \
    samba-winbind-clients \
    libwbclient.i686

# Outils d'archivage et compression
dnf5 -y install \
    cabextract \
    unzip \
    rar

# Outils multimédia
dnf5 -y install \
    yt-dlp \
    mpv \
    mpv-libs

# Agent invité QEMU pour virtualisation
# Léger (~300 Ko), inoffensif sur bare metal (service sans canal QEMU),
# utile en VM : IP dans virt-manager, graceful shutdown, snapshots consistants.
# Installé sur toutes les variantes pour que les ISOs live fonctionnent dans libvirt.
dnf5 -y install qemu-guest-agent

# =============================================================================
# VIRTUALISATION ET CONTENEURS (MODE DX)
# =============================================================================

if [ "${DX_MODE:-false}" == "true" ]; then
    # Docker et composants associés pour le développement conteneurisé
    dnf5 -y install docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin

    # Libvirt, QEMU et virtualisation pour développement
    # --setopt=install_weak_deps=False : les modules QEMU externes (display, audio,
    # usb, ui) ne sont pas tirés automatiquement, il faut les lister explicitement.
    # Les modules virtio/net/pci/vfio sont compilés statiquement dans qemu-system-x86-core
    # (tiré par qemu-kvm-core), seuls SPICE/USB/UI sont en paquets séparés.
    dnf5 -y --setopt=install_weak_deps=False install \
        libvirt \
        libvirt-nss \
        edk2-ovmf \
        qemu-img \
        qemu-kvm-core \
        spice-server \
        virt-manager \
        virt-viewer \
        virt-install \
        swtpm \
        swtpm-tools \
        qemu-device-display-qxl \
        qemu-device-display-virtio-gpu \
        qemu-device-display-virtio-gpu-gl \
        qemu-device-display-virtio-vga \
        qemu-device-display-virtio-vga-gl \
        qemu-device-display-virtio-gpu-rutabaga \
        qemu-audio-spice \
        qemu-audio-pipewire \
        qemu-audio-pa \
        qemu-audio-alsa \
        qemu-audio-sdl \
        qemu-device-usb-host \
        qemu-device-usb-redirect \
        qemu-device-usb-smartcard \
        qemu-ui-spice-core \
        qemu-ui-spice-app \
        qemu-ui-opengl \
        qemu-ui-egl-headless \
        qemu-ui-gtk \
        qemu-ui-dbus \
        qemu-ui-sdl \
        qemu-char-spice \
        qemu-block-curl \
        qemu-block-ssh \
        qemu-tools

    # Émulation rétro et outils avancés
    dnf5 -y --setopt=install_weak_deps=False install \
        qemu-system-ppc-core \
        qemu-system-m68k-core \
        qemu-system-arm-core \
        qemu-system-aarch64-core \
        guestfs-tools \
        python3-libguestfs \
        ublue-os-libvirt-workarounds

    # ROCm pour GPU compute (AMD uniquement, pas de sens sur NVIDIA)
    if [ "$VARIANT" == "main" ]; then
        dnf5 -y --setopt=install_weak_deps=False install rocm-hip rocm-opencl rocm-clinfo rocm-smi

        # Suppression du compilateur ROCm (inutile au runtime)
        # rocm-llvm-static pèse 1.9 Go à lui seul
        rpm -e --nodeps \
            rocm-llvm-static \
            rocm-llvm-devel \
            rocm-clang-devel \
            rocm-libc++-devel \
            rocm-clang-runtime-devel \
            rocm-lld

        # Empêcher leur réinstallation future
        dnf5 versionlock exclude \
            rocm-llvm-static \
            rocm-llvm-devel \
            rocm-clang-devel \
            rocm-libc++-devel \
            rocm-clang-runtime-devel \
            rocm-lld
    fi
fi

# =============================================================================
# UTILITAIRES TERMINAL AMUSANTS
# =============================================================================

# Améliorations visuelles du terminal
dnf5 -y install \
    bash-color-prompt \
    asciiquarium \
    figlet \
    toilet \
    cmatrix

# =============================================================================
# APPLICATIONS GRAPHIQUES
# =============================================================================

# Outil de streaming et contrôle système
dnf5 -y install \
    sunshine \
    corectrl \
    solaar

# Utilitaires système et bureautique
dnf5 -y install \
    gnome-disk-utility \
    skanpage \
    x2goclient \
    snapper \
    btrfs-assistant

# Gaming et performance (depuis terra-mesa)
dnf5 -y --enable-repo=terra-mesa install \
    gamescope \
    gamescope-libs.i686 \
    mangohud \
    mangohud.i686

# Autres outils gaming (Fedora)
dnf5 -y install \
    gamemode \
    gamemode.i686 \
    dmemcg-booster
dnf5 -y install --skip-unavailable \
    plasma-foreground-booster-dmemcg

# Couche Vulkan basse latence (Anti-Lag 2 / Reflex 2, hardware-agnostic)
dnf5 -y install vulkan-low-latency-layer

# =============================================================================
# EXTENSIONS KDE (UNIQUEMENT KINOITE)
# =============================================================================

# Extensions et applications KDE
if [ "$SOURCE_IMAGE" == "kinoite" ]; then
    dnf5 -y install \
        okular \
        gwenview \
        kcalc \
        yakuake \
        papirus-icon-theme \
        papirus-icon-theme-dark \
        langpacks-fr \
        kdenetwork-filesharing \
        kdeplasma-addons \
        plasma-oxygen \
        plasma-bigscreen \
        plasma-union
fi

# =============================================================================
# EXTENSIONS SHELL
# =============================================================================

# Extension rom-properties pour navigateur de fichiers (Dolphin)
if [ "$SOURCE_IMAGE" == "kinoite" ]; then
    dnf5 -y install rom-properties-kf6
fi

# Utilitaires rom-properties (CLI, indépendant de l'environnement)
dnf5 -y install rom-properties-utils

# =============================================================================
# POLICES
# =============================================================================

# Polices de Bazzite (aligné sur le Containerfile upstream)
dnf5 -y --setopt=install_weak_deps=False install \
    nerd-fonts \
    twitter-twemoji-fonts \
    google-noto-sans-cjk-fonts \
    lato-fonts \
    fira-code-fonts

# =============================================================================
# PILOTES ET SUPPORT MATÉRIEL
# =============================================================================

# Support HDMI-CEC pour contrôle TV via télécommande
dnf5 -y install libcec

# Pilotes d'impression et support mobile
dnf5 -y install \
    hplip \
    printer-driver-brlaser \
    ifuse \
    libimobiledevice \
    libimobiledevice-utils \
    libratbag-ratbagd \
    oversteer-udev

# =============================================================================
# OUTILS RUNTIME
# =============================================================================

# Outils système légers (pas de compilateur, installable via brew si besoin)
dnf5 -y install \
    patch \
    bzip2 \
    sqlite \
    gdbm-libs \
    libnsl2 \
    uv

# =============================================================================
# MODULES PYTHON (SCRIPTS ET APPLICATIONS GABLUE)
# =============================================================================

# Modules requis par les scripts et applications Gablue
# (evdev/uinput = manette, pyside6 = interfaces graphiques tvqt/gablue-update/menus)
dnf5 -y install \
    python3-evdev \
    python3-uinput \
    python3-pyside6

# =============================================================================
# PAQUETS SPÉCIFIQUES AUX VARIANTES
# =============================================================================

# Paquets supplémentaires pour la variante main
if [ "$VARIANT" == "main" ]; then
    dnf5 -y install \
        radeontop
fi

# =============================================================================
# CORRECTIONS TEMPORAIRES
# =============================================================================

# Correction temporaire pour SELinux composefs/overlay (jeux 32-bit, JIT, etc.)
# Workaround de ublue-os pour les denials execmem sur composefs/overlay
# TODO: a supprimer quand le fix kernel/composefs sera disponible
dnf5 -y install ublue-os-selinux-workarounds

# Pack langue français pour OCR (skanpage)
dnf5 -y install tesseract-langpack-fra

# =============================================================================
# NETTOYAGE DES PAQUETS SUPERFLUS
# =============================================================================

# Suppression des paquets non désirés
dnf5 -y remove \
    firefox \
    firefox-langpacks \
    htop \
    fedora-flathub-remote \
    fedora-third-party \
    fedora-workstation-repositories \
    plasma-welcome-fedora \
    plasma-welcome

# Ajout de Flathub manuellement (comme ublue-os/main)
mkdir -p /etc/flatpak/remotes.d/
curl --retry 3 -Lo /etc/flatpak/remotes.d/flathub.flatpakrepo https://dl.flathub.org/repo/flathub.flatpakrepo

# Suppression spécifique à Kinoite
if [ "$SOURCE_IMAGE" == "kinoite" ]; then
    dnf5 -y remove plasma-discover-rpm-ostree
fi

# =============================================================================
# BIBLIOTHÈQUES 32-BIT POUR WINE/PROTON
# =============================================================================

    # Note: Mesa i686 déjà installé depuis le script mesa
# Note: gamescope-libs.i686 et mangohud.i686 déjà installés depuis terra-mesa ci-dessus

# -----------------------------------------------------------------------------
# Rendu de polices (REQUIS pour l'affichage texte dans Wine 32-bit)
# fontconfig et freetype tirent harfbuzz, pango, cairo, glib2, pixman, etc.
# -----------------------------------------------------------------------------

dnf5 -y --setopt=install_weak_deps=False install \
    fontconfig.i686 \
    freetype.i686

# -----------------------------------------------------------------------------
# X11 libs (REQUIS pour le rendu fenêtré Wine 32-bit)
# Sans ces libs : écrans noirs, crashs, fenêtres invisibles
# -----------------------------------------------------------------------------

dnf5 -y --setopt=install_weak_deps=False install \
    libXcomposite.i686 \
    libXcursor.i686 \
    libXdamage.i686 \
    libXfixes.i686 \
    libXi.i686 \
    libXinerama.i686 \
    libXrandr.i686 \
    libXrender.i686 \
    libXtst.i686 \
    libXv.i686

# -----------------------------------------------------------------------------
# Wayland et OpenGL (REQUIS pour le rendu Wayland Wine 32-bit)
# -----------------------------------------------------------------------------

dnf5 -y --setopt=install_weak_deps=False install \
    libepoxy.i686 \
    libdecor.i686 \
    libwayland-cursor.i686 \
    libwayland-egl.i686

# -----------------------------------------------------------------------------
# Core Wine 32-bit (réseau, SSL, débogage, impression)
# -----------------------------------------------------------------------------

dnf5 -y --setopt=install_weak_deps=False install \
    gnutls.i686 \
    libunwind.i686 \
    cups-libs.i686 \
    openldap.i686

# -----------------------------------------------------------------------------
# Audio 32-bit (REQUIS pour le son dans les jeux Wine/Proton)
# -----------------------------------------------------------------------------

# PulseAudio 32-bit (REQUIS pour l'audio Wine)
dnf5 -y --setopt=install_weak_deps=False install \
    pulseaudio-libs.i686

# PipeWire 32-bit (REQUIS pour l'audio PipeWire)
# pipewire-libs.i686 vient de Fedora updates (les dépôts bazzite sont exclus)
# Sur fc44 : la version x86_64 de l'image de base peut être en retard sur updates
# Il faut upgrader x86_64 d'abord pour aligner les versions et éviter les conflits de fichiers
dnf5 -y upgrade \
    pipewire-libs

dnf5 -y --setopt=install_weak_deps=False install \
    pipewire-libs.i686 \
    pipewire-gstreamer.i686

# FAudio pour XAudio2 dans Wine (REQUIS pour les jeux Xbox Audio)
dnf5 -y --setopt=install_weak_deps=False install \
    libFAudio \
    libFAudio.i686

# ALSA 32-bit (REQUIS pour l'audio Wine natif)
dnf5 -y --setopt=install_weak_deps=False install \
    alsa-lib.i686

# OpenAL pour l'audio des jeux 32-bit
dnf5 -y --setopt=install_weak_deps=False install \
    openal-soft.i686

# Librairies audio complémentaires (REQUISES par de nombreux jeux)
dnf5 -y --setopt=install_weak_deps=False install \
    libogg.i686 \
    libvorbis.i686 \
    flac-libs.i686 \
    libsndfile.i686

# -----------------------------------------------------------------------------
# Vulkan 32-bit
# -----------------------------------------------------------------------------

# Vulkan loader pour les applications 32-bit
dnf5 -y --enable-repo=terra-mesa --setopt=install_weak_deps=False install \
    vulkan-loader.i686

# OBS vkcapture hook libs (capture Vulkan/OpenGL sans installer OBS)
dnf5 -y --setopt=install_weak_deps=False install \
    obs-studio-plugin-vkcapture-hook-libs.x86_64 \
    obs-studio-plugin-vkcapture-hook-libs.i686

# -----------------------------------------------------------------------------
# Vidéo 32-bit (accélération matérielle pour décodage dans Wine)
# -----------------------------------------------------------------------------

dnf5 -y --setopt=install_weak_deps=False install \
    libva.i686 \
    libvdpau.i686
