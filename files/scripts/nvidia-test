#!/usr/bin/bash

# Installation des pilotes NVIDIA via akmods (version test)
# Ce script étend le script nvidia standard avec les configurations spécifiques à la version test

set -eoux pipefail

# =============================================================================
# APPEL DU SCRIPT NVIDIA STANDARD
# =============================================================================

# Exécuter d'abord le script nvidia standard
sh /ctx/nvidia

echo "Installation NVIDIA test terminée avec succès"
