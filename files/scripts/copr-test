#!/usr/bin/bash

# Configuration des dépôts COPR pour uBlue/Fedora (version test avec support 32-bit)
# Ce script configure tous les dépôts tiers nécessaires pour Gablue, incluant le support multilib

set -eoux pipefail

# =============================================================================
# PRÉPARATION INITIALE
# =============================================================================

# Création du répertoire pour éviter les erreurs GPG avec dnf5
mkdir -p /var/roothome

# =============================================================================
# CONFIGURATION DES EXCLUSIONS FEDORA
# =============================================================================

# Exclusion des paquets Mesa et kernel des dépôts Fedora officiels
# Ces paquets seront fournis par des dépôts tiers (Terra)
dnf5 -y config-manager setopt "*fedora*".exclude="mesa-* kernel-core-* kernel-modules-* kernel-uki-virt-*"

# =============================================================================
# DÉPÔTS COPR
# =============================================================================

# Activation des dépôts COPR nécessaires (incluant bazzite-multilib pour le support 32-bit)
for copr in \
        bazzite-org/bazzite \
        bazzite-org/bazzite-multilib \
        ublue-os/staging \
        ublue-os/packages \
        che/nerd-fonts \
        hikariknight/looking-glass-kvmfr \
        lizardbyte/beta \
        bazzite-org/rom-properties;
do
        dnf5 -y copr enable $copr
done && unset -v copr

# Configuration des priorités des dépôts COPR (comme Bazzite)
# bazzite* en priorité 1 pour les paquets spécifiques (kernel, akmods, etc.)
# Exclusion de pipewire/bluez/xwayland : on utilise les versions Fedora pour aligner i686/x86_64
# Le dépôt bazzite-multilib a des versions i686 en retard sur Fedora fc44, causant des conflits
dnf5 -y config-manager setopt "*bazzite*".priority=1 "*bazzite*".exclude="pipewire-* bluez-* xorg-x11-server-Xwayland wireplumber-*"

# =============================================================================
# DÉPÔTS TIERS
# =============================================================================

# Ajout du dépôt Tailscale
dnf5 -y config-manager addrepo --overwrite --from-repofile=https://pkgs.tailscale.com/stable/fedora/tailscale.repo

# Ajout du dépôt Negativo17 (RAR et autres logiciels)
dnf5 -y config-manager addrepo --from-repofile=https://negativo17.org/repos/fedora-rar.repo

# =============================================================================
# TERRA (FyraLabs)
# =============================================================================

# Installation des dépôts Terra pour des versions plus récentes
# terra-release-mesa active automatiquement le dépôt Mesa Terra
dnf5 -y install --nogpgcheck --repofrompath 'terra,https://repos.fyralabs.com/terra$releasever' terra-release terra-release-extras terra-release-mesa

# Désactivation explicite du dépôt Terra Mesa (activé uniquement quand nécessaire via --enable-repo)
dnf5 -y config-manager setopt "terra-mesa".enabled=false

# Configuration des exclusions Terra : priorité haute et exclusions spécifiques
dnf5 -y config-manager setopt "*terra*".priority=3 "*terra*".exclude="nerd-fonts topgrade scx-scheds steam python3-protobuf"

# =============================================================================
# FINALISATION
# =============================================================================

# Activation du dépôt multimédia Negativo17
sed -i 's@enabled=0@enabled=1@g' /etc/yum.repos.d/negativo17-fedora-multimedia.repo
