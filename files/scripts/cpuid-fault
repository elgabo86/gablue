#!/usr/bin/bash

# Compilation du module kernel cpuid_fault_emulation
# Ce module émule le CPUID faulting sur les CPU AMD sans support natif
# (AM4, Steam Deck). Sur les CPU avec support natif (Intel 4th gen+,
# AMD Ryzen 7000+), le module n'est pas nécessaire.

set -eoux pipefail

# =============================================================================
# SECTION 1 : DÉTECTION DE LA VERSION DU KERNEL
# =============================================================================

KVER=$(ls /usr/src/kernels/ | head -1)
echo "Kernel version: ${KVER}"

# =============================================================================
# SECTION 2 : COMPILATION DU MODULE
# =============================================================================

make -C "/usr/src/kernels/${KVER}" M=/src/cpuid-fault modules

# =============================================================================
# SECTION 3 : INSTALLATION
# =============================================================================

mkdir -p "/lib/modules/${KVER}/extra"
cp /src/cpuid-fault/cpuid_fault_emulation.ko "/lib/modules/${KVER}/extra/"

# =============================================================================
# SECTION 4 : SIGNATURE SECURE BOOT
# =============================================================================

SB_KEY="/run/secrets/gablue-kmod-key"
SB_CERT="/etc/pki/akmods/certs/gablue-kmod.der"

if [ -f "${SB_KEY}" ]; then
    /usr/src/kernels/"${KVER}"/scripts/sign-file sha256 \
        "${SB_KEY}" "${SB_CERT}" \
        "/lib/modules/${KVER}/extra/cpuid_fault_emulation.ko"
    echo "Module signed for Secure Boot"
else
    echo "WARNING: Secure Boot key not available, module is UNSIGNED"
    echo "Secure Boot users must sign manually or disable SB"
fi

# =============================================================================
# SECTION 5 : FINALISATION
# =============================================================================

depmod "${KVER}"

# Nettoyage des artefacts de compilation
rm -f /src/cpuid-fault/*.o /src/cpuid-fault/src/*.o \
      /src/cpuid-fault/*.mod* /src/cpuid-fault/Module.symvers \
      /src/cpuid-fault/modules.order

echo "Module cpuid_fault_emulation compilé et installé avec succès"
