#!/usr/bin/bash

# Script post-installation pour Gablue (version test)
# Étend post-install avec les configurations spécifiques à la version test

set -eoux pipefail

# =============================================================================
# APPEL DU POST-INSTALL STANDARD
# =============================================================================

# Exécuter d'abord le post-install standard
sh /ctx/post-install

# =============================================================================
# CONFIGURATIONS SPÉCIFIQUES À LA VERSION TEST
# =============================================================================

# Suppression des fichiers .desktop inutiles
rm -f /usr/share/applications/org.kde.plasma.bigscreen.uvcviewer.desktop

echo "Post-installation test terminée avec succès"
