#!/usr/bin/bash

# Installation du kernel ogc et des akmods (comme Bazzite unstable)
# Ce script installe le kernel depuis les images ublue-os/akmods

set -eoux pipefail

echo "::group::Executing install-kernel-test"
trap 'echo "::endgroup::"' EXIT

# =============================================================================
# SECTION 1 : PRÉPARATION
# =============================================================================

# Création des shims pour contourner le déclenchement de dracut/rpm-ostree lors de l'installation du kernel
pushd /usr/lib/kernel/install.d || exit 1
mv 05-rpmostree.install 05-rpmostree.install.bak 2>/dev/null || true
mv 50-dracut.install 50-dracut.install.bak 2>/dev/null || true
printf '%s\n' '#!/bin/sh' 'exit 0' > 05-rpmostree.install
printf '%s\n' '#!/bin/sh' 'exit 0' > 50-dracut.install
chmod +x 05-rpmostree.install 50-dracut.install
popd

# =============================================================================
# SECTION 2 : SUPPRESSION DU KERNEL EXISTANT
# =============================================================================

# Suppression des paquets kernel existants
for pkg in kernel kernel{-core,-modules,-modules-core,-modules-extra,-tools-libs,-tools}; do
    rpm --erase "${pkg}" --nodeps 2>/dev/null || true
done

# Nettoyage des résidus non couverts par les paquets kernel-*
rm -rf /usr/lib/modules

# =============================================================================
# SECTION 3 : INSTALLATION DU KERNEL OGC
# =============================================================================

# Installation du kernel depuis les RPMs d'akmods
dnf5 -y install \
    /tmp/kernel-rpms/kernel-[0-9]*.rpm \
    /tmp/kernel-rpms/kernel-core-*.rpm \
    /tmp/kernel-rpms/kernel-modules-*.rpm \
    /tmp/kernel-rpms/kernel-devel-*.rpm

# Verrouillage des versions du kernel
dnf5 versionlock add kernel kernel-devel kernel-devel-matched kernel-core kernel-modules kernel-modules-core kernel-modules-extra

# =============================================================================
# SECTION 4 : INSTALLATION DES AKMODS (KMODS)
# =============================================================================

# Installation des kmods critiques individuellement (depuis /tmp/rpms/common et /tmp/rpms/kmods)
# Ces kmods sont obligatoires : l'échec de l'un d'eux fait échouer le build
for rpm in /tmp/rpms/{common,kmods}/*v4l2loopback*.rpm \
           /tmp/rpms/{common,kmods}/*xone*.rpm \
           /tmp/rpms/{common,kmods}/*xpadneo*.rpm; do
    dnf5 -y install "$rpm"
done

# Installation des kmods critiques extras individuellement (depuis akmods-extra)
# Ces kmods sont obligatoires : l'échec de l'un d'eux fait échouer le build
for rpm in /tmp/rpms/{extra,kmods-extra}/*zenergy*.rpm \
           /tmp/rpms/{extra,kmods-extra}/*gcadapter*.rpm \
           /tmp/rpms/{extra,kmods-extra}/*evdi*.rpm; do
    dnf5 -y install "$rpm"
done

# Installation des kmods optionnels individuellement (depuis /tmp/rpms/common et /tmp/rpms/kmods)
# Ces kmods sont optionnels : un échec n'empêche pas les autres de s'installer
for rpm in /tmp/rpms/{common,kmods}/*framework-laptop*.rpm \
           /tmp/rpms/{common,kmods}/*openrazer*.rpm; do
    dnf5 -y install "$rpm" || echo "SKIPPED: ${rpm}"
done

# Installation des kmods optionnels extras individuellement (depuis akmods-extra)
# Ces kmods sont optionnels : un échec n'empêche pas les autres de s'installer
for rpm in /tmp/rpms/{extra,kmods-extra}/*new-lg4ff*.rpm \
           /tmp/rpms/{extra,kmods-extra}/*t150-driver*.rpm \
           /tmp/rpms/{extra,kmods-extra}/*hid-fanatecff*.rpm \
           /tmp/rpms/{extra,kmods-extra}/*sc0710*.rpm \
           /tmp/rpms/{extra,kmods-extra}/*system76*.rpm; do
    dnf5 -y install "$rpm" || echo "SKIPPED: ${rpm}"
done

# =============================================================================
# SECTION 5 : RESTAURATION DES SCRIPTS D'INSTALLATION DU KERNEL
# =============================================================================

pushd /usr/lib/kernel/install.d || exit 1
mv -f 05-rpmostree.install.bak 05-rpmostree.install 2>/dev/null || true
mv -f 50-dracut.install.bak 50-dracut.install 2>/dev/null || true
popd

# =============================================================================
# SECTION 6 : INSTALLATION DES OUTILS SUPPLÉMENTAIRES
# =============================================================================

# Installation de scx-scheds depuis COPR bieszczaders/kernel-cachyos-addons
dnf5 -y copr enable bieszczaders/kernel-cachyos-addons && \
dnf5 -y install \
    scx-scheds \
    scx-tools && \
dnf5 -y copr disable bieszczaders/kernel-cachyos-addons

echo "Kernel ogc ${KERNEL_VERSION} installé avec succès avec les akmods"
