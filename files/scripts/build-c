#!/usr/bin/bash

# Script de compilation des sources C du projet
# Compile et installe les binaires C natifs pour remplacer les scripts Python gourmands en RAM

set -eoux pipefail

# =============================================================================
# COMPILATION DES SOURCES C
# =============================================================================

# Dépendances de compilation (supprimées après build)
dnf5 -y install gcc dbus-devel

# Compilation et installation de gamepadshortcuts
# Remplace le script Python gamepadshortcuts.py (~28Mo RAM) par un binaire C natif (~500Ko RAM)
# Utilise libdbus-1 pour l'inhibition ecran (~200Ko PSS vs 6.2Mo systemd-inhibit)
if [ -d /src/gamepadshortcuts ]; then
    make -C /src/gamepadshortcuts install DESTDIR=
    rm -rf /src/gamepadshortcuts
else
    echo "ATTENTION: Sources C non trouvees dans /src/gamepadshortcuts"
fi

# Compilation et installation de ds2xbox
# Emulateur de manette Xbox 360 pour manettes Sony (DualSense, DualShock 4)
if [ -d /src/ds2xbox ]; then
    make -C /src/ds2xbox install DESTDIR=
    rm -rf /src/ds2xbox
else
    echo "ATTENTION: Sources C non trouvees dans /src/ds2xbox"
fi

# Compilation et installation de gablue-isomount
# Remplace le plugin dolphin-plugins mountisoaction (defectueux, bug KDE #471487)
# Monte les images disque via UDisks2 et assure le rafraichissement du panneau Devices
if [ -d /src/gablue-isomount ]; then
    make -C /src/gablue-isomount install DESTDIR=
    rm -rf /src/gablue-isomount
else
    echo "ATTENTION: Sources C non trouvees dans /src/gablue-isomount"
fi

# Nettoyage des dependances de compilation (inutiles dans l'image finale)
dnf5 -y remove gcc dbus-devel || true

# Compilation du hook composefs-fix (correction espace libre Dolphin)
# Necessite gcc, donc compile ici avant de le supprimer
if [ -d /usr/src/composefs-fix ]; then
    make -C /usr/src/composefs-fix install
    rm -rf /usr/src/composefs-fix
fi

# Nettoyage du repertoire sources si vide
rmdir /src 2>/dev/null || true
