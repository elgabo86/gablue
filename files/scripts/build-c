#!/usr/bin/bash

# Script de compilation des sources C du projet
# Compile et installe les binaires C natifs pour remplacer les scripts Python gourmands en RAM
# ECHEC DU BUILD si une source est absente ou si un binaire manque apres compilation

set -eoux pipefail

# =============================================================================
# COMPILATION DES SOURCES C
# =============================================================================

# Dépendances de compilation (supprimées après build)
dnf5 -y install gcc dbus-devel

# Fonction de build securisee : compile et verifie le binaire final
build_and_verify() {
    local src_dir="$1"
    local binary="$2"
    local name="$3"

    if [ ! -d "$src_dir" ]; then
        echo "ERREUR FATALE : sources C '$name' absentes dans $src_dir" >&2
        exit 1
    fi

    make -C "$src_dir" install DESTDIR=
    rm -rf "$src_dir"

    if [ ! -f "/usr/bin/$binary" ]; then
        echo "ERREUR FATALE : binaire '$binary' absent apres compilation de $name" >&2
        exit 1
    fi
    echo "OK : $binary compile et installe"
}

build_and_verify "/src/gamepadshortcuts" "gamepadshortcuts" "gamepadshortcuts"
build_and_verify "/src/ds2xbox" "ds2xbox" "ds2xbox"
build_and_verify "/src/gablue-isomount" "gablue-isomount" "gablue-isomount"

# Compilation du hook composefs-fix (correction espace libre Dolphin)
# Necessite gcc, compile AVANT de supprimer le compilateur
if [ -d /src/composefs-fix ]; then
    make -C /src/composefs-fix install
    rm -rf /src/composefs-fix
    if [ ! -f /usr/lib64/gablue-composefs-fix.so ]; then
        echo "ERREUR FATALE : echec de compilation de gablue-composefs-fix.so" >&2
        exit 1
    fi
fi

# Nettoyage du repertoire sources si vide
rmdir /src 2>/dev/null || true
