#!/usr/bin/bash

# Script post-installation pour Gablue
# Configure les permissions, installe les binaires externes et effectue le branding

set -eoux pipefail

# =============================================================================
# PERMISSIONS DES EXÉCUTABLES
# =============================================================================

# Rendre exécutables les scripts système Gablue
chmod +x /usr/bin/ventoy
chmod +x /usr/bin/dlcover
chmod +x /usr/bin/lol
chmod +x /usr/bin/dlv
chmod +x /usr/bin/citron-install
chmod +x /usr/bin/eden-install
chmod +x /usr/bin/gskill
chmod +x /usr/bin/limitw
chmod +x /usr/bin/encode64
chmod +x /usr/bin/decode64
chmod +x /usr/bin/qwen-install
chmod +x /usr/bin/clean-media
chmod +x /usr/bin/azahar-install
chmod +x /usr/bin/xenia-install
chmod +x /usr/bin/shadps4-install
chmod +x /usr/bin/scrap-win
chmod +x /usr/bin/wgpcheck
chmod +x /usr/bin/wgpadd
chmod +x /usr/bin/esde-install
chmod +x /usr/bin/lgp-thumbnailer
chmod +x /usr/bin/wgp-thumbnailer
chmod +x /usr/bin/ds2xbox
chmod +x /usr/bin/gamepadshortcuts
chmod +x /usr/bin/tv
chmod +x /usr/bin/tvqt
chmod +x /usr/bin/gablue-bigscreen-swap-session
chmod +x /usr/bin/wallpaper-import

chmod +x /usr/bin/gablue-isomount
chmod +x /usr/bin/gablue-update
chmod +x /usr/libexec/gablue-config
chmod +x /usr/libexec/archgab-update
chmod +x /usr/libexec/gablue-bigscreen-session-init
chmod +x /usr/libexec/gablue-dx-groups

# Rendre exécutables les scripts supplémentaires Gablue
chmod +x /usr/share/ublue-os/gablue/scripts/*.sh
chmod +x /usr/share/ublue-os/gablue/scripts/*.py
chmod +x /usr/share/ublue-os/gablue/scripts/gamepadshortcuts/*

# =============================================================================
# CAPACITÉS SYSTÈME (CAPABILITIES)
# =============================================================================

# Donner les capacités d'ordonnancement temps réel à Gamescope
setcap 'cap_sys_nice=eip' /usr/bin/gamescope

# =============================================================================
# MODULES SELINUX
# =============================================================================

# Compilation et installation des modules SELinux personnalisés
# Les modules .te sont compilés en .pp pendant le build pour garantir la compatibilité
SELINUX_PACKAGES_DIR="/usr/share/selinux/packages"

if [ -d "$SELINUX_PACKAGES_DIR" ]; then
    for te_file in "$SELINUX_PACKAGES_DIR"/*.te; do
        if [ -f "$te_file" ]; then
            module_name=$(basename "$te_file" .te)
            mod_file="${SELINUX_PACKAGES_DIR}/${module_name}.mod"
            pp_file="${SELINUX_PACKAGES_DIR}/${module_name}.pp"
            
            echo "Compilation du module SELinux: $module_name"
            checkmodule -M -m -o "$mod_file" "$te_file"
            semodule_package -o "$pp_file" -m "$mod_file"
            
            echo "Installation du module SELinux: $module_name"
            semodule --verbose --install "$pp_file"
            
            # Nettoyage des fichiers temporaires de compilation
            rm -f "$mod_file"
fi

# =============================================================================
# CORRECTION COMPOSEFS - ESPACE DISQUE DOLPHIN
# =============================================================================

# Injection du LD_PRELOAD dans le .desktop Dolphin
# Le hook gablue-composefs-fix.so est compile dans build-c (necessite gcc)
SO_PATH="/usr/lib64/gablue-composefs-fix.so"
if [ ! -f "$SO_PATH" ]; then
    echo "ERREUR FATALE : $SO_PATH absent, build corrompu" >&2
    exit 1
fi
sed -i 's|^Exec=dolphin %u|Exec=env LD_PRELOAD=/usr/lib64/gablue-composefs-fix.so dolphin %u|' \
    /usr/share/applications/org.kde.dolphin.desktop
echo "Composefs fix active dans Dolphin"
    done && unset -v te_file module_name mod_file pp_file
fi

# =============================================================================
# INSTALLATION DES BINAIRES EXTERNES
# =============================================================================

# Installation de RetroPlayer (TUI lecteur de musiques rétro)
# Téléchargement du binaire depuis la dernière release GitHub
curl -fsSL https://github.com/elgabo86/retroplayer/releases/latest/download/retroplayer -o /usr/bin/retroplayer
chmod +x /usr/bin/retroplayer

# Installation de ZXTune (lecteur de musique tracker/chiptune)
# Exclusion des binaires non nécessaires
curl -s https://storage.zxtune.ru/builds/public/r5100/linux/x86_64/zxtune_r5100_linux_x86_64.tar.gz | tar -xzf - -C / --exclude=./usr/bin/zxtune123 --exclude=./usr/bin/xtractor

# =============================================================================
# BRANDING GABLUE
# =============================================================================

# Configuration de l'identité du système
IMAGE_DATE=$(date +%Y%m%d.%H)
MAJOR_RELEASE_VERSION=$(grep -oP '[0-9]*' /etc/fedora-release)
sed -i "s,^PRETTY_NAME=.*,PRETTY_NAME=\"Gablue ${MAJOR_RELEASE_VERSION}.${IMAGE_DATE}\"," /usr/lib/os-release

# Configuration des icônes KDE pour Kinoite
if [ "$SOURCE_IMAGE" == "kinoite" ]; then
    ln -sf /usr/share/icons/Papirus/24x24/apps/distributor-logo-fedora.svg /usr/share/icons/Papirus/16x16/symbolic/places/start-here-kde-symbolic.svg
    ln -sf /usr/share/icons/Papirus/24x24/apps/distributor-logo-fedora.svg /usr/share/icons/Papirus/22x22/symbolic/places/start-here-kde-symbolic.svg
    ln -sf /usr/share/icons/Papirus/24x24/apps/distributor-logo-fedora.svg /usr/share/icons/Papirus/24x24/symbolic/places/start-here-kde-symbolic.svg
fi

# =============================================================================
# CONFIGURATION SYSTÈME
# =============================================================================

# Configuration des profils tuned pour Gablue
sed -i 's/balanced=balanced$/balanced=balanced-gablue/' /etc/tuned/ppd.conf
sed -i 's/performance=throughput-performance$/performance=throughput-performance-gablue/' /etc/tuned/ppd.conf
sed -i 's/balanced=balanced-battery$/balanced=balanced-battery-gablue/' /etc/tuned/ppd.conf
sed -i 's/power-saver=powersave$/power-saver=powersave-gablue/' /etc/tuned/ppd.conf
sed -i 's/balanced=balanced-battery$/balanced=balanced-battery-gablue\npower-saver=powersave-battery-gablue/' /etc/tuned/ppd.conf

# Activer le support HID userspace pour Bluetooth
sed -i 's/#UserspaceHID.*/UserspaceHID=true/' /etc/bluetooth/input.conf

# Corriger les erreurs de bus QT6 sur Kinoite
# Qt6 fournit le binaire sous le nom qdbus-qt6 (plus de /bin/qdbus) : on crée
# les alias qdbus6 et qdbus attendus par certaines applications (dont kdialog)
if [ "$SOURCE_IMAGE" == "kinoite" ] && [ -e /usr/bin/qdbus-qt6 ]; then
    ln -sf /usr/bin/qdbus-qt6 /usr/bin/qdbus6
    ln -sf /usr/bin/qdbus-qt6 /usr/bin/qdbus
fi

# =============================================================================
# CONFIGURATION PIPEWIRE (LATENCE AUDIO)
# =============================================================================

# Réduire le quantum de 1024 à 256 pour diviser par 4 la latence audio
sed -i 's/#default.clock.quantum       = 1024/default.clock.quantum       = 256/' /usr/share/pipewire/pipewire.conf
sed -i 's/default.clock.min-quantum = 1024/default.clock.min-quantum = 256/' /usr/share/pipewire/pipewire.conf

#MAJ Seulement le samedi
# 1. Flatpak : passer de quotidien à samedi
sed -i 's/OnCalendar=\*-\*-\* 4:00:00/OnCalendar=Sat \*-\*-\* 04:00:00/' /usr/lib/systemd/system/flatpak-system-update.timer
sed -i 's/OnCalendar=\*-\*-\* 4:00:00/OnCalendar=Sat \*-\*-\* 04:00:00/' /usr/lib/systemd/user/flatpak-user-update.timer

# 2. Flatpak : supprimer le déclenchement 2 min après boot
sed -i '/OnBootSec=/d' /usr/lib/systemd/system/flatpak-system-update.timer
sed -i '/OnBootSec=/d' /usr/lib/systemd/user/flatpak-user-update.timer

# 3. rpm-ostree : override timer → samedi 04:00 + delai aléatoire 10 min
sed -i 's/OnCalendar=\*-\*-\* 4:00:00/OnCalendar=Sat \*-\*-\* 04:00:00/' /usr/lib/systemd/system/rpm-ostreed-automatic.timer.d/override.conf
sed -i '/OnBootSec=/d'        /usr/lib/systemd/system/rpm-ostreed-automatic.timer.d/override.conf
sed -i '/OnUnitInactiveSec=/d' /usr/lib/systemd/system/rpm-ostreed-automatic.timer.d/override.conf
echo 'RandomizedDelaySec=10m' >> /usr/lib/systemd/system/rpm-ostreed-automatic.timer.d/override.conf

# 4. Activer les mises à jour automatiques rpm-ostree (stage)
cp /usr/share/ublue-os/update-services/etc/rpm-ostreed.conf /etc/rpm-ostreed.conf

# 5. Brew : passer de périodique à samedi 04:00 + délai aléatoire 10 min
sed -i 's/OnBootSec=10min/OnCalendar=Sat *-*-* 04:00:00/' /usr/lib/systemd/system/brew-update.timer
sed -i '/OnUnitInactiveSec=/d' /usr/lib/systemd/system/brew-update.timer
echo 'RandomizedDelaySec=10m' >> /usr/lib/systemd/system/brew-update.timer
sed -i 's/OnBootSec=30min/OnCalendar=Sat *-*-* 04:00:00/' /usr/lib/systemd/system/brew-upgrade.timer
sed -i '/OnUnitInactiveSec=/d' /usr/lib/systemd/system/brew-upgrade.timer
echo 'RandomizedDelaySec=10m' >> /usr/lib/systemd/system/brew-upgrade.timer

# 6. Ajouter linuxbrew au secure_path de sudo
sed -Ei 's|secure_path = (.*)|secure_path = \1:/home/linuxbrew/.linuxbrew/bin|' /etc/sudoers

# =============================================================================
# CORRECTION COMPLÉTION UJUST
# =============================================================================

# Le RPM ublue-os-just génère une complétion qui enregistre pour 'just'
# au lieu de 'ujust' (just --completions ne tient pas compte du nom de commande).
# On écrase le fichier avec notre version custom basée sur ujust --summary.
cat > /usr/share/bash-completion/completions/ujust << 'UJUSTEOF'
# Completion bash pour ujust
# Génère dynamiquement la liste des recettes du justfile ublue

_ujust() {
    local cur
    cur="${COMP_WORDS[COMP_CWORD]}"

    if [[ $COMP_CWORD -eq 1 ]]; then
        local recipes
        recipes=$(ujust --summary 2>/dev/null)
        COMPREPLY=( $(compgen -W "${recipes}" -- "${cur}") )
    fi
}
complete -F _ujust ujust
UJUSTEOF

# =============================================================================
# NETTOYAGE DES CONFIGURATIONS
# =============================================================================

# Supprimer la configuration par défaut d'Atuin
if [ -f /etc/profile.d/atuin.sh ]; then
    rm -f /etc/profile.d/atuin.sh
    echo "Le fichier /etc/profile.d/atuin.sh a été supprimé."
else
    echo "Le fichier /etc/profile.d/atuin.sh n'existe pas."
fi

# =============================================================================
# DÉSACTIVATION DES DÉPÔTS
# =============================================================================

# Désactiver les dépôts COPR après installation
for copr in \
        bazzite-org/bazzite \
        ublue-os/staging \
        ublue-os/packages \
        che/nerd-fonts \
        hikariknight/looking-glass-kvmfr \
        lizardbyte/beta \
        bazzite-org/rom-properties;
do
        dnf5 -y copr disable $copr
done && unset -v copr

# Désactiver les dépôts supplémentaires
test -f /etc/yum.repos.d/_copr:copr.fedorainfracloud.org:phracek:PyCharm.repo && sed -i 's@enabled=1@enabled=0@g' /etc/yum.repos.d/_copr:copr.fedorainfracloud.org:phracek:PyCharm.repo || true
test -f /etc/yum.repos.d/_copr_ublue-os-akmods.repo && sed -i 's@enabled=1@enabled=0@g' /etc/yum.repos.d/_copr_ublue-os-akmods.repo || true
test -f /etc/yum.repos.d/tailscale.repo && sed -i 's@enabled=1@enabled=0@g' /etc/yum.repos.d/tailscale.repo || true
test -f /etc/yum.repos.d/docker-ce.repo && sed -i 's@enabled=1@enabled=0@g' /etc/yum.repos.d/docker-ce.repo || true
dnf5 -y config-manager setopt "terra".enabled=false || true

# =============================================================================
# CONFIGURATION MIME PAR DÉFAUT
# =============================================================================

# Définir Windows.desktop comme application par défaut pour les exécutables Windows
if [ -f /usr/share/applications/mimeapps.list ]; then
    # S'assurer que la section [Default Applications] existe
    if ! grep -q "^\[Default Applications\]$" /usr/share/applications/mimeapps.list; then
        echo "[Default Applications]" >> /usr/share/applications/mimeapps.list
    fi
    
    # Ajouter ou remplacer les associations MIME pour Windows.desktop
    for mimetype in \
        "application/x-ms-dos-executable" \
        "application/vnd.microsoft.portable-executable" \
        "application/x-msi" \
        "application/x-ms-shortcut" \
        "application/x-wine-extension-msp" \
        "application/x-bat" \
        "application/x-wgp"; do
        # Supprimer l'ancienne association si elle existe (utiliser # comme délimiteur pour éviter les conflits avec /)
        sed -i "\#^${mimetype}=#d" /usr/share/applications/mimeapps.list
        # Ajouter la nouvelle association
        sed -i "/^\[Default Applications\]/a ${mimetype}=Windows.desktop" /usr/share/applications/mimeapps.list
    done

    # Ajouter l'association pour les fichiers .lgp (Linux Game Project)
    sed -i "\#^application/x-lgp=#d" /usr/share/applications/mimeapps.list
    sed -i "/^\[Default Applications\]/a application/x-lgp=Linux.desktop" /usr/share/applications/mimeapps.list
fi

# Mettre à jour la base de données MIME pour les nouveaux types
update-mime-database /usr/share/mime || true

# =============================================================================
# NETTOYAGE DES FICHIERS DE BUREAU
# =============================================================================

# Supprimer les raccourcis d'applications non utilisés
rm -f /usr/share/applications/kde4/knetattach.desktop
rm -f /usr/share/applications/org.kde.kdebugsettings.desktop
rm -f /usr/share/applications/org.kde.kdeconnect.sms.desktop
rm -f /usr/share/applications/byobu.desktop
rm -f /usr/share/applications/org.kde.plasma.bigscreen.uvcviewer.desktop
rm -f /usr/share/applications/btop.desktop
rm -f /usr/share/applications/htop.desktop
rm -f /usr/share/applications/nvtop.desktop
rm -f /usr/share/applications/firewall-config.desktop
rm -f /usr/share/applications/org.kde.kjournaldbrowser.desktop
sed -i '/^\[Desktop Entry\]/a NoDisplay=true' /usr/share/applications/org.kde.foreground-booster.desktop

# Remplacer le swap-session bigscreen par le wrapper Gablue
# Écrase le script original (appelé via QProcess par bigscreen, pas via .desktop)
# - Lance l'inputhandler via kioclient avant le swap
# - Tue l'inputhandler et relance xwaylandvideobridge au retour
cp /usr/bin/gablue-bigscreen-swap-session /usr/bin/plasma-bigscreen-swap-session

# Supprimer Waydroid uniquement sur la variante main
if [ "$VARIANT" == "main" ]; then
    rm -f /usr/share/applications/Waydroid.desktop
fi

# =============================================================================
# OPTIMISATIONS FINALES
# =============================================================================

# Supprimer os-prober pour accélérer les redémarrages après mise à jour
rm -f /etc/grub.d/30_os-prober

# Désactiver la vérification Flatpak à chaque démarrage
sed -i -E 's|(; /usr/bin/flatpak --system repair)$||' /usr/lib/systemd/system/flatpak-system-update.service

# =============================================================================
# CONFIGURATIONS SUPPLÉMENTAIRES (MODE DX)
# =============================================================================

# Configuration supplémentaire uniquement pour le mode DX (développement)
if [ "${DX_MODE:-false}" == "true" ]; then
    # Charger le module iptable_nat pour Docker-in-Docker
    # Voir:
    #   - https://github.com/ublue-os/bluefin/issues/2365
    #   - https://github.com/devcontainers/features/issues/1235
    mkdir -p /etc/modules-load.d && cat >>/etc/modules-load.d/ip_tables.conf <<EOF
iptable_nat
EOF

fi

# =============================================================================
# ASSOCIATION MIME POUR GABLUE-ISOMOUNT
# =============================================================================

# Remplacer le plugin dolphin-plugins mountisoaction (bug KDE #471487)
# gablue-isomount gere le montage d'images disque avec rafraichissement
# correct du panneau Devices de Dolphin
for mime in application/x-cd-image application/x-iso9660-image \
            application/x-raw-disk-image application/vnd.efi.iso \
            application/vnd.efi.img application/x-apple-diskimage \
            application/x-compressed-iso application/x-raw-cd-image \
            application/x-raw-floppy-disk-image \
            application/x-raw-disk-image-xz-compressed; do
    xdg-mime default gablue-open-iso.desktop "$mime" || true
done && unset -v mime
