#!/usr/bin/bash

# Installation de packages Python depuis PyPI (sans équivalent RPM Fedora)
# Utilise uv (installé via RPM) pour installer dans le Python système

set -eoux pipefail

# =============================================================================
# PACKAGES PYTHON PYPI
# =============================================================================

# Correction conflit : un RPM peut avoir créé un fichier ou symlink à la place
# d'un répertoire dans le chemin (ex: transition majeure Python), ce qui bloque
# uv pip install (File exists). On remonte la hiérarchie et nettoie tout ce qui
# n'est pas un répertoire, puis on crée le dossier.
TARGET="/usr/local/lib/python3.14/site-packages"
CURRENT=""
IFS="/" read -ra PARTS <<< "$TARGET"
for PART in "${PARTS[@]}"; do
    [ -z "$PART" ] && continue
    CURRENT="${CURRENT}/${PART}"
    if [ ! -d "$CURRENT" ]; then
        rm -f "$CURRENT"
    fi
done
mkdir -p "$TARGET"

uv pip install --system --break-system-packages \
    terminaltexteffects
