#!/usr/bin/bash

# Installation Mesa Terra pour les images test (multilib)
# Version multilib du script mesa avec support i686 complet
# Bug Terra fc44 : mesa-vulkan-drivers.i686 a un conflit de fichier
# LICENSE.dependencies avec x86_64 (fichier identique, pas marqué %_netsharedpath)
# Workaround : installer x86_64 + i686 ensemble, puis vulkan-drivers.i686
# via rpm --excludepath pour sauter uniquement le chemin en conflit

set -eoux pipefail

# Swap Mesa filesystem avec la version Terra
dnf5 -y swap --from-repo=terra-mesa --enable-repo=terra-mesa mesa-filesystem mesa-filesystem

# Installer les paquets Mesa x86_64
dnf5 -y --enable-repo=terra-mesa install \
    mesa-dri-drivers \
    mesa-libEGL \
    mesa-libGL \
    mesa-libgbm \
    mesa-vulkan-drivers

# Installer les paquets Mesa i686 (sauf mesa-vulkan-drivers qui a un conflit de fichier)
dnf5 -y --enable-repo=terra-mesa install \
    mesa-dri-drivers.i686 \
    mesa-libEGL.i686 \
    mesa-libGL.i686 \
    mesa-libgbm.i686

# Dépendances i686 de mesa-vulkan-drivers (nécessaires avant l'install via rpm --nodeps)
# Sans ces libs au runtime, libvulkan_radeon.so ne charge pas et Vulkan 32-bit échoue
dnf5 -y --setopt=install_weak_deps=False install \
    libdisplay-info.i686 \
    systemd-libs.i686 \
    vulkan-loader.i686

# mesa-vulkan-drivers.i686 : bug de packaging Terra fc44
# Le fichier LICENSE.dependencies est identique entre i686 et x86_64
# mais Terra ne le marque pas dans %_netsharedpath, donc RPM le signale en conflit
# On installe via rpm --excludepath pour sauter uniquement ce chemin
# (le fichier est déjà fourni par le paquet x86_64)
dnf5 -y --enable-repo=terra-mesa download --destdir=/tmp mesa-vulkan-drivers.i686
rpm -i --nodeps --excludepath=/usr/share/licenses/mesa-vulkan-drivers /tmp/mesa-vulkan-drivers-*.i686.rpm
rm -f /tmp/mesa-vulkan-drivers-*.i686.rpm

# Verrouiller les versions Mesa pour éviter les downgrades
dnf5 versionlock add \
    mesa-dri-drivers \
    mesa-filesystem \
    mesa-libEGL \
    mesa-libGL \
    mesa-libgbm \
    mesa-vulkan-drivers
