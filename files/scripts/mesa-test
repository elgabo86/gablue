#!/usr/bin/bash

# Installation Mesa Terra pour les images test (multilib)
# Version multilib du script mesa avec support i686 complet
# Workaround pour le bug de packaging Terra fc44 :
# mesa-vulkan-drivers.i686 entre en conflit de fichier avec x86_64

set -eoux pipefail

# Swap Mesa filesystem avec la version Terra
dnf5 -y swap --from-repo=terra-mesa --enable-repo=terra-mesa mesa-filesystem mesa-filesystem

# Installer les paquets Mesa principaux x86_64
dnf5 -y --enable-repo=terra-mesa install \
    mesa-dri-drivers \
    mesa-libEGL \
    mesa-libGL \
    mesa-libgbm \
    mesa-vulkan-drivers

# Installer les paquets Mesa i686 (sauf mesa-vulkan-drivers qui a un conflit de fichier)
dnf5 -y --enable-repo=terra-mesa install \
    mesa-dri-drivers.i686 \
    mesa-libEGL.i686 \
    mesa-libGL.i686 \
    mesa-libgbm.i686

# Dépendances i686 de mesa-vulkan-drivers (nécessaires avant l'install via rpm)
dnf5 -y --setopt=install_weak_deps=False install \
    libdisplay-info.i686 \
    systemd-libs.i686 \
    vulkan-loader.i686

# mesa-vulkan-drivers.i686 : workaround pour le conflit LICENSE.dependencies
# Bug Terra fc44 : le fichier /usr/share/licenses/mesa-vulkan-drivers/LICENSE.dependencies
# est identique entre i686 et x86_64 mais RPM le marque en conflit
# Les dépendances i686 sont déjà installées ci-dessus, --nodeps est sûr
dnf5 -y --enable-repo=terra-mesa download --destdir=/tmp mesa-vulkan-drivers.i686
rpm -i --nodeps --force /tmp/mesa-vulkan-drivers-*.i686.rpm
rm -f /tmp/mesa-vulkan-drivers-*.i686.rpm

# Verrouiller les versions Mesa pour éviter les downgrades
dnf5 versionlock add \
    mesa-dri-drivers \
    mesa-filesystem \
    mesa-libEGL \
    mesa-libGL \
    mesa-libgbm \
    mesa-vulkan-drivers
