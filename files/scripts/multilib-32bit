#!/usr/bin/bash

# Installation du support 32-bit (i686) pour Wine/Proton
# Ce script installe les bibliothèques 32-bit nécessaires pour exécuter des applications Windows 32-bit
# Inspiré de Bazzite - Installation minimale, les dépendances sont résolues automatiquement

set -eoux pipefail

# =============================================================================
# BIBLIOTHÈQUES SYSTÈME DE BASE 32-BIT
# =============================================================================

# Glibc et libs système de base (requis pour tout binaire 32-bit)
dnf5 -y install \
    glibc.i686 \
    libgcc.i686 \
    libstdc++.i686

# =============================================================================
# BIBLIOTHÈQUES GRAPHIQUES MESA 32-BIT
# =============================================================================

# Mesa 32-bit pour le rendu graphique
# Installation depuis tous les dépôts pour résoudre les dépendances
dnf5 -y install \
    mesa-dri-drivers.i686 \
    mesa-libEGL.i686 \
    mesa-libGL.i686 \
    mesa-libgbm.i686 \
    mesa-vulkan-drivers.i686 \
    mesa-filesystem.i686

# Verrouiller les versions Mesa 32-bit
dnf5 versionlock add \
    mesa-dri-drivers.i686 \
    mesa-filesystem.i686 \
    mesa-libEGL.i686 \
    mesa-libGL.i686 \
    mesa-libgbm.i686 \
    mesa-vulkan-drivers.i686

# =============================================================================
# BIBLIOTHÈQUES AUDIO 32-BIT
# =============================================================================

# FAudio pour le support audio des jeux 32-bit
dnf5 -y --setopt=install_weak_deps=False install \
    libFAudio.i686

# PulseAudio/PipeWire 32-bit (REQUIS pour l'audio Wine)
dnf5 -y --setopt=install_weak_deps=False install \
    pulseaudio-libs.i686

# =============================================================================
# BIBLIOTHÈQUES GAMING 32-BIT
# =============================================================================

# Vulkan loader pour les applications 32-bit (mangohud déjà installé par rpm-test)
dnf5 -y --setopt=install_weak_deps=False install \
    vulkan-loader.i686
