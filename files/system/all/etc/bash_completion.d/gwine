#!/bin/bash
# Autocomplétion Bash pour Gwine

gwine_completions() {
    local cur prev opts
    COMPREPLY=()
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"

    # Options disponibles
    opts="--help -h --fix --exewgp --init --offline --update --kdialog --cmd
          --regedit --reg --winecfg --winetricks --winetrick --download-components
          --cachepack --nosandbox --joytest --args --gameid --use-ln-mounts --kill --dir
          --wayland --env"

    # Si on complète une option
    if [[ ${cur} == -* ]]; then
        COMPREPLY=( $(compgen -W "${opts}" -- ${cur}) )
        return 0
    fi

    # Si l'option précédente nécessite un fichier
    case "${prev}" in
        --reg)
            COMPREPLY=( $(compgen -f -- ${cur}) )
            return 0
            ;;
        --args)
            # Pas d'autocomplétion pour les arguments
            return 0
            ;;
    esac

    # Gestion de --dir avec sous-commandes
    local prev_prev="${COMP_WORDS[COMP_CWORD-2]}"
    if [[ "${prev_prev}" == "--dir" ]]; then
        case "${prev}" in
            add|del)
                # Autocomplétion des répertoires
                COMPREPLY=( $(compgen -d -- ${cur}) )
                return 0
                ;;
        esac
    fi

    # Si on vient de --dir sans sous-commande
    if [[ "${prev}" == "--dir" ]]; then
        local dir_subcmds="add del list reset"
        COMPREPLY=( $(compgen -W "${dir_subcmds}" -- ${cur}) )
        return 0
    fi

    # Autocomplétion des fichiers .wgp et .exe avec gestion des espaces
    local IFS=$'\n'
    local files
    files=$(compgen -f -X '!*.@(wgp|exe)' -- "${cur}" 2>/dev/null)
    COMPREPLY=( ${files} $(compgen -f -- "${cur}") )
}

complete -F gwine_completions gwine
