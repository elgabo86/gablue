#!/bin/bash
INPUT="$1"    # %i
OUTPUT="$2"   # %o
SIZE="$3"     # %s (128 ou 256)

[ -z "$SIZE" ] && SIZE=256

EXEICONEXTRACT="/usr/share/ublue-os/gablue/scripts/exeiconextract.py"

# Fichier lock unique par PID pour éviter les race conditions
LOCK_FILE="/tmp/wgp-thumbnailer.${MY_PID}.lock"
MY_PID=$$

# Rate limiting: attendre que le thumbnailer précédent (quel qu'il soit) ait fini
# Cela évite de surcharger Dolphin avec trop de callbacks simultanés
rate_limit() {
    local max_wait=30
    local waited=0
    while [ -f /tmp/wgp-thumbnailer.active ] && [ $waited -lt $max_wait ]; do
        sleep 0.05
        waited=$((waited + 1))
    done
    # Marquer comme actif
    touch /tmp/wgp-thumbnailer.active
}

# Vérification rapide: si fichier en cours d'écriture, on abandonne (Dolphin rappellera plus tard)
size1=$(stat -c %s "$INPUT" 2>/dev/null) || { rm -f /tmp/wgp-thumbnailer.active 2>/dev/null; exit 1; }
sleep 0.1
size2=$(stat -c %s "$INPUT" 2>/dev/null) || { rm -f /tmp/wgp-thumbnailer.active 2>/dev/null; exit 1; }
if [ "$size1" != "$size2" ]; then
    rm -f /tmp/wgp-thumbnailer.active 2>/dev/null
    exit 1  # Fichier en cours d'écriture, on sort
fi

# Rate limiting pour éviter de surcharger Dolphin
rate_limit

TEMP_MOUNT=$(mktemp -d)
TEMP_ICO=$(mktemp -d)

# Fonction de sortie propre qui appelle cleanup puis exit
cleanup_and_exit() {
    local exit_code=$1
    cleanup
    exit $exit_code
}

# Nettoyage complet en toute circonstance
cleanup() {
    # Tuer le processus squashfuse explicitement si on l'a enregistré
    SQUASHFUSE_PID_FILE="/tmp/wgp-thumbnailer-squashfuse.${MY_PID}.pid"
    if [ -f "$SQUASHFUSE_PID_FILE" ]; then
        local stored_pid
        stored_pid=$(cat "$SQUASHFUSE_PID_FILE" 2>/dev/null)
        if [ -n "$stored_pid" ]; then
            kill -TERM "$stored_pid" 2>/dev/null || true
            # Attendre que le processus soit vraiment mort
            for i in 1 2 3; do
                kill -0 "$stored_pid" 2>/dev/null || break
                sleep 0.1
            done
            kill -KILL "$stored_pid" 2>/dev/null || true
        fi
        rm -f "$SQUASHFUSE_PID_FILE"
    fi
    # Démontage forcé
    if mountpoint -q "$TEMP_MOUNT" 2>/dev/null; then
        fusermount -uz "$TEMP_MOUNT" 2>/dev/null || fusermount -u "$TEMP_MOUNT" 2>/dev/null || umount -f "$TEMP_MOUNT" 2>/dev/null
    fi
    # Backup: tuer tout squashfuse lié à ce mount point
    for pid in $(pgrep -f "squashfuse.*$TEMP_MOUNT" 2>/dev/null); do
        kill -TERM "$pid" 2>/dev/null || true
    done
    rm -rf "$TEMP_MOUNT" "$TEMP_ICO"
    rm -f "$LOCK_FILE"
    # Libérer le rate limiter
    rm -f /tmp/wgp-thumbnailer.active
}
trap cleanup EXIT

# Variable pour stocker le PID de squashfuse (fichier unique par instance)
SQUASHFUSE_PID_FILE="/tmp/wgp-thumbnailer-squashfuse.${MY_PID}.pid"

# Montage en arrière-plan avec timeout
squashfuse "$INPUT" "$TEMP_MOUNT" &
SQUASHFUSE_PID=$!
echo $SQUASHFUSE_PID > "$SQUASHFUSE_PID_FILE"

# Timeout killer en arrière-plan
(
    sleep 5
    kill $SQUASHFUSE_PID 2>/dev/null
) &
KILLER_PID=$!

# Attendre le montage
wait $SQUASHFUSE_PID
MOUNT_STATUS=$?

# Arrêter le killer
kill $KILLER_PID 2>/dev/null
wait $KILLER_PID 2>/dev/null

# Vérifier si le montage a réussi (vérification mountpoint plus fiable que $?)
if ! mountpoint -q "$TEMP_MOUNT" 2>/dev/null; then
    cleanup_and_exit 1
fi

# L'icône custom .icon.png a priorité sur l'extraction depuis .exe
if [ -f "$TEMP_MOUNT/.icon.png" ]; then
    magick "$TEMP_MOUNT/.icon.png" -resize "${SIZE}x${SIZE}!" -background none -gravity center -extent "${SIZE}x${SIZE}" "$OUTPUT" 2>/dev/null && cleanup_and_exit 0
fi

# Lecture .launch
if [ ! -f "$TEMP_MOUNT/.launch" ]; then
    cleanup_and_exit 1  # → fallback MIME (org.gnome.Games)
fi

EXE_IN_WGP=$(cat "$TEMP_MOUNT/.launch" | tr -d '\r')
ICON_EXE_PATH="$TEMP_MOUNT/$EXE_IN_WGP"

# Si le fichier indiqué est un symlink → abandonne
[ -L "$ICON_EXE_PATH" ] && cleanup_and_exit 1

# Si le fichier indiqué n'existe pas → fallback
[ -f "$ICON_EXE_PATH" ] || cleanup_and_exit 1

# NOUVEAU : si c'est un .bat (ou .cmd, .ps1, etc.), on ne touche à rien → fallback
case "${ICON_EXE_PATH,,}" in  # ,, = tout en minuscule
    *.bat|*.cmd|*.ps1|*.vbs)
        cleanup_and_exit 1  # → Dolphin affiche org.gnome.Games
        ;;
esac

# Sinon : c'est un .exe → extraction avec exeiconextract.py
TEMP_PNG="$TEMP_ICO/extracted.png"

# Extraction avec timeout shell (1 seconde max - réduit pour éviter SIGKILL de Dolphin)
python3 "$EXEICONEXTRACT" "$ICON_EXE_PATH" "$TEMP_PNG" 2>/dev/null &
EXTRACT_PID=$!
(sleep 1 && kill $EXTRACT_PID 2>/dev/null) &
KILLER_PID=$!
wait $EXTRACT_PID
EXTRACT_STATUS=$?
kill $KILLER_PID 2>/dev/null
wait $KILLER_PID 2>/dev/null

if [ -f "$TEMP_PNG" ]; then
    magick "$TEMP_PNG" -resize "${SIZE}x${SIZE}!" -background none -gravity center -extent "${SIZE}x${SIZE}" "$OUTPUT" 2>/dev/null && cleanup_and_exit 0
fi

cleanup_and_exit 1  # → fallback MIME si rien d'extrait
