#!/bin/bash
INPUT="$1"    # %i
OUTPUT="$2"   # %o
SIZE="$3"     # %s (128 ou 256)

[ -z "$SIZE" ] && SIZE=256

EXEICONEXTRACT="/usr/share/ublue-os/gablue/scripts/exeiconextract.py"

LOCK_FILE="/tmp/wgp-thumbnailer.lock"
MAX_INSTANCES=2  # 2 instances en parallèle pour les gros dossiers

# Vérification rapide: si fichier en cours d'écriture, on abandonne (Dolphin rappellera plus tard)
# Une seule vérification de 0.1s - rapide mais suffisant pour détecter les copies
size1=$(stat -c %s "$INPUT" 2>/dev/null) || exit 1
sleep 0.1
size2=$(stat -c %s "$INPUT" 2>/dev/null) || exit 1
[ "$size1" = "$size2" ] || exit 1  # Fichier en cours d'écriture, on sort

# Sémaphore avec N instances concurrentes max (attente max 10s)
acquire_slot() {
    local timeout=100  # 10 secondes (100 × 0.1s)
    local elapsed=0
    local instance_num

    while [ $elapsed -lt $timeout ]; do
        # Essaie de trouver un slot libre parmi les N disponibles
        for instance_num in $(seq 1 $MAX_INSTANCES); do
            local inst_lock="${LOCK_FILE}.${instance_num}"
            # Essaie d'acquérir ce slot
            if (flock -n 200) 200>"$inst_lock" 2>/dev/null; then
                # Slot pris, retourne le numéro via une variable globale
                echo "$instance_num" > /tmp/wgp-thumbnailer-current-instance
                return 0
            fi
        done
        # Tous les slots occupés, on attend
        sleep 0.1
        elapsed=$((elapsed + 1))
    done
    return 1
}

# Libère le slot
release_slot() {
    local instance_num
    instance_num=$(cat /tmp/wgp-thumbnailer-current-instance 2>/dev/null)
    [ -n "$instance_num" ] && rm -f "${LOCK_FILE}.${instance_num}" 2>/dev/null
    rm -f /tmp/wgp-thumbnailer-current-instance 2>/dev/null
}

# Acquiert un slot ou quitte
acquire_slot || exit 1

TEMP_MOUNT=$(mktemp -d)
TEMP_ICO=$(mktemp -d)

# Nettoyage complet en toute circonstance
cleanup() {
    # Démontage forcé et kill des processus squashfuse restants
    if mountpoint -q "$TEMP_MOUNT" 2>/dev/null; then
        fusermount -uz "$TEMP_MOUNT" 2>/dev/null || fusermount -u "$TEMP_MOUNT" 2>/dev/null || umount -f "$TEMP_MOUNT" 2>/dev/null
        # Kill de tous les processus squashfuse qui pointent sur ce mount point
        local mount_dev
        mount_dev=$(stat -c %d "$TEMP_MOUNT" 2>/dev/null)
        if [ -n "$mount_dev" ]; then
            # Tuer tous les processus squashfuse qui ont ce mount point ouvert
            for pid in $(lsof -t "$TEMP_MOUNT" 2>/dev/null); do
                kill -TERM "$pid" 2>/dev/null || true
            done
        fi
    fi
    # Tuer tout squashfuse qui pourrait utiliser ce répertoire
    pgrep -f "squashfuse.*$TEMP_MOUNT" 2>/dev/null | while read -r spid; do
        kill -TERM "$spid" 2>/dev/null || true
    done
    rm -rf "$TEMP_MOUNT" "$TEMP_ICO"
    release_slot
}
trap cleanup EXIT

# Montage avec timeout (max 5 secondes)
timeout 5 squashfuse "$INPUT" "$TEMP_MOUNT" || exit 1

# L'icône custom .icon.png a priorité sur l'extraction depuis .exe
if [ -f "$TEMP_MOUNT/.icon.png" ]; then
    magick "$TEMP_MOUNT/.icon.png" -resize "${SIZE}x${SIZE}!" -background none -gravity center -extent "${SIZE}x${SIZE}" "$OUTPUT" 2>/dev/null && exit 0
fi

# Lecture .launch
if [ ! -f "$TEMP_MOUNT/.launch" ]; then
    exit 1  # → fallback MIME (org.gnome.Games)
fi

EXE_IN_WGP=$(cat "$TEMP_MOUNT/.launch" | tr -d '\r')
ICON_EXE_PATH="$TEMP_MOUNT/$EXE_IN_WGP"

# Si le fichier indiqué est un symlink → abandonne
[ -L "$ICON_EXE_PATH" ] && exit 1

# Si le fichier indiqué n'existe pas → fallback
[ -f "$ICON_EXE_PATH" ] || exit 1

# NOUVEAU : si c'est un .bat (ou .cmd, .ps1, etc.), on ne touche à rien → fallback
case "${ICON_EXE_PATH,,}" in  # ,, = tout en minuscule
    *.bat|*.cmd|*.ps1|*.vbs)
        exit 1  # → Dolphin affiche org.gnome.Games
        ;;
esac

# Sinon : c'est un .exe → extraction avec exeiconextract.py
    TEMP_PNG="$TEMP_ICO/extracted.png"

# Extraction avec timeout (max 5 secondes)
timeout 5 python3 "$EXEICONEXTRACT" "$ICON_EXE_PATH" "$TEMP_PNG" 2>/dev/null
if [ -f "$TEMP_PNG" ]; then
    magick "$TEMP_PNG" -resize "${SIZE}x${SIZE}!" -background none -gravity center -extent "${SIZE}x${SIZE}" "$OUTPUT" 2>/dev/null && exit 0
fi

exit 1  # → fallback MIME si rien d'extrait
