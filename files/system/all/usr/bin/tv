#!/usr/bin/python3
"""NetPlus IPTV picker — arrow keys, real-time filter, ffplay fullscreen."""

import curses
import subprocess

BASE = "https://viamotionhsi.netplus.ch/live/eds"
SUFFIX = "/browser-HLS8"

CHANNELS = [
    # (id, label, country)
    # 🇨🇭 Suisse
    ("rts1hd",        "RTS Un",            "🇨🇭 Suisse"),
    ("rts2hd",        "RTS Deux",          "🇨🇭 Suisse"),
    ("srf1hd",        "SRF 1",             "🇨🇭 Suisse"),
    ("srf2hd",        "SRF 2",             "🇨🇭 Suisse"),
    ("srfinfo",       "SRF info",          "🇨🇭 Suisse"),
    ("telebaern",     "TeleBärn",          "🇨🇭 Suisse"),
    ("telebielingue", "TeleBielingue",     "🇨🇭 Suisse"),
    ("telezueri",     "TeleZüri",          "🇨🇭 Suisse"),
    ("tv24",          "TV24",              "🇨🇭 Suisse"),
    ("tvm3",          "TVM3",              "🇨🇭 Suisse"),
    ("kanal9",        "Kanal9",            "🇨🇭 Suisse"),
    ("valtv",         "ValTV",             "🇨🇭 Suisse"),
    ("canalalphaju",  "Canal Alpha",       "🇨🇭 Suisse"),
    ("starhd",        "Star HD",           "🇨🇭 Suisse"),
    # 🇫🇷 France
    ("tf1hd",         "TF1",               "🇫🇷 France"),
    ("france2hd",     "France 2",          "🇫🇷 France"),
    ("france3hd",     "France 3",          "🇫🇷 France"),
    ("france4hd",     "France 4",          "🇫🇷 France"),
    ("france5hd",     "France 5",          "🇫🇷 France"),
    ("m6hd",          "M6",                "🇫🇷 France"),
    ("artehd",        "Arte",              "🇫🇷 France"),
    ("tmc",           "TMC",               "🇫🇷 France"),
    # 🇩🇪 Allemagne
    ("zdfhd",         "ZDF",               "🇩🇪 Allemagne"),
    ("zdfinfohd",     "ZDFinfo",           "🇩🇪 Allemagne"),
    ("zdfneohd",      "ZDFneo",            "🇩🇪 Allemagne"),
    ("3sathd",        "3sat",              "🇩🇪 Allemagne"),
    ("phoenixhd",     "Phoenix",           "🇩🇪 Allemagne"),
    ("kikahd",        "KiKA",              "🇩🇪 Allemagne"),
    ("brhdsud",       "BR Süd",            "🇩🇪 Allemagne"),
    ("wdrhd",         "WDR",               "🇩🇪 Allemagne"),
    ("ndrhd",         "NDR",               "🇩🇪 Allemagne"),
    ("rtlnitro",      "RTL Nitro",         "🇩🇪 Allemagne"),
    ("rtl2",          "RTL 2",             "🇩🇪 Allemagne"),
    ("superrtl",      "Super RTL",         "🇩🇪 Allemagne"),
    ("vox",           "VOX",               "🇩🇪 Allemagne"),
    ("ntv",           "ntv",               "🇩🇪 Allemagne"),
    ("onehd",         "ONE",               "🇩🇪 Allemagne"),
    ("sport1",        "Sport1",            "🇩🇪 Allemagne"),
    ("dmax",          "DMAX",              "🇩🇪 Allemagne"),
    ("deluxemusic",   "Deluxe Music",      "🇩🇪 Allemagne"),
    ("tele5",         "Tele 5",            "🇩🇪 Allemagne"),
    # 🌍 International
    ("euronews",      "Euronews",          "🌍 International"),
    ("mezzo",         "Mezzo",             "🌍 International"),
]

def main(stdscr):
    curses.curs_set(0)
    curses.start_color()
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_CYAN, -1)
    curses.init_pair(2, curses.COLOR_YELLOW, -1)
    curses.init_pair(3, curses.COLOR_GREEN, -1)

    query = ""
    selected = 0
    offset = 0

    stdscr.nodelay(False)

    while True:
        # Filter
        qf = query.strip().lower()
        matches = [(i, c) for i, c in enumerate(CHANNELS)
                   if qf in c[1].lower() or qf in c[2].lower()]

        if not matches:
            stdscr.clear()
            h, w = stdscr.getmaxyx()
            stdscr.addstr(2, 2, f"🔍 {query}")
            stdscr.addstr(4, 2, "Aucun résultat.")
            stdscr.refresh()
            key = stdscr.getch()
            if key == 27:  # ESC
                return
            elif key in (curses.KEY_BACKSPACE, 127):
                query = query[:-1]
            elif 32 <= key <= 126:
                query += chr(key)
            continue

        # Clamp selection
        selected = max(0, min(selected, len(matches) - 1))

        # Scroll
        h, w = stdscr.getmaxyx()
        rows = h - 2
        if selected < offset:
            offset = selected
        elif selected >= offset + rows:
            offset = selected - rows + 1

        stdscr.clear()

        # Search bar
        stdscr.addstr(0, 1, f"🔍 {query}_"[:w-1], curses.A_BOLD)

        # Build display lines (headers + channels) with match index
        display = []  # (y_offset, type, match_index_or_country)
        last_country = ""
        for j, (idx, ch) in enumerate(matches):
            _, label, country = ch
            if country != last_country:
                display.append(("header", country))
                last_country = country
            display.append(("channel", j, label))

        # Scroll logic: find selected channel position in display
        sel_display = next(
            i for i, d in enumerate(display)
            if d[0] == "channel" and d[1] == selected
        )
        if sel_display < offset:
            offset = sel_display
        elif sel_display >= offset + rows:
            offset = sel_display - rows + 1

        # Paint
        for i, entry in enumerate(display):
            y = i - offset + 1
            if y < 1 or y >= h - 1:
                continue
            if entry[0] == "header":
                country = entry[1]
                line = f"── {country} ──"
                stdscr.addstr(y, 1, line[:w-1],
                              curses.color_pair(1) | curses.A_BOLD)
            else:
                j, label = entry[1], entry[2]
                line = f"    {label}"
                if j == selected:
                    stdscr.addstr(y, 1, " ▶ ", curses.color_pair(3))
                    stdscr.addstr(y, 4, line[:w-4],
                                  curses.color_pair(3) | curses.A_REVERSE)
                else:
                    stdscr.addstr(y, 1, line[:w-1])

        # Footer
        try:
            stdscr.addstr(h-1, 1,
                          "↑↓ Nav  |  Tape pour filtrer  |  ↵ Lancer  |  ESC Quitter"
                          [:w-1], curses.color_pair(2))
        except curses.error:
            pass

        stdscr.refresh()

        key = stdscr.getch()
        if key == 27:  # ESC
            return
        elif key == curses.KEY_UP:
            selected -= 1
        elif key == curses.KEY_DOWN:
            selected += 1
        elif key in (curses.KEY_BACKSPACE, 127, 8):
            query = query[:-1]
            selected = 0
            offset = 0
        elif key in (10, 13):  # Enter
            idx, (ch_id, label, _) = matches[selected]
            url = f"{BASE}/{ch_id}{SUFFIX}/{ch_id}.m3u8"
            curses.endwin()
            print(f"▶️  {label} — connexion...")
            # ffplay — fullscreen natif
            cmd = ["ffplay", "-fs", url]
            subprocess.run(cmd)
            return
        elif 32 <= key <= 126:
            query += chr(key)
            selected = 0
            offset = 0

try:
    curses.wrapper(main)
except curses.error:
    pass
