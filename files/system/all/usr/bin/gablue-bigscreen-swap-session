#!/usr/bin/sh

LOG="$HOME/.cache/plasma-bigscreen/swap-session.log"

log() {
    echo "$(date '+%F %T') - $*" >> "$LOG"
}

if [ -z "$XDG_CURRENT_DESKTOP" ] || [ "$XDG_CURRENT_DESKTOP" != "KDE" ]; then
    echo "This script can only be run on KDE Plasma."
    exit 1
fi

CACHE_DIR="$HOME/.cache/plasma-bigscreen"
SAVED_ENV="$CACHE_DIR/saved-env"

mkdir -pv "$CACHE_DIR"

log "Script started"

swap_to_bigscreen() {
    log "swap_to_bigscreen: saving env and KWin settings"
    export -p > "$SAVED_ENV"

    # Sauvegarder les settings KWin actuels pour les restaurer au retour
    local val
    val=$(kreadconfig6 --file "$HOME/.config/kwinrc" --group Windows --key BorderlessMaximizedWindows 2>/dev/null)
    echo "${val:-__DELETE__}" > "$CACHE_DIR/kwin-BorderlessMaximizedWindows"
    val=$(kreadconfig6 --file "$HOME/.config/kwinrc" --group Windows --key Placement 2>/dev/null)
    echo "${val:-__DELETE__}" > "$CACHE_DIR/kwin-Placement"
    val=$(kreadconfig6 --file "$HOME/.config/kwinrc" --group org.kde.kdecoration2 --key NoPlugin 2>/dev/null)
    echo "${val:-__DELETE__}" > "$CACHE_DIR/kwin-NoPlugin"

    . plasma-bigscreen-common-env

    export PLASMA_BIGSCREEN_LAUNCH_REASON=swap

    # Appliquer les settings KWin bigscreen (fenêtres maximisées sans décorations)
    log "swap_to_bigscreen: applying bigscreen KWin settings"
    kwriteconfig6 --file "$HOME/.config/kwinrc" --group Windows --key BorderlessMaximizedWindows --type bool true
    kwriteconfig6 --file "$HOME/.config/kwinrc" --group Windows --key Placement Maximizing
    kwriteconfig6 --file "$HOME/.config/kwinrc" --group org.kde.kdecoration2 --key NoPlugin --type bool false
    qdbus org.kde.KWin /KWin org.kde.KWin.reconfigure 2>/dev/null || true

    # Mettre tous les écrans en miroir sur le principal (bigscreen ne gère pas le multi-écran)
    log "swap_to_bigscreen: mirroring all displays on primary"
    /usr/bin/python3 -c "
import subprocess, json
raw = subprocess.run(['kscreen-doctor', '--json'], capture_output=True).stdout
d = json.loads(raw)
outs = [o for o in d['outputs'] if o.get('connected') and o.get('enabled')]
outs.sort(key=lambda o: o.get('priority', 99))
if len(outs) > 1:
    primary = outs[0]['name']
    # Sauvegarder les noms pour restauration
    with open('$CACHE_DIR/kscreen-mirrored.txt', 'w') as f:
        for o in outs[1:]:
            f.write(o['name'] + '\\n')
    # Appliquer le mirroring
    cmds = [f'output.{primary}.enable']
    for o in outs[1:]:
        cmds.append(f'output.{o[\"name\"]}.enable')
        cmds.append(f'output.{o[\"name\"]}.mirror.{primary}')
    print(' '.join(cmds))
" > "$CACHE_DIR/kscreen-bigscreen-cmds.txt" 2>/dev/null
    if [ -s "$CACHE_DIR/kscreen-bigscreen-cmds.txt" ]; then
        log "swap_to_bigscreen: kscreen-doctor $(cat "$CACHE_DIR/kscreen-bigscreen-cmds.txt")"
        kscreen-doctor $(cat "$CACHE_DIR/kscreen-bigscreen-cmds.txt") 2>/dev/null || true
    fi

    # Maximiser toutes les fenêtres existantes et enlever leurs décorations
    log "swap_to_bigscreen: maximizing all windows"
    qdbus org.kde.KWin /Scripting org.kde.kwin.Scripting.loadScript "/usr/share/gablue/kwin-maximize-all.js" "gablue-maximize" 2>/dev/null || true
    qdbus org.kde.KWin /Scripting org.kde.kwin.Scripting.start 2>/dev/null || true
    sleep 1
    qdbus org.kde.KWin /Scripting org.kde.kwin.Scripting.unloadScript "gablue-maximize" 2>/dev/null || true

    log "swap_to_bigscreen: launching inputhandler via kioclient exec"
    kioclient exec /usr/share/applications/org.kde.plasma.bigscreen.inputhandler.desktop &
    log "swap_to_bigscreen: kioclient launched (pid $!)"

    log "swap_to_bigscreen: replacing plasmashell"
    plasmashell --replace &
}

swap_to_default() {
    log "swap_to_default: killing inputhandler"
    pgrep -f "/usr/bin/plasma-bigscreen-inputhandler" >> "$LOG" 2>&1

    pkill -f "/usr/bin/plasma-bigscreen-inputhandler" >> "$LOG" 2>&1
    sleep 1
    pkill -9 -f "/usr/bin/plasma-bigscreen-inputhandler" >> "$LOG" 2>&1
    log "swap_to_default: kill done, exit code: $?"
    sleep 0.5
    pgrep -f "/usr/bin/plasma-bigscreen-inputhandler" >> "$LOG" 2>&1 || log "swap_to_default: process killed (good)"

    # Restaurer les settings KWin originaux
    log "swap_to_default: restoring original KWin settings"
    for setting in BorderlessMaximizedWindows:Windows:"--type bool" Placement:Windows:"" NoPlugin:org.kde.kdecoration2:"--type bool"; do
        key="${setting%%:*}"
        rest="${setting#*:}"
        group="${rest%%:*}"
        extra="${rest#*:}"
        saved=$(cat "$CACHE_DIR/kwin-$key" 2>/dev/null)
        if [ "$saved" = "__DELETE__" ]; then
            kwriteconfig6 --file "$HOME/.config/kwinrc" --group "$group" --key "$key" --delete 2>/dev/null || true
        elif [ -n "$saved" ]; then
            kwriteconfig6 --file "$HOME/.config/kwinrc" --group "$group" --key "$key" $extra "$saved" 2>/dev/null || true
        fi
    done

    # Bigscreen tue xwaylandvideobridge quand il prend le focus (HACK dans HomeScreen.qml)
    log "swap_to_default: restarting xwaylandvideobridge (was killed by bigscreen)"
    systemctl --user restart plasma-xwaylandvideobridge.service >> "$LOG" 2>&1 || true

    if [ -f "$SAVED_ENV" ]; then
        . "$SAVED_ENV"
        rm "$SAVED_ENV"
    fi

    unset PLASMA_BIGSCREEN_LAUNCH_REASON

    # Recharger KWin APRÈS avoir restauré l'env (XDG_CONFIG_DIRS normal)
    log "swap_to_default: reloading KWin config for normal Plasma settings"
    qdbus org.kde.KWin /KWin org.kde.KWin.reconfigure 2>/dev/null || true

    # Annuler le mirroring APRÈS avoir restauré l'env (DBus fonctionnel)
    if [ -f "$CACHE_DIR/kscreen-mirrored.txt" ]; then
        log "swap_to_default: removing mirroring, restoring extended layout"
        while read -r output_name; do
            [ -n "$output_name" ] && kscreen-doctor "output.$output_name.mirror.none" 2>/dev/null || true
        done < "$CACHE_DIR/kscreen-mirrored.txt"
    fi

    # Restaurer les décorations des fenêtres (annuler noBorder du mode bigscreen)
    log "swap_to_default: restoring window decorations"
    qdbus org.kde.KWin /Scripting org.kde.kwin.Scripting.loadScript "/usr/share/gablue/kwin-restore-windows.js" "gablue-restore" 2>/dev/null || true
    qdbus org.kde.KWin /Scripting org.kde.kwin.Scripting.start 2>/dev/null || true
    sleep 0.5
    qdbus org.kde.KWin /Scripting org.kde.kwin.Scripting.unloadScript "gablue-restore" 2>/dev/null || true

    log "swap_to_default: replacing plasmashell"
    plasmashell --replace &
}

if pgrep -f "/usr/bin/plasma-bigscreen-inputhandler" > /dev/null 2>&1; then
    log "Detected inputhandler running, swapping to default"
    swap_to_default
else
    log "No inputhandler running, swapping to bigscreen"
    swap_to_bigscreen
fi

log "Script finished"
