################################################################################
# wincomponent-misc.sh - Installation des composants Windows divers
# OpenAL, PhysX, MSLS31, VB6 Runtime
################################################################################

# Installe OpenAL
install_openal() {
    echo "Installation d'OpenAL..."
    
    local cache_zip="$WINCOMPONENTS_CACHE/openal/oalinst.zip"
    
    if [ -f "$cache_zip" ]; then
        local tmp_dir=$(mktemp -d)
        unzip -q "$cache_zip" -d "$tmp_dir" 2>/dev/null || true
        
        if [ -f "$tmp_dir/oalinst.exe" ]; then
            WINEPREFIX="$WINEPREFIX" "$WINE_BIN" "$tmp_dir/oalinst.exe" /s 2>/dev/null || true
        fi
        
        rm -rf "$tmp_dir"
    fi
    
    return 0
}

# Installe PhysX
install_physx() {
    echo "Installation de PhysX..."
    
    local cache_file="$WINCOMPONENTS_CACHE/physx/PhysX_9.23.1019_SystemSoftware.exe"
    
    if [ -f "$cache_file" ]; then
        echo "  - Lancement de l'installateur PhysX..."
        if WINEPREFIX="$WINEPREFIX" "$WINE_BIN" "$cache_file" /s 2>/dev/null; then
            echo "  ✓ PhysX installé"
        else
            echo "  ⚠ PhysX installé (peut déjà être présent)"
        fi
    else
        echo "  ✗ Fichier PhysX non trouvé dans le cache"
        return 1
    fi
    
    return 0
}

# Installe MSLS31
install_msls31() {
    echo "Installation de MSLS31..."
    
    local win32_sys="$WINEPREFIX/drive_c/windows/syswow64"
    local cache_file="$WINCOMPONENTS_CACHE/msls31/InstMsiW.exe"
    
    if [ ! -f "$cache_file" ]; then
        echo "  ✗ Fichier MSLS31 non trouvé"
        return 1
    fi
    
    if command -v cabextract &>/dev/null; then
        cabextract -d "$win32_sys" -F 'msls31.dll' "$cache_file" >/dev/null 2>&1 || true
    fi
    
    echo "  ✓ MSLS31 installé"
    return 0
}

# Installe VB6 Runtime
install_vb6run() {
    echo "Installation de VB6 Runtime..."
    
    local win32_sys="$WINEPREFIX/drive_c/windows/syswow64"
    local cache_file="$WINCOMPONENTS_CACHE/vb6run/VB6.0-KB290887-X86.exe"
    
    if [ ! -f "$cache_file" ]; then
        echo "  ✗ Fichier VB6 non trouvé"
        return 1
    fi
    
    if command -v cabextract &>/dev/null; then
        local tmp_dir=$(mktemp -d)
        cabextract -d "$tmp_dir" "$cache_file" >/dev/null 2>&1 || true
        
        for dll in "$tmp_dir"/*.dll; do
            if [ -f "$dll" ]; then
                cp -f "$dll" "$win32_sys/" 2>/dev/null || true
            fi
        done
        
        rm -rf "$tmp_dir"
    fi
    
    echo "  ✓ VB6 Runtime installé"
    return 0
}

# =============================================================================
# Module: wincomponent-main.sh
# =============================================================================


################################################################################
# wincomponent-main.sh - Fonction principale d'installation des composants Windows
# Orchestration de l'installation complète
################################################################################

# Installe tous les composants Windows
install_all_wincomponents() {
    echo "Installation des composants Windows..."
    
    # Vérifier le cache en mode offline
    if [ "${OFFLINE_MODE:-false}" = "true" ]; then
        if ! check_wincomponents_cache; then
            echo "Erreur: Mode offline activé mais certains composants sont manquants"
            echo "Lancez 'gwine --init' sans l'option --offline pour télécharger les composants"
            return 1
        fi
    fi
    
    # Installer les polices
    install_corefonts
    
    # Installer VC++ Redistributables
    install_vcrun 2010 both
    install_vcrun 2012 both
    install_vcrun 2013 both
    install_vcrun 2022 both
    
    # Installer .NET
    install_dotnet 6 both
    install_dotnet 7 both
    install_dotnet 8 both
    
    # Installer DirectX
    install_d3dx9
    
    # Installer XACT
    install_xact
    install_xact_x64
    
    # Installer D3DCompiler
    install_d3dcompiler 42
    install_d3dcompiler 43
    install_d3dcompiler_47
    
    # Installer MSLS31
    install_msls31
    
    # Installer VB6 Runtime
    install_vb6run
    
    # Installer VCRUN6 (MFC42)
    install_vcrun6
    
    # Installer OpenAL
    install_openal
    
    # Installer PhysX
    install_physx
    
    echo "✓ Installation des composants Windows terminée"
    return 0
}

# =============================================================================
# Module: cache-gwine.sh
# =============================================================================


################################################################################
# cache-gwine.sh - Gestion du cache et installation de gwine-proton
################################################################################

# Versions des composants
DXVK_VERSION="2.7.1"
VKD3D_VERSION="3.0"

# Installe gwine-proton depuis le cache (mode offline)
# Retourne 0 si installé avec succès, 1 sinon
install_gwine_proton_from_cache() {
    local WINE_INSTALL_DIR="$GWINE_DIR/wine"
    local archives_dir="$COMPONENTS_DIR/gwine-proton"
    
    if [ ! -d "$archives_dir" ] || [ -z "$(ls -A "$archives_dir" 2>/dev/null)" ]; then
        return 1
    fi
    
    local latest_archive
    latest_archive=$(ls -1 "$archives_dir"/gwine-proton-*.tar.xz 2>/dev/null | sort -V | tail -1)
    
    if [ -z "$latest_archive" ] || [ ! -f "$latest_archive" ]; then
        return 1
    fi
    
    local version_name
    version_name=$(basename "$latest_archive" .tar.xz)
    
    echo "Installation de $version_name depuis le cache..."
    
    local temp_dir="$CACHE_DIR/.temp_install"
    rm -rf "$temp_dir"
    ensure_dir "$temp_dir" "Impossible de créer le répertoire temporaire"
    
    local extract_dir="$temp_dir/extracted"
    ensure_dir -s "$extract_dir"
    
    if ! tar -xf "$latest_archive" -C "$extract_dir" 2>/dev/null; then
        echo "Échec de l'extraction de l'archive"
        rm -rf "$temp_dir"
        return 1
    fi
    
    local extracted_wine_dir
    extracted_wine_dir=$(find "$extract_dir" -maxdepth 1 -type d -name "*gwine*" | head -1)
    if [ -z "$extracted_wine_dir" ]; then
        extracted_wine_dir=$(find "$extract_dir" -maxdepth 1 -type d | head -1)
    fi
    if [ -z "$extracted_wine_dir" ]; then
        extracted_wine_dir="$extract_dir"
    fi
    
    rm -rf "$WINE_INSTALL_DIR"
    ensure_dir "$WINE_INSTALL_DIR" "Impossible de créer le répertoire d'installation Wine"
    cp -r "$extracted_wine_dir"/* "$WINE_INSTALL_DIR/"
    
    if [ ! -f "$WINE_INSTALL_DIR/bin/wine64" ]; then
        echo "Échec de l'installation"
        rm -rf "$WINE_INSTALL_DIR"
        rm -rf "$temp_dir"
        return 1
    fi
    
    echo "$version_name" > "$GWINE_DIR/.version"
    
    rm -rf "$temp_dir"
    
    WINE_DIR="$WINE_INSTALL_DIR"
    WINE_BIN="$WINE_INSTALL_DIR/bin/wine64"
    WINESERVER_BIN="$WINE_INSTALL_DIR/bin/wineserver"
    
    echo "✓ $version_name installé depuis le cache"
    return 0
}

# Installe gwine-proton depuis une archive extraite
install_gwine_from_extracted() {
    local extracted_dir="$1"
    local install_dir="$2"
    local backup_dir="$GWINE_DIR/.wine-backup"
    
    local wine_subdir
    wine_subdir=$(find "$extracted_dir" -maxdepth 1 -type d -name "*gwine*" | head -1)
    if [ -z "$wine_subdir" ]; then
        wine_subdir=$(find "$extracted_dir" -maxdepth 1 -type d | head -1)
    fi
    [ -z "$wine_subdir" ] && wine_subdir="$extracted_dir"
    
    local old_backup=""
    if [ -d "$install_dir" ]; then
        old_backup=$(backup_component "$install_dir")
    fi
    
    echo "Installation de la nouvelle version..."
    ensure_dir "$install_dir" "Impossible de créer le répertoire d'installation"
    cp -r "$wine_subdir"/* "$install_dir/"
    
    if [ ! -f "$install_dir/bin/wine64" ]; then
        echo "Échec de l'installation"
        rm -rf "$install_dir"
        if [ -n "$old_backup" ]; then
            restore_backup_component "$old_backup" "$install_dir"
            echo "Ancienne version restaurée avec succès"
        fi
        return 1
    fi
    
    cleanup_backup_component "$old_backup"
    return 0
}

# Télécharge et installe gwine-proton
download_gwine_proton() {
    local WINE_INSTALL_DIR="$GWINE_DIR/wine"
    local current_version=""
    local latest_version=""
    local force_update="${1:-false}"
    
    if [ -d "$WINE_INSTALL_DIR" ] && [ -f "$WINE_INSTALL_DIR/bin/wine64" ]; then
        current_version=$(cat "$GWINE_DIR/.version" 2>/dev/null || echo "unknown")
    fi
    
    echo "Vérification des mises à jour de gwine-proton..."
    latest_version=$(get_latest_gwine_version)
    
    if [ -z "$latest_version" ]; then
        echo "Impossible de récupérer la dernière version (pas de connexion internet)"
        echo "Tentative d'installation depuis le cache..."
        if install_gwine_proton_from_cache; then
            return 0
        else
            echo "Échec: aucune archive disponible dans le cache"
            return 1
        fi
    fi
    
    echo "Version installée: ${current_version:-Aucune}"
    echo "Dernière version disponible: $latest_version"
    
    if [ "$force_update" = "false" ] && [ "$current_version" = "$latest_version" ]; then
        echo "Vous avez déjà la dernière version de gwine-proton."
        return 0
    fi
    
    if [ "$force_update" = "false" ] && [ -n "$current_version" ]; then
        if ! compare_versions "$latest_version" "$current_version"; then
            echo "Vous avez déjà la dernière version de gwine-proton."
            return 0
        fi
    fi
    
    local no_confirm=false
    if [ "$init_mode" = "true" ]; then
        echo "Mode init : téléchargement automatique..."
        no_confirm=true
    else
        echo ""
        echo "Une nouvelle version de gwine-proton est disponible : $latest_version"
        read -p "Voulez-vous télécharger et installer cette version ? [O/n]: " -r
        if [[ ! "$REPLY" =~ ^[OoYy]$ ]] && [ -n "$REPLY" ]; then
            echo "Mise à jour annulée."
            return 0
        fi
    fi
    
    echo ""
    echo "Téléchargement de $latest_version..."
    
    local archives_dir="$COMPONENTS_DIR/gwine-proton"
    local archive_name="${latest_version}.tar.xz"
    local download_url="https://github.com/elgabo86/gwine/releases/download/${latest_version}/${archive_name}"
    local temp_dir="$CACHE_DIR/.temp_gwine"
    local archive_path="$archives_dir/$archive_name"
    
    ensure_dir -s "$archives_dir"
    rm -rf "$temp_dir"
    ensure_dir -s "$temp_dir"
    
    local old_archive
    old_archive=$(find "$archives_dir" -maxdepth 1 -name "gwine-proton-*.tar.xz" | head -1)
    if [ -n "$old_archive" ] && [ "$old_archive" != "$archive_path" ]; then
        echo "Suppression de l'ancienne archive: $(basename "$old_archive")"
        rm -f "$old_archive"
    fi
    
    if [ ! -f "$archive_path" ]; then
        echo "Téléchargement depuis: $download_url"
        if ! download_file "$download_url" "$archive_path" "gwine-proton"; then
            rm -rf "$temp_dir"
            if [ -n "$current_version" ] && [ "$current_version" != "unknown" ]; then
                echo "Utilisation de la version existante: $current_version"
                return 0
            fi
            return 1
        fi
        echo "Archive sauvegardée dans: $archive_path"
    else
        echo "Archive trouvée dans le cache: $archive_path"
    fi
    
    echo "Extraction..."
    local extract_dir="$temp_dir/extracted"
    if ! extract_archive "$archive_path" "$extract_dir" "tar.xz"; then
        rm -rf "$temp_dir"
        if [ -n "$current_version" ] && [ "$current_version" != "unknown" ]; then
            echo "Utilisation de la version existante: $current_version"
            return 0
        fi
        return 1
    fi
    
    if install_gwine_from_extracted "$extract_dir" "$WINE_INSTALL_DIR"; then
        echo "$latest_version" > "$GWINE_DIR/.version"
        
        WINE_DIR="$WINE_INSTALL_DIR"
        WINE_BIN="$WINE_INSTALL_DIR/bin/wine64"
        WINESERVER_BIN="$WINE_INSTALL_DIR/bin/wineserver"
        
        rm -rf "$temp_dir"
        echo "✓ gwine-proton $latest_version installé avec succès"
        return 0
    else
        rm -rf "$temp_dir"
        return 1
    fi
}

# =============================================================================
# Module: cache-dxvk.sh
# =============================================================================


################################################################################
# cache-dxvk.sh - Gestion des mises à jour DXVK, VKD3D et NVAPI
################################################################################

# Télécharge et installe DXVK/VKD3D-Proton mis à jour
download_updated_dxvk_vkd3d() {
    local current_dxvk=""
    local current_vkd3d=""
    local latest_dxvk=""
    local latest_vkd3d=""
    local no_confirm=false
    
    if [ "$1" = "--no-confirm" ]; then
        no_confirm=true
    fi
    
    ensure_dirs "$DXVK_CACHE_DIR" "$VKD3D_CACHE_DIR"
    
    local dxvk_folder
    dxvk_folder=$(find "$DXVK_CACHE_DIR" -mindepth 1 -maxdepth 1 -type d -name "dxvk-*" 2>/dev/null | grep -v "gplasync\|nvapi" | head -1)
    [ -n "$dxvk_folder" ] && current_dxvk=$(basename "$dxvk_folder" | sed 's/^dxvk-//')
    
    local vkd3d_folder
    vkd3d_folder=$(find "$VKD3D_CACHE_DIR" -mindepth 1 -maxdepth 1 -type d -name "vkd3d-proton-*" 2>/dev/null | head -1)
    [ -n "$vkd3d_folder" ] && current_vkd3d=$(basename "$vkd3d_folder" | sed 's/^vkd3d-proton-//')
    
    echo ""
    echo "Vérification des mises à jour de DXVK et VKD3D-Proton..."
    
    latest_dxvk=$(get_latest_dxvk_version)
    latest_vkd3d=$(get_latest_vkd3d_version)
    
    if [ -z "$latest_dxvk" ] || [ -z "$latest_vkd3d" ]; then
        echo "Impossible de récupérer les dernières versions"
        return 1
    fi
    
    echo "DXVK - Installé: ${current_dxvk:-Aucun}, Dernière: $latest_dxvk"
    echo "VKD3D - Installé: ${current_vkd3d:-Aucun}, Dernière: $latest_vkd3d"
    
    local current_nvapi=""
    local latest_nvapi=""
    local needs_nvapi_update=false
    local current_fakenvapi=""
    local latest_fakenvapi=""
    local needs_fakenvapi_update=false
    
    if is_nvidia_gpu; then
        latest_nvapi=$(get_latest_dxvk_nvapi_version)
        local nvapi_folder
        nvapi_folder=$(find "$DXVK_NVAPI_CACHE_DIR" -mindepth 1 -maxdepth 1 -type d -name "dxvk-nvapi-*" 2>/dev/null | head -1)
        [ -n "$nvapi_folder" ] && current_nvapi=$(basename "$nvapi_folder" | sed 's/^dxvk-nvapi-v//; s/^dxvk-nvapi-//')
        echo ""
        echo "DXVK-NVAPI (NVIDIA) - Installé: ${current_nvapi:-Aucun}, Dernière: ${latest_nvapi:-Inconnue}"
    else
        latest_fakenvapi=$(get_latest_fakenvapi_version)
        local fakenvapi_folder
        fakenvapi_folder=$(find "$FAKENVAPI_CACHE_DIR" -mindepth 1 -maxdepth 1 -type d -name "fakenvapi-*" 2>/dev/null | head -1)
        [ -n "$fakenvapi_folder" ] && current_fakenvapi=$(basename "$fakenvapi_folder" | sed 's/^fakenvapi-v//; s/^fakenvapi-//')
        echo ""
        echo "FakeNVAPI (non-NVIDIA) - Installé: ${current_fakenvapi:-Aucun}, Dernière: ${latest_fakenvapi:-Inconnue}"
    fi
    
    if [ -n "$current_dxvk" ] && ! compare_versions "$latest_dxvk" "$current_dxvk"; then
        latest_dxvk=""
    fi
    
    if [ -n "$current_vkd3d" ] && ! compare_versions "$latest_vkd3d" "$current_vkd3d"; then
        latest_vkd3d=""
    fi
    
    if is_nvidia_gpu && [ -n "$latest_nvapi" ]; then
        if [ -z "$current_nvapi" ] || compare_versions "$latest_nvapi" "$current_nvapi"; then
            needs_nvapi_update=true
        fi
    elif ! is_nvidia_gpu && [ -n "$latest_fakenvapi" ]; then
        if [ -z "$current_fakenvapi" ] || compare_versions "$latest_fakenvapi" "$current_fakenvapi"; then
            needs_fakenvapi_update=true
        fi
    fi
    
    if [ -z "$latest_dxvk" ] && [ -z "$latest_vkd3d" ] && [ "$needs_nvapi_update" = false ] && [ "$needs_fakenvapi_update" = false ]; then
        echo "Vous avez déjà les dernières versions des composants."
        return 0
    fi
    
    if [ "$no_confirm" = false ]; then
        echo ""
        local updates_msg=""
        [ -n "$latest_dxvk" ] && updates_msg="DXVK $latest_dxvk"
        [ -n "$latest_vkd3d" ] && updates_msg="${updates_msg}${updates_msg:+, }VKD3D-Proton $latest_vkd3d"
        [ "$needs_nvapi_update" = true ] && updates_msg="${updates_msg}${updates_msg:+, }DXVK-NVAPI $latest_nvapi"
        [ "$needs_fakenvapi_update" = true ] && updates_msg="${updates_msg}${updates_msg:+, }FakeNVAPI $latest_fakenvapi"
        
        if [ -n "$updates_msg" ]; then
            echo "Nouvelles versions disponibles : $updates_msg"
        fi
        
        read -p "Voulez-vous télécharger et installer ces mises à jour ? [O/n]: " -r
        if [[ ! "$REPLY" =~ ^[OoYy]$ ]] && [ -n "$REPLY" ]; then
            echo "Mise à jour annulée."
            return 0
        fi
    fi
    
    local temp_dir="$CACHE_DIR/.temp_download"
    ensure_dir -s "$temp_dir"
    
    local update_success=true
    
    if [ -n "$latest_dxvk" ]; then
        local dxvk_tag="dxvk-${latest_dxvk}"
        local dxvk_url="https://github.com/bottlesdevs/components/releases/download/${dxvk_tag}/${dxvk_tag}.tar.gz"
        if ! download_and_install_component "dxvk" "$latest_dxvk" "$DXVK_CACHE_DIR" "dxvk-*" "$dxvk_url" "$temp_dir"; then
            update_success=false
        fi
    fi
    
    if [ -n "$latest_vkd3d" ]; then
        local vkd3d_tag="vkd3d-proton-${latest_vkd3d}"
        local vkd3d_url="https://github.com/bottlesdevs/components/releases/download/${vkd3d_tag}/${vkd3d_tag}.tar.gz"
        if ! download_and_install_component "vkd3d-proton" "$latest_vkd3d" "$VKD3D_CACHE_DIR" "vkd3d-proton-*" "$vkd3d_url" "$temp_dir"; then
            update_success=false
        fi
    fi
    
    rm -rf "$temp_dir"
    
    if [ "$needs_nvapi_update" = true ]; then
        echo ""
        echo "Téléchargement de DXVK-NVAPI $latest_nvapi..."
        if ! download_dxvk_nvapi --no-confirm; then
            echo "✗ Échec du téléchargement de DXVK-NVAPI"
            update_success=false
        fi
    fi
    
    if [ "$needs_fakenvapi_update" = true ]; then
        echo ""
        echo "Téléchargement de FakeNVAPI $latest_fakenvapi..."
        if ! download_fakenvapi --no-confirm; then
            echo "✗ Échec du téléchargement de FakeNVAPI"
            update_success=false
        fi
    fi
    
    if [ "$update_success" = true ]; then
        echo ""
        echo "Mises à jour installées avec succès !"
        if [ -d "$WINEPREFIX" ]; then
            echo "Réinstallation des DLLs dans le préfixe Wine..."
            install_dxvk_vkd3d
        fi
    fi
    
    return 0
}

# =============================================================================
# Module: cache-offline.sh
# =============================================================================


################################################################################
# cache-offline.sh - Préparation du cache complet pour le mode offline
################################################################################

# Prépare le cache complet pour le mode offline (--download-components)
prepare_full_offline_cache() {
    echo "Préparation du cache complet pour le mode offline..."
    echo ""
    
    local failed=false
    
    # 1. Télécharger gwine-proton
    echo "1. Préparation de gwine-proton..."
    if [ ! -d "$WINE_DIR" ] || [ ! -f "$WINE_DIR/bin/wine64" ]; then
        local latest_version
        latest_version=$(get_latest_gwine_version)
        if [ -n "$latest_version" ]; then
            local archive_name="${latest_version}.tar.xz"
            local download_url="https://github.com/elgabo86/gwine/releases/download/${latest_version}/${archive_name}"
            local archives_dir="$COMPONENTS_DIR/gwine-proton"
            local archive_path="$archives_dir/$archive_name"
            
            ensure_dir "$archives_dir"
            
            if [ ! -f "$archive_path" ]; then
                echo "   Téléchargement de $latest_version..."
                if ! download_file "$download_url" "$archive_path" "gwine-proton"; then
                    echo "   ⚠️ Échec du téléchargement de gwine-proton"
                    failed=true
                else
                    echo "   ✓ gwine-proton téléchargé"
                fi
            else
                echo "   ✓ gwine-proton déjà en cache"
            fi
        else
            echo "   ⚠️ Impossible de récupérer la version de gwine-proton"
            failed=true
        fi
    else
        echo "   ✓ gwine-proton déjà installé"
    fi
    echo ""
    
    # 2. Télécharger Wine Mono et Gecko
    echo "2. Préparation de Wine Mono et Gecko..."
    local WINE_CACHE="$COMPONENTS_DIR/wine-cache"
    ensure_dir "$WINE_CACHE"
    
    local MONO_URL="https://dl.winehq.org/wine/wine-mono/11.0.0/wine-mono-11.0.0-x86.msi"
    local GECKO_URL="https://dl.winehq.org/wine/wine-gecko/2.47.4/wine-gecko-2.47.4-x86_64.msi"
    local GECKO32_URL="https://dl.winehq.org/wine/wine-gecko/2.47.4/wine-gecko-2.47.4-x86.msi"
    
    local mono_file="$WINE_CACHE/wine-mono-11.0.0-x86.msi"
    local gecko64_file="$WINE_CACHE/wine-gecko-2.47.4-x86_64.msi"
    local gecko32_file="$WINE_CACHE/wine-gecko-2.47.4-x86.msi"
    
    if [ ! -f "$mono_file" ]; then
        echo "   Téléchargement de Wine Mono..."
        if ! wget -q --show-progress "$MONO_URL" -O "$mono_file" 2>&1; then
            echo "   ⚠️ Échec du téléchargement de Wine Mono"
            failed=true
        else
            echo "   ✓ Wine Mono téléchargé"
        fi
    else
        echo "   ✓ Wine Mono déjà en cache"
    fi
    
    if [ ! -f "$gecko64_file" ]; then
        echo "   Téléchargement de Wine Gecko (x64)..."
        if ! wget -q --show-progress "$GECKO_URL" -O "$gecko64_file" 2>&1; then
            echo "   ⚠️ Échec du téléchargement de Wine Gecko (x64)"
            failed=true
        else
            echo "   ✓ Wine Gecko (x64) téléchargé"
        fi
    else
        echo "   ✓ Wine Gecko (x64) déjà en cache"
    fi
    
    if [ ! -f "$gecko32_file" ]; then
        echo "   Téléchargement de Wine Gecko (x86)..."
        if ! wget -q --show-progress "$GECKO32_URL" -O "$gecko32_file" 2>&1; then
            echo "   ⚠️ Échec du téléchargement de Wine Gecko (x86)"
            failed=true
        else
            echo "   ✓ Wine Gecko (x86) téléchargé"
        fi
    else
        echo "   ✓ Wine Gecko (x86) déjà en cache"
    fi
    echo ""
    
    # 3. Télécharger DXVK
    echo "3. Préparation de DXVK..."
    ensure_dir "$DXVK_CACHE_DIR"
    local has_dxvk=false
    find "$DXVK_CACHE_DIR" -mindepth 1 -maxdepth 1 -type d -name "dxvk-*" 2>/dev/null | grep -qv "gplasync\|nvapi" && has_dxvk=true
    
    if [ "$has_dxvk" = false ]; then
        local DXVK_TAG="dxvk-${DXVK_VERSION}"
        local DXVK_URL="https://github.com/bottlesdevs/components/releases/download/${DXVK_TAG}/${DXVK_TAG}.tar.gz"
        local DXVK_TEMP="$DXVK_CACHE_DIR/dxvk.tar.gz"
        local DXVK_DIR="$DXVK_CACHE_DIR/dxvk-${DXVK_VERSION}"
        
        echo "   Téléchargement de $DXVK_TAG..."
        if ! wget -q --show-progress "$DXVK_URL" -O "$DXVK_TEMP" 2>&1; then
            echo "   ⚠️ Échec du téléchargement de DXVK"
            failed=true
        else
            local temp_extract="$DXVK_CACHE_DIR/.temp_extract"
            rm -rf "$temp_extract"
            ensure_dir "$temp_extract"
            if tar -xzf "$DXVK_TEMP" -C "$temp_extract" 2>/dev/null; then
                local extracted_dir
                extracted_dir=$(find "$temp_extract" -maxdepth 1 -type d -name "dxvk-*" | head -1)
                if [ -d "$extracted_dir" ]; then
                    mv "$extracted_dir" "$DXVK_DIR"
                    echo "   ✓ DXVK téléchargé et extrait"
                fi
            else
                echo "   ⚠️ Échec de l'extraction de DXVK"
                failed=true
            fi
            rm -rf "$temp_extract" "$DXVK_TEMP"
        fi
    else
        echo "   ✓ DXVK déjà en cache"
    fi
    echo ""
    
    # 4. Télécharger VKD3D-Proton
    echo "4. Préparation de VKD3D-Proton..."
    ensure_dir "$VKD3D_CACHE_DIR"
    local has_vkd3d=false
    find "$VKD3D_CACHE_DIR" -mindepth 1 -maxdepth 1 -type d -name "vkd3d-proton-*" 2>/dev/null | grep -q . && has_vkd3d=true
    
    if [ "$has_vkd3d" = false ]; then
        local VKD3D_TAG="vkd3d-proton-${VKD3D_VERSION}"
        local VKD3D_URL="https://github.com/bottlesdevs/components/releases/download/${VKD3D_TAG}/${VKD3D_TAG}.tar.gz"
        local VKD3D_TEMP="$VKD3D_CACHE_DIR/vkd3d.tar.gz"
        local VKD3D_DIR="$VKD3D_CACHE_DIR/vkd3d-proton-${VKD3D_VERSION}"
        
        echo "   Téléchargement de $VKD3D_TAG..."
        if ! wget -q --show-progress "$VKD3D_URL" -O "$VKD3D_TEMP" 2>&1; then
            echo "   ⚠️ Échec du téléchargement de VKD3D-Proton"
            failed=true
        else
            local temp_extract="$VKD3D_CACHE_DIR/.temp_extract"
            rm -rf "$temp_extract"
            ensure_dir "$temp_extract"
            if tar -xzf "$VKD3D_TEMP" -C "$temp_extract" 2>/dev/null; then
                local extracted_dir
                extracted_dir=$(find "$temp_extract" -maxdepth 1 -type d -name "vkd3d-proton-*" | head -1)
                if [ -d "$extracted_dir" ]; then
                    mv "$extracted_dir" "$VKD3D_DIR"
                    echo "   ✓ VKD3D-Proton téléchargé et extrait"
                fi
            else
                echo "   ⚠️ Échec de l'extraction de VKD3D-Proton"
                failed=true
            fi
            rm -rf "$temp_extract" "$VKD3D_TEMP"
        fi
    else
        echo "   ✓ VKD3D-Proton déjà en cache"
    fi
    echo ""
    
    # 5. Télécharger DXVK-NVAPI ou FakeNVAPI
    echo "5. Préparation de NVAPI..."
    if is_nvidia_gpu; then
        ensure_dir "$DXVK_NVAPI_CACHE_DIR"
        local latest_nvapi
        latest_nvapi=$(get_latest_dxvk_nvapi_version)
        local current_nvapi=""
        local nvapi_folder
        nvapi_folder=$(find "$DXVK_NVAPI_CACHE_DIR" -mindepth 1 -maxdepth 1 -type d -name "dxvk-nvapi-*" 2>/dev/null | head -1)
        [ -n "$nvapi_folder" ] && current_nvapi=$(basename "$nvapi_folder" | sed 's/^dxvk-nvapi-v//; s/^dxvk-nvapi-//')
        
        if [ -z "$current_nvapi" ] || [ "$current_nvapi" != "$latest_nvapi" ]; then
            echo "   Téléchargement de DXVK-NVAPI $latest_nvapi..."
            if ! download_dxvk_nvapi --no-confirm 2>/dev/null; then
                echo "   ⚠️ Échec du téléchargement de DXVK-NVAPI"
                failed=true
            else
                echo "   ✓ DXVK-NVAPI téléchargé"
            fi
        else
            echo "   ✓ DXVK-NVAPI déjà en cache (version $current_nvapi)"
        fi
    else
        ensure_dir "$FAKENVAPI_CACHE_DIR"
        local latest_fakenvapi
        latest_fakenvapi=$(get_latest_fakenvapi_version)
        local current_fakenvapi=""
        local fakenvapi_folder
        fakenvapi_folder=$(find "$FAKENVAPI_CACHE_DIR" -mindepth 1 -maxdepth 1 -type d -name "fakenvapi-*" 2>/dev/null | head -1)
        [ -n "$fakenvapi_folder" ] && current_fakenvapi=$(basename "$fakenvapi_folder" | sed 's/^fakenvapi-v//; s/^fakenvapi-//')
        
        if [ -z "$current_fakenvapi" ] || [ "$current_fakenvapi" != "$latest_fakenvapi" ]; then
            echo "   Téléchargement de FakeNVAPI $latest_fakenvapi..."
            if ! download_fakenvapi --no-confirm 2>/dev/null; then
                echo "   ⚠️ Échec du téléchargement de FakeNVAPI"
                failed=true
            else
                echo "   ✓ FakeNVAPI téléchargé"
            fi
        else
            echo "   ✓ FakeNVAPI déjà en cache (version $current_fakenvapi)"
        fi
    fi
    echo ""
    
    # 6. Télécharger les composants Windows
    echo "6. Préparation des composants Windows..."
    if ! prepare_wincomponents_cache; then
        echo "   ⚠️ Échec du téléchargement des composants Windows"
        failed=true
    fi
    echo ""
    
    # Résumé
    echo "=========================================="
    if [ "$failed" = true ]; then
        echo "⚠️  Certains composants n'ont pas pu être téléchargés"
        echo "Le mode offline pourrait ne pas fonctionner correctement"
        return 1
    else
        echo "✓ Tous les composants sont prêts pour le mode offline"
        echo "Vous pouvez maintenant utiliser 'gwine --init --offline'"
        return 0
    fi
}

# =============================================================================
# Module: cache-main.sh
# =============================================================================


################################################################################
# cache-main.sh - Fonctions principales de gestion du cache
# Préparation locale, mises à jour automatiques, téléchargement des composants
################################################################################

# Télécharge automatiquement les composants manquants
download_missing_components() {
    echo "Téléchargement des composants manquants..."
    
    # Télécharger Wine Mono et Wine Gecko
    if [ ! -d "$COMPONENTS_DIR/wine-cache" ] || [ -z "$(ls -A "$COMPONENTS_DIR/wine-cache" 2>/dev/null)" ]; then
        echo "Téléchargement de Wine Mono et Wine Gecko..."
        local MONO_URL="https://dl.winehq.org/wine/wine-mono/11.0.0/wine-mono-11.0.0-x86.msi"
        local GECKO_URL="https://dl.winehq.org/wine/wine-gecko/2.47.4/wine-gecko-2.47.4-x86_64.msi"
        local GECKO32_URL="https://dl.winehq.org/wine/wine-gecko/2.47.4/wine-gecko-2.47.4-x86.msi"
        
        mkdir -p "$COMPONENTS_DIR/wine-cache"
        
        wget -q --show-progress "$MONO_URL" -O "$COMPONENTS_DIR/wine-cache/wine-mono-11.0.0-x86.msi" 2>&1 || echo "Warning: Échec du téléchargement de Wine Mono"
        wget -q --show-progress "$GECKO_URL" -O "$COMPONENTS_DIR/wine-cache/wine-gecko-2.47.4-x86_64.msi" 2>&1 || echo "Warning: Échec du téléchargement de Wine Gecko (x64)"
        wget -q --show-progress "$GECKO32_URL" -O "$COMPONENTS_DIR/wine-cache/wine-gecko-2.47.4-x86.msi" 2>&1 || echo "Warning: Échec du téléchargement de Wine Gecko (x86)"
    fi
    
    # Télécharger DXVK et VKD3D-Proton
    ensure_dirs "$DXVK_CACHE_DIR" "$VKD3D_CACHE_DIR"
    
    local has_dxvk=false
    find "$DXVK_CACHE_DIR" -mindepth 1 -maxdepth 1 -type d -name "dxvk-*" 2>/dev/null | grep -qv "gplasync\|nvapi" && has_dxvk=true
    
    local has_vkd3d=false
    find "$VKD3D_CACHE_DIR" -mindepth 1 -maxdepth 1 -type d -name "vkd3d-proton-*" 2>/dev/null | grep -q . && has_vkd3d=true
    
    if [ "$has_dxvk" = false ]; then
        echo "Téléchargement de DXVK..."
        
        local DXVK_TAG="dxvk-${DXVK_VERSION}"
        local DXVK_URL="https://github.com/bottlesdevs/components/releases/download/${DXVK_TAG}/${DXVK_TAG}.tar.gz"
        local DXVK_TEMP="$DXVK_CACHE_DIR/dxvk.tar.gz"
        local DXVK_DIR="$DXVK_CACHE_DIR/dxvk-${DXVK_VERSION}"
        
        wget -q --show-progress "$DXVK_URL" -O "$DXVK_TEMP" 2>&1 || echo "Warning: Échec du téléchargement de DXVK"
        if [ -f "$DXVK_TEMP" ]; then
            ensure_dir -s "$DXVK_DIR"
            local temp_extract="$DXVK_CACHE_DIR/.temp_dxvk"
            rm -rf "$temp_extract"
            ensure_dir -s "$temp_extract"
            tar -xzf "$DXVK_TEMP" -C "$temp_extract" 2>/dev/null || true
            local extracted_dir
            extracted_dir=$(find "$temp_extract" -mindepth 1 -maxdepth 1 -type d | head -1)
            if [ -n "$extracted_dir" ]; then
                cp -r "$extracted_dir"/* "$DXVK_DIR/" 2>/dev/null || true
            fi
            rm -rf "$temp_extract" "$DXVK_TEMP"
        fi
    fi
    
    if [ "$has_vkd3d" = false ]; then
        echo "Téléchargement de VKD3D-Proton..."
        
        local old_vkd3d_dir
        old_vkd3d_dir=$(find "$VKD3D_CACHE_DIR" -mindepth 1 -maxdepth 1 -type d -name "vkd3d-proton-*" | head -1)
        if [ -n "$old_vkd3d_dir" ]; then
            echo "Suppression de l'ancienne version VKD3D-Proton: $(basename "$old_vkd3d_dir")"
            rm -rf "$old_vkd3d_dir"
        fi
        
        local VKD3D_TAG="vkd3d-proton-${VKD3D_VERSION}"
        local VKD3D_URL="https://github.com/bottlesdevs/components/releases/download/${VKD3D_TAG}/${VKD3D_TAG}.tar.gz"
        local VKD3D_TEMP="$VKD3D_CACHE_DIR/vkd3d.tar.gz"
        local VKD3D_DIR="$VKD3D_CACHE_DIR/vkd3d-proton-${VKD3D_VERSION}"
        
        wget -q --show-progress "$VKD3D_URL" -O "$VKD3D_TEMP" 2>&1 || echo "Warning: Échec du téléchargement de VKD3D-Proton"
        if [ -f "$VKD3D_TEMP" ]; then
            ensure_dir -s "$VKD3D_DIR"
            local temp_extract="$VKD3D_CACHE_DIR/.temp_vkd3d"
            rm -rf "$temp_extract"
            ensure_dir -s "$temp_extract"
            tar -xf "$VKD3D_TEMP" -C "$temp_extract" 2>/dev/null || true
            local extracted_dir
            extracted_dir=$(find "$temp_extract" -mindepth 1 -maxdepth 1 -type d | head -1)
            if [ -n "$extracted_dir" ]; then
                cp -r "$extracted_dir"/* "$VKD3D_DIR/" 2>/dev/null || true
            fi
            rm -rf "$temp_extract" "$VKD3D_TEMP"
        fi
    fi
}

# Prépare le cache local avec les composants
prepare_local_cache() {
    ensure_dirs "$CACHE_DIR" "$COMPONENTS_DIR" "$SHADER_CACHE_DIR"
    
    local missing_components=false
    
    if [ ! -d "$COMPONENTS_DIR/wine-cache" ] || [ -z "$(ls -A "$COMPONENTS_DIR/wine-cache" 2>/dev/null)" ]; then
        missing_components=true
    fi
    
    if [ ! -d "$DXVK_CACHE_DIR" ] || [ -z "$(find "$DXVK_CACHE_DIR" -mindepth 1 -maxdepth 1 -type d -name "dxvk-*" 2>/dev/null | grep -v "gplasync\|nvapi")" ]; then
        missing_components=true
    fi
    
    if [ ! -d "$VKD3D_CACHE_DIR" ] || [ -z "$(find "$VKD3D_CACHE_DIR" -mindepth 1 -maxdepth 1 -type d -name "vkd3d-proton-*" 2>/dev/null)" ]; then
        missing_components=true
    fi
    
    if [ "$missing_components" = true ]; then
        echo ""
        echo "Certains composants sont manquants dans ~/.cache/gwine/components/"
        echo "Ils seront téléchargés automatiquement..."
        echo ""
        download_missing_components
    fi
}

# Met à jour automatiquement les composants (sans interaction)
auto_update_components() {
    local need_download=false
    local has_network=false
    
    local has_gwine=false
    local has_dxvk=false
    local has_vkd3d=false
    
    [ -d "$WINE_DIR" ] && [ -f "$WINE_DIR/bin/wine64" ] && has_gwine=true
    [ -n "$(find "$DXVK_CACHE_DIR" -maxdepth 1 -type d -name "dxvk-*" 2>/dev/null | grep -v "gplasync\|nvapi")" ] && has_dxvk=true
    [ -n "$(find "$VKD3D_CACHE_DIR" -maxdepth 1 -type d -name "vkd3d-proton-*" 2>/dev/null)" ] && has_vkd3d=true
    
    if curl -s --max-time 5 https://github.com > /dev/null 2>&1; then
        has_network=true
    fi
    
    if [ "$has_gwine" = false ] || [ "$has_dxvk" = false ] || [ "$has_vkd3d" = false ]; then
        need_download=true
        
        if [ "$has_network" = false ]; then
            error_exit "Composants manquants et pas de connexion réseau disponible"
        fi
    fi
    
    if [ "$need_download" = false ] && [ "$has_network" = true ]; then
        local latest_gwine
        latest_gwine=$(get_latest_gwine_version)
        local current_gwine
        current_gwine=$(cat "$GWINE_DIR/.version" 2>/dev/null || echo "")
        local latest_dxvk
        latest_dxvk=$(get_latest_dxvk_version)
        local latest_vkd3d
        latest_vkd3d=$(get_latest_vkd3d_version)
        
        local current_dxvk=""
        local dxvk_folder
        dxvk_folder=$(find "$DXVK_CACHE_DIR" -maxdepth 1 -type d -name "dxvk-*" 2>/dev/null | grep -v "gplasync\|nvapi" | head -1)
        [ -n "$dxvk_folder" ] && current_dxvk=$(basename "$dxvk_folder" | sed 's/^dxvk-//')
        
        local current_vkd3d=""
        local vkd3d_folder
        vkd3d_folder=$(find "$VKD3D_CACHE_DIR" -maxdepth 1 -type d -name "vkd3d-proton-*" 2>/dev/null | head -1)
        [ -n "$vkd3d_folder" ] && current_vkd3d=$(basename "$vkd3d_folder" | sed 's/^vkd3d-proton-//')
        
        if [ -n "$latest_gwine" ] && [ -n "$current_gwine" ]; then
            if compare_versions "$latest_gwine" "$current_gwine"; then
                need_download=true
            fi
        elif [ -z "$current_gwine" ]; then
            need_download=true
        fi
        
        if [ -n "$latest_dxvk" ]; then
            if [ -z "$current_dxvk" ] || compare_versions "$latest_dxvk" "$current_dxvk"; then
                need_download=true
            fi
        fi
        
        if [ -n "$latest_vkd3d" ]; then
            if [ -z "$current_vkd3d" ] || compare_versions "$latest_vkd3d" "$current_vkd3d"; then
                need_download=true
            fi
        fi
    fi
    
    if [ "$need_download" = true ]; then
        echo "Téléchargement des composants..."
        
        if [ "$has_gwine" = false ]; then
            echo "  - Installation de gwine-proton..."
            download_gwine_proton "force" || error_exit "Échec du téléchargement de gwine-proton"
        elif [ "$has_network" = true ]; then
            download_gwine_proton
        fi
        
        if [ "$has_dxvk" = false ] || [ "$has_vkd3d" = false ]; then
            echo "  - Installation de DXVK/VKD3D..."
            download_updated_dxvk_vkd3d --no-confirm || error_exit "Échec du téléchargement de DXVK/VKD3D"
        elif [ "$has_network" = true ]; then
            download_updated_dxvk_vkd3d --no-confirm
        fi
        
        if is_nvidia_gpu; then
            echo "  - Vérification de DXVK-NVAPI (NVIDIA)..."
            local has_nvapi=false
            [ -n "$(find "$DXVK_NVAPI_CACHE_DIR" -maxdepth 1 -type d -name "dxvk-nvapi-*" 2>/dev/null | head -1)" ] && has_nvapi=true
            
            local latest_nvapi
            latest_nvapi=$(get_latest_dxvk_nvapi_version)
            local current_nvapi=""
            local nvapi_folder
            nvapi_folder=$(find "$DXVK_NVAPI_CACHE_DIR" -maxdepth 1 -type d -name "dxvk-nvapi-*" 2>/dev/null | head -1)
            [ -n "$nvapi_folder" ] && current_nvapi=$(basename "$nvapi_folder" | sed 's/^dxvk-nvapi-v//; s/^dxvk-nvapi-//')
            
            if [ "$has_nvapi" = false ] || { [ -n "$latest_nvapi" ] && { [ -z "$current_nvapi" ] || compare_versions "$latest_nvapi" "$current_nvapi"; }; }; then
                echo "  - Installation de DXVK-NVAPI..."
                download_dxvk_nvapi --no-confirm || echo "Warning: Échec du téléchargement de DXVK-NVAPI"
            fi
        else
            echo "  - Vérification de FakeNVAPI (non-NVIDIA)..."
            local has_fakenvapi=false
            [ -n "$(find "$FAKENVAPI_CACHE_DIR" -maxdepth 1 -type d -name "fakenvapi-*" 2>/dev/null | head -1)" ] && has_fakenvapi=true
            
            local latest_fakenvapi
            latest_fakenvapi=$(get_latest_fakenvapi_version)
            local current_fakenvapi=""
            local fakenvapi_folder
            fakenvapi_folder=$(find "$FAKENVAPI_CACHE_DIR" -maxdepth 1 -type d -name "fakenvapi-*" 2>/dev/null | head -1)
            [ -n "$fakenvapi_folder" ] && current_fakenvapi=$(basename "$fakenvapi_folder" | sed 's/^fakenvapi-v//; s/^fakenvapi-//')
            
            if [ "$has_fakenvapi" = false ] || { [ -n "$latest_fakenvapi" ] && { [ -z "$current_fakenvapi" ] || compare_versions "$latest_fakenvapi" "$current_fakenvapi"; }; }; then
                echo "  - Installation de FakeNVAPI..."
                download_fakenvapi --no-confirm || echo "Warning: Échec du téléchargement de FakeNVAPI"
            fi
        fi
    else
        echo "Composants à jour, utilisation des versions locales"
    fi
}

# =============================================================================
# Module: cachepack.sh
# =============================================================================


################################################################################
# cachepack.sh - Création d'un pack du cache pour installation offline
################################################################################

# Crée un pack du cache contenant tous les composants nécessaires pour le --init --offline
# Crée un dossier 'gwine-cache-installer' avec l'archive et un script de déploiement
create_cachepack() {
    local OUTPUT_DIR="$(pwd)/gwine-cache-installer"
    local CACHE_SOURCE="$HOME/.cache/gwine"
    local COMPONENTS_SOURCE="$CACHE_SOURCE/components"
    
    echo "Création du pack cache pour installation offline..."
    echo ""
    
    # Vérifier que le cache existe
    if [ ! -d "$CACHE_SOURCE" ]; then
        error_exit "Cache gwine non trouvé dans $CACHE_SOURCE\nLancez d'abord 'gwine --download-components' pour télécharger les composants."
    fi
    
    # Créer le dossier de sortie
    if [ -d "$OUTPUT_DIR" ]; then
        echo "Le dossier $OUTPUT_DIR existe déjà, suppression..."
        rm -rf "$OUTPUT_DIR"
    fi
    
    mkdir -p "$OUTPUT_DIR"
    echo "Dossier de sortie: $OUTPUT_DIR"
    echo ""
    
    # Vérifier les composants nécessaires
    echo "Vérification des composants..."
    local missing_components=false
    
    # Vérifier gwine-proton (archive en cache uniquement)
    local GWINE_ARCHIVE_DIR="$COMPONENTS_SOURCE/gwine-proton"
    if [ -d "$GWINE_ARCHIVE_DIR" ] && [ -n "$(ls -A "$GWINE_ARCHIVE_DIR"/*.tar.xz 2>/dev/null)" ]; then
        echo "  ✓ gwine-proton présent dans le cache"
    else
        echo "  ⚠️  gwine-proton n'est pas dans le cache"
        missing_components=true
    fi
    
    # Vérifier le cache des composants
    if [ ! -d "$COMPONENTS_SOURCE" ]; then
        echo "  ✗ Composants non trouvés"
        missing_components=true
    else
        echo "  ✓ Composants présents"
    fi
    
    # Vérifier DXVK
    local has_dxvk=false
    if [ -d "$DXVK_CACHE_DIR" ]; then
        find "$DXVK_CACHE_DIR" -mindepth 1 -maxdepth 1 -type d -name "dxvk-*" 2>/dev/null | grep -qv "gplasync\|nvapi" && has_dxvk=true
    fi
    if [ "$has_dxvk" = false ]; then
        echo "  ⚠️  DXVK manquant"
        missing_components=true
    else
        echo "  ✓ DXVK présent"
    fi
    
    # Vérifier VKD3D
    local has_vkd3d=false
    if [ -d "$VKD3D_CACHE_DIR" ]; then
        find "$VKD3D_CACHE_DIR" -mindepth 1 -maxdepth 1 -type d -name "vkd3d-proton-*" 2>/dev/null | grep -q . && has_vkd3d=true
    fi
    if [ "$has_vkd3d" = false ]; then
        echo "  ⚠️  VKD3D-Proton manquant"
        missing_components=true
    else
        echo "  ✓ VKD3D-Proton présent"
    fi
    
    # Vérifier Wine Mono et Gecko
    local wine_cache="$COMPONENTS_SOURCE/wine-cache"
    if [ ! -f "$wine_cache/wine-mono-11.0.0-x86.msi" ] || \
       [ ! -f "$wine_cache/wine-gecko-2.47.4-x86_64.msi" ] || \
       [ ! -f "$wine_cache/wine-gecko-2.47.4-x86.msi" ]; then
        echo "  ⚠️  Wine Mono/Gecko manquants"
        missing_components=true
    else
        echo "  ✓ Wine Mono/Gecko présents"
    fi
    
    # Vérifier les wincomponents (composants Windows)
    if [ ! -d "$CACHE_SOURCE/wincomponents" ]; then
        echo "  ⚠️  Composants Windows (wincomponents) manquants"
        missing_components=true
    else
        # Vérifier plus en détail avec la fonction existante
        if command -v check_wincomponents_cache &>/dev/null; then
            if ! check_wincomponents_cache 2>/dev/null; then
                echo "  ⚠️  Certains composants Windows sont manquants"
                missing_components=true
            else
                echo "  ✓ Composants Windows complets"
            fi
        else
            echo "  ✓ Composants Windows présents"
        fi
    fi
    
    if [ "$missing_components" = true ]; then
        echo ""
        echo "=========================================="
        echo "Certains composants sont manquants."
        echo ""
        echo "Pour télécharger tous les composants:"
        echo "  gwine --download-components"
        echo ""
        echo "Le pack cache ne peut pas être créé."
        echo "=========================================="
        rm -rf "$OUTPUT_DIR"
        exit 1
    fi
    
    # Créer une copie du cache
    echo ""
    echo "Copie du cache..."
    local TEMP_CACHE="$OUTPUT_DIR/.temp_cache"
    mkdir -p "$TEMP_CACHE"
    
    # Copier les composants essentiels
    echo "  - Copie des composants..."
    cp -r "$COMPONENTS_SOURCE" "$TEMP_CACHE/"
    
    # Copier les wincomponents (composants Windows - ESSENTIEL pour --offline)
    local WINCOMPONENTS_SOURCE="$CACHE_SOURCE/wincomponents"
    if [ -d "$WINCOMPONENTS_SOURCE" ]; then
        echo "  - Copie des composants Windows (wincomponents)..."
        cp -r "$WINCOMPONENTS_SOURCE" "$TEMP_CACHE/"
    else
        echo "  ⚠️  ATTENTION: wincomponents non trouvé !"
        echo "      Le mode offline ne fonctionnera pas correctement."
        echo "      Lancez d'abord: gwine --download-components"
        rm -rf "$OUTPUT_DIR"
        exit 1
    fi
    
    # Pas besoin de copier gwine-proton séparément, il est déjà dans components/gwine-proton/
    
    # Créer l'archive
    echo ""
    echo "Création de l'archive..."
    local ARCHIVE_NAME="gwine-cache.tar.xz"
    local ARCHIVE_PATH="$OUTPUT_DIR/$ARCHIVE_NAME"
    
    cd "$OUTPUT_DIR"
    if tar -cJf "$ARCHIVE_NAME" -C "$TEMP_CACHE" .; then
        echo "  ✓ Archive créée: $ARCHIVE_NAME"
    else
        echo "  ✗ Échec de la création de l'archive"
        rm -rf "$OUTPUT_DIR"
        exit 1
    fi
    
    # Nettoyer le dossier temporaire
    rm -rf "$TEMP_CACHE"
    
    # Créer le script de déploiement
    echo ""
    echo "Création du script de déploiement..."
    
    cat > "$OUTPUT_DIR/install-cache.sh" << 'DEPLOY_SCRIPT'
#!/bin/bash

# Script de déploiement du cache Gwine
# Ce script déploie le cache sur le système et propose de lancer l'initialisation

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ARCHIVE_FILE="$SCRIPT_DIR/gwine-cache.tar.xz"
CACHE_DIR="$HOME/.cache/gwine"
GWINE_DIR="$HOME/.local/share/gwine"

# Couleurs pour les messages
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "========================================"
echo "  Déploiement du cache Gwine"
echo "========================================"
echo ""

# Vérifier que l'archive existe
if [ ! -f "$ARCHIVE_FILE" ]; then
    echo -e "${RED}Erreur: Archive non trouvée: $ARCHIVE_FILE${NC}"
    exit 1
fi

# Vérifier que gwine est disponible (dans le PATH)
if ! command -v gwine &> /dev/null; then
    echo -e "${RED}Erreur: Gwine n'est pas installé sur ce système.${NC}"
    echo "Veuillez installer gwine avant de déployer le cache."
    exit 1
fi

# Demander confirmation
if command -v kdialog &> /dev/null; then
    if ! kdialog --title "Déploiement du cache" --yesno "Voulez-vous déployer le cache Gwine sur ce système ?"; then
        echo "Déploiement annulé."
        exit 0
    fi
else
    echo "Ce script va déployer le cache Gwine dans:"
    echo "  - $CACHE_DIR"
    echo "  - $GWINE_DIR"
    echo ""
    read -p "Voulez-vous déployer le cache ? [O/n]: " -r
    if [[ ! "$REPLY" =~ ^[OoYy]$ ]] && [ -n "$REPLY" ]; then
        echo "Déploiement annulé."
        exit 0
    fi
fi

echo ""
echo "Déploiement en cours..."

# Nettoyer l'ancien cache en préservant le shader cache
echo "  - Nettoyage de l'ancien cache..."
if [ -d "$CACHE_DIR" ]; then
    # Supprimer tout sauf shader-cache
    find "$CACHE_DIR" -mindepth 1 -maxdepth 1 ! -name "shader-cache" -exec rm -rf {} + 2>/dev/null || true
fi

# Supprimer l'ancien gwine
if [ -d "$GWINE_DIR" ]; then
    echo "  - Suppression de l'ancienne installation..."
    rm -rf "$GWINE_DIR"
fi

# Créer les nouveaux répertoires
mkdir -p "$CACHE_DIR"
mkdir -p "$GWINE_DIR"

# Extraire l'archive
echo "  - Extraction de l'archive..."
if tar -xJf "$ARCHIVE_FILE" -C "$CACHE_DIR"; then
    echo -e "${GREEN}  ✓ Cache déployé avec succès${NC}"
else
    echo -e "${RED}  ✗ Échec du déploiement${NC}"
    # Restaurer les backups en cas d'échec
    rm -rf "$CACHE_DIR" "$GWINE_DIR"
    exit 1
fi



# Déplacer gwine-proton vers le bon emplacement
if [ -d "$CACHE_DIR/gwine" ]; then
    echo "  - Installation de gwine-proton..."
    mv "$CACHE_DIR/gwine"/* "$GWINE_DIR/"
    rm -rf "$CACHE_DIR/gwine"
    echo -e "${GREEN}  ✓ gwine-proton installé${NC}"
fi

# Extraire et installer gwine-proton depuis components/gwine-proton/
if [ -d "$CACHE_DIR/components/gwine-proton" ]; then
    echo "  - Extraction de gwine-proton..."
    local archive_file
    archive_file=$(ls "$CACHE_DIR/components/gwine-proton"/*.tar.xz 2>/dev/null | head -1)
    if [ -n "$archive_file" ]; then
        local temp_extract="/tmp/gwine-extract-$$"
        mkdir -p "$temp_extract"
        if tar -xJf "$archive_file" -C "$temp_extract"; then
            local extracted_dir
            extracted_dir=$(find "$temp_extract" -maxdepth 1 -type d -name "*gwine*" | head -1)
            [ -z "$extracted_dir" ] && extracted_dir=$(find "$temp_extract" -maxdepth 1 -type d | head -1)
            if [ -n "$extracted_dir" ]; then
                cp -r "$extracted_dir"/* "$GWINE_DIR/"
                echo -e "${GREEN}  ✓ gwine-proton installé${NC}"
            fi
        fi
        rm -rf "$temp_extract"
    fi
fi

echo ""
echo -e "${GREEN}✓ Déploiement terminé avec succès !${NC}"
echo ""

# Demander si l'utilisateur veut lancer --init --offline
echo "Voulez-vous maintenant initialiser le préfixe Wine ?"
echo "Cela lancera: gwine --init --offline --kdialog"
echo ""

INIT_CONFIRM=false
if command -v kdialog &> /dev/null; then
    if kdialog --title "Initialisation" --yesno "Voulez-vous initialiser le préfixe Wine maintenant ?\n\nCela configurera Wine avec tous les composants nécessaires."; then
        INIT_CONFIRM=true
    fi
else
    read -p "Lancer l'initialisation ? [O/n]: " -r
    if [[ "$REPLY" =~ ^[OoYy]$ ]] || [ -z "$REPLY" ]; then
        INIT_CONFIRM=true
    fi
fi

if [ "$INIT_CONFIRM" = true ]; then
    echo ""
    echo "Lancement de l'initialisation..."
    echo "========================================"
    gwine --init --offline --kdialog
else
    echo ""
    echo "Pour initialiser plus tard, lancez:"
    echo "  gwine --init --offline"
fi

echo ""
echo "========================================"
DEPLOY_SCRIPT

    # Rendre le script exécutable
    chmod +x "$OUTPUT_DIR/install-cache.sh"
    echo "  ✓ Script de déploiement créé: install-cache.sh"
    
    # Créer un README
    cat > "$OUTPUT_DIR/README.txt" << 'README'
Gwine Cache Installer
=====================

Ce dossier contient tous les composants nécessaires pour installer Gwine
en mode offline.

Contenu:
  - gwine-cache.tar.xz    : Archive contenant le cache et gwine-proton
  - install-cache.sh      : Script de déploiement automatique
  - README.txt            : Ce fichier

Instructions:
=============

1. Copiez ce dossier sur la machine cible (sans connexion internet)

2. Exécutez le script de déploiement:
     ./install-cache.sh

   Le script va:
   - Déployer le cache dans ~/.cache/gwine/
   - Installer gwine-proton dans ~/.local/share/gwine/
   - Proposer d'initialiser le préfixe Wine (avec kdialog si disponible)

3. Alternative manuelle:
   - Extraire gwine-cache.tar.xz dans ~/.cache/gwine/
   - Si un dossier gwine/ existe: copier vers ~/.local/share/gwine/
   - Si un dossier gwine-archive/ existe: extraire l'archive .tar.xz
   - Lancer: gwine --init --offline

Notes:
======
- Assurez-vous que les dépendances système sont installées
  (wine, squashfuse, bubblewrap, fuse-overlayfs, etc.)
- Le script détecte automatiquement si kdialog est disponible
- Le préfixe Wine sera créé dans ~/Windows/Prefix/
- Le pack peut contenir gwine soit installé soit sous forme d'archive

Pour plus d'informations: https://github.com/elgabo86/gwine
README

    echo "  ✓ README créé"
    
    # Afficher le résumé
    echo ""
    echo "========================================"
    echo "  Pack cache créé avec succès !"
    echo "========================================"
    echo ""
    echo "Emplacement: $OUTPUT_DIR"
    echo ""
    echo "Contenu:"
    ls -lh "$OUTPUT_DIR" | tail -n +2
    echo ""
    echo "Pour déployer sur une autre machine:"
    echo "  1. Copiez le dossier '$OUTPUT_DIR'"
    echo "  2. Exécutez: ./install-cache.sh"
    echo ""
    echo "Le cache est prêt pour le mode offline."
}

# =============================================================================
# Module: wineprefix.sh
# =============================================================================


################################################################################
# wineprefix.sh - Gestion du préfixe Wine (création, init, DLLs, configuration)
################################################################################

# =============================================================================
# Gestion du préfixe Wine
# =============================================================================

# Sauvegarde le préfixe Wine existant
# Usage: backup_wineprefix [suffix]
# Paramètres:
#   suffix : Suffixe optionnel pour le nom du backup (défaut: timestamp)
# Définit la variable globale _WINETRICKS_BACKUP_PREFIX avec le chemin du backup
# Retourne 0 si succès ou si pas de préfixe à sauvegarder, 1 si échec
backup_wineprefix() {
    local suffix="${1:-$(date +%Y%m%d_%H%M%S)}"
    local backup_dir="$HOME_REAL/Windows/Prefix.backup.$suffix"
    
    if [ -d "$WINEPREFIX" ]; then
        if mv "$WINEPREFIX" "$backup_dir" 2>/dev/null; then
            _WINETRICKS_BACKUP_PREFIX="$backup_dir"
            return 0
        else
            echo "Erreur: Impossible de sauvegarder le préfixe"
            return 1
        fi
    fi
    
    return 0
}

# Restaure le préfixe Wine depuis le backup
# Usage: restore_wineprefix [backup_path]
# Paramètres:
#   backup_path : Chemin du backup (défaut: utilise _WINETRICKS_BACKUP_PREFIX)
# Retourne 0 si succès ou si pas de backup, 1 si échec
restore_wineprefix() {
    local backup_path="${1:-${_WINETRICKS_BACKUP_PREFIX:-}}"
    
    if [ -z "$backup_path" ] || [ ! -d "$backup_path" ]; then
        return 0
    fi
    
    echo ""
    echo "⚠️  Restauration de l'ancien préfixe..."
    
    # Supprimer le préfixe incomplet s'il existe
    if [ -d "$WINEPREFIX" ]; then
        rm -rf "$WINEPREFIX" 2>/dev/null || true
    fi
    
    # Restaurer depuis le backup
    if mv -T "$backup_path" "$WINEPREFIX" 2>/dev/null; then
        echo "Ancien préfixe restauré: $WINEPREFIX"
        return 0
    else
        # Essayer la méthode classique si mv -T échoue
        rm -rf "$WINEPREFIX" 2>/dev/null || true
        if mv "$backup_path" "$WINEPREFIX" 2>/dev/null; then
            echo "Ancien préfixe restauré: $WINEPREFIX"
            return 0
        else
            echo "ERREUR: Impossible de restaurer le backup !"
            echo "Backup disponible dans: $backup_path"
            return 1
        fi
    fi
}

# Initialise un préfixe Wine avec wineboot --init
# Désactive mscoree et mshtml pour éviter les fenêtres de dialogue Mono/Gecko
wineboot_init_prefix() {
    WINEDLLOVERRIDES="mscoree,mshtml=" WINEPREFIX="$WINEPREFIX" "$WINE_BIN" wineboot --init >/dev/null 2>&1
}

# Vérifie que Wine est disponible et exécutable
# Usage: require_wine [custom_message]
require_wine() {
    local custom_msg="${1:-}"
    
    if [ ! -x "$WINE_BIN" ]; then
        if [ -n "$custom_msg" ]; then
            error_exit "$custom_msg"
        else
            error_exit "Wine introuvable: $WINE_BIN"
        fi
    fi
}

# Configure la structure des dossiers Windows avec liens symboliques
setup_windows_directories() {
    local target_prefix="${1:-$WINEPREFIX}"
    
    echo "Configuration de la structure des dossiers Windows..."
    
    # Créer les dossiers utilisateur dans ~/Windows/
    for dir in UserData SteamData Games Applications; do
        if [ ! -e "$HOME_REAL/Windows/$dir" ] && [ ! -L "$HOME_REAL/Windows/$dir" ]; then
            if ! mkdir -p "$HOME_REAL/Windows/$dir"; then
                echo "Erreur: Impossible de créer le dossier $HOME_REAL/Windows/$dir"
                return 1
            fi
        fi
    done
    
    # Créer les liens symboliques depuis le préfixe vers ~/Windows/
    
    # users -> ~/Windows/UserData
    if [ -e "$target_prefix/drive_c/users" ] || [ -L "$target_prefix/drive_c/users" ]; then
        rm -rf "$target_prefix/drive_c/users"
    fi
    if ! ln -sf "$HOME_REAL/Windows/UserData" "$target_prefix/drive_c/users"; then
        echo "Erreur: Échec de création du lien symbolique users"
        return 1
    fi
    
    # ProgramData/Steam -> ~/Windows/SteamData
    if ! mkdir -p "$target_prefix/drive_c/ProgramData/"; then
        echo "Erreur: Impossible de créer ProgramData"
        return 1
    fi
    if [ -e "$target_prefix/drive_c/ProgramData/Steam" ] || [ -L "$target_prefix/drive_c/ProgramData/Steam" ]; then
        rm -rf "$target_prefix/drive_c/ProgramData/Steam"
    fi
    if ! ln -sf "$HOME_REAL/Windows/SteamData" "$target_prefix/drive_c/ProgramData/Steam"; then
        echo "Erreur: Échec de création du lien symbolique Steam"
        return 1
    fi
    
    # drive_c/Applications -> ~/Windows/Applications
    if [ -e "$target_prefix/drive_c/Applications" ] || [ -L "$target_prefix/drive_c/Applications" ]; then
        rm -rf "$target_prefix/drive_c/Applications"
    fi
    if ! ln -sf "$HOME_REAL/Windows/Applications" "$target_prefix/drive_c/Applications"; then
        echo "Erreur: Échec de création du lien symbolique Applications"
        return 1
    fi
    
    # drive_c/Games -> ~/Windows/Games
    if [ -e "$target_prefix/drive_c/Games" ] || [ -L "$target_prefix/drive_c/Games" ]; then
        rm -rf "$target_prefix/drive_c/Games"
    fi
    if ! ln -sf "$HOME_REAL/Windows/Games" "$target_prefix/drive_c/Games"; then
        echo "Erreur: Échec de création du lien symbolique Games"
        return 1
    fi
    
    echo "Structure des dossiers configurée avec succès"
    return 0
}

# Copie la configuration MangoHud
copy_mangohud_config() {
    local MANGOHUD_CONFIG_DIR="$HOME_REAL/.config/MangoHud"
    local MANGOHUD_CONF_USER="$MANGOHUD_CONFIG_DIR/MangoHud.conf"
    local MANGOHUD_CONF_SOURCE="/usr/share/ublue-os/gablue/MangoHud.conf"
    
    # Créer le dossier de config
    ensure_dir "$MANGOHUD_CONFIG_DIR" "Impossible de créer le dossier $MANGOHUD_CONFIG_DIR"
    
    # Copier la config depuis ublue-os/gablue si elle existe
    if [ -f "$MANGOHUD_CONF_SOURCE" ]; then
        echo "Copie de la configuration MangoHud depuis $MANGOHUD_CONF_SOURCE..."
        if cp -f "$MANGOHUD_CONF_SOURCE" "$MANGOHUD_CONF_USER"; then
            echo "Configuration MangoHud copiée dans $MANGOHUD_CONF_USER"
        else
            echo "Erreur: Échec de la copie de la configuration MangoHud"
            return 1
        fi
    else
        # Créer un config MangoHud par défaut si inexistant
        if [ ! -f "$MANGOHUD_CONF_USER" ]; then
            cat > "$MANGOHUD_CONF_USER" << 'EOF'
# MangoHud configuration
fps_limit=0
vsync=0
gl_vsync=0
legacy_layout=false
gpu_stats
cpu_stats
ram
vram
fps
frame_timing
EOF
            echo "Configuration MangoHud créée dans ~/.config/MangoHud/"
        else
            echo "Configuration MangoHud déjà existante"
        fi
    fi
    
    return 0
}

# Fonctions de fix manette (DisableHidraw)
apply_padfix_setting() {
    local SYSTEM_REG="$WINEPREFIX/system.reg"
    
    if [ ! -f "$SYSTEM_REG" ]; then
        echo "Warning: system.reg introuvable, skip du fix manette"
        return 0
    fi
    
    if ! grep -q '\[System\\\\CurrentControlSet\\\\Services\\\\WineBus\]' "$SYSTEM_REG" 2>/dev/null; then
        echo '' >> "$SYSTEM_REG"
        echo '[System\\CurrentControlSet\\Services\\WineBus]' >> "$SYSTEM_REG"
    fi
    
    if [ "$fix_mode" = true ]; then
        if grep -q '"DisableHidraw"' "$SYSTEM_REG" 2>/dev/null; then
            sed -i 's/"DisableHidraw"=dword:00000001/"DisableHidraw"=dword:00000000/' "$SYSTEM_REG"
            echo "Mode fix manette: DisableHidraw=0 (hidraw activé)"
        else
            echo '"DisableHidraw"=dword:00000000' >> "$SYSTEM_REG"
            echo "Mode fix manette: DisableHidraw=0 (hidraw activé)"
        fi
    else
        if grep -q '"DisableHidraw"' "$SYSTEM_REG" 2>/dev/null; then
            sed -i 's/"DisableHidraw"=dword:00000000/"DisableHidraw"=dword:00000001/' "$SYSTEM_REG"
            echo "Mode normal: DisableHidraw=1 (hidraw désactivé par défaut)"
        else
            echo '"DisableHidraw"=dword:00000001' >> "$SYSTEM_REG"
            echo "Mode normal: DisableHidraw=1 (hidraw désactivé par défaut)"
        fi
    fi
}

# Restaurer DisableHidraw après le lancement
restore_padfix_setting() {
    [ "$fix_mode" != true ] && return 0
    
    sleep 0.5
    local SYSTEM_REG="$WINEPREFIX/system.reg"
    
    if [ -f "$SYSTEM_REG" ]; then
        sed -i 's/"DisableHidraw"=dword:00000000/"DisableHidraw"=dword:00000001/' "$SYSTEM_REG"
        echo "Mode fix restauré: DisableHidraw=1"
    fi
}

# =============================================================================
# Fonctions pour le préfixe isolé avec overlayfs
# =============================================================================

# Prépare l'overlay du préfixe Wine pour isolation
# Usage: setup_isolated_prefix <real_prefix>
setup_isolated_prefix() {
    local real_prefix="$1"
    
    if [ "$isolated_prefix_mode" != "true" ]; then
        echo "$real_prefix"
        return 0
    fi
    
    # Générer un ID unique pour cette instance
    local instance_id
    instance_id="$(date +%s)_$$_$RANDOM"
    local overlay_base="/tmp/gwine-prefix-overlay-$instance_id"
    
    _ISOLATED_PREFIX_MOUNT="$overlay_base/merged"
    _ISOLATED_PREFIX_UPPER="$overlay_base/upper"
    _ISOLATED_PREFIX_WORK="$overlay_base/work"
    _ISOLATED_PREFIX_REAL="$real_prefix"
    
    echo "Configuration du préfixe isolé avec overlayfs..." >&2
    echo "  Préfixe réel (RO): $real_prefix" >&2
    echo "  Point de montage: $_ISOLATED_PREFIX_MOUNT" >&2
    
    # Créer les dossiers nécessaires
    ensure_dirs -s "$_ISOLATED_PREFIX_MOUNT" "$_ISOLATED_PREFIX_UPPER" "$_ISOLATED_PREFIX_WORK"
    
    # Vérifier que le préfixe réel existe
    if [ ! -d "$real_prefix" ]; then
        echo "Warning: Le préfixe réel n'existe pas: $real_prefix" >&2
        echo "$real_prefix"
        return 1
    fi
    
    # Monter overlayfs avec fuse-overlayfs (userspace, pas besoin de root)
    echo "Tentative de montage avec fuse-overlayfs..." >&2
    if command -v fuse-overlayfs &>/dev/null; then
        if ! fuse-overlayfs -o "lowerdir=$real_prefix,upperdir=$_ISOLATED_PREFIX_UPPER,workdir=$_ISOLATED_PREFIX_WORK" "$_ISOLATED_PREFIX_MOUNT" 2>&1; then
            echo "Warning: Échec du montage fuse-overlayfs" >&2
            cleanup_isolated_prefix_instance "$_ISOLATED_PREFIX_MOUNT" "$_ISOLATED_PREFIX_UPPER" "$_ISOLATED_PREFIX_WORK"
            _ISOLATED_PREFIX_MOUNT=""
            _ISOLATED_PREFIX_UPPER=""
            _ISOLATED_PREFIX_WORK=""
            echo "$real_prefix"
            return 1
        fi
    else
        echo "Warning: fuse-overlayfs non disponible, utilisation du préfixe direct" >&2
        cleanup_isolated_prefix_instance "$_ISOLATED_PREFIX_MOUNT" "$_ISOLATED_PREFIX_UPPER" "$_ISOLATED_PREFIX_WORK"
        _ISOLATED_PREFIX_MOUNT=""
        _ISOLATED_PREFIX_UPPER=""
        _ISOLATED_PREFIX_WORK=""
        echo "$real_prefix"
        return 1
    fi
    
    echo "Overlay monté avec succès: $_ISOLATED_PREFIX_MOUNT" >&2
    
    # Gérer .update-timestamp : CRUCIAL pour éviter "La configuration est en cours de mise à jour"
    # Wine détecte un "nouveau" préfixe quand le chemin change et écrit le timestamp actuel.
    # Solution : mettre dans .update-timestamp le timestamp du nom du dossier overlay.
    # Ex: /tmp/gwine-prefix-overlay-1773862805_30863_31580 -> mettre 1773862805 dans le fichier
    local overlay_timestamp="$_ISOLATED_PREFIX_MOUNT/.update-timestamp"
    local instance_timestamp
    instance_timestamp=$(echo "$instance_id" | cut -d'_' -f1)
    
    # Créer le fichier avec le timestamp du nom du dossier
    rm -f "$overlay_timestamp" 2>/dev/null || true
    echo "$instance_timestamp" > "$overlay_timestamp" 2>/dev/null || true
    # Mettre en read-only pour empêcher Wine de l'écraser
    chmod 444 "$overlay_timestamp" 2>/dev/null || true
    echo "  Timestamp configuré: .update-timestamp ($instance_timestamp) [read-only]" >&2
    
    # Créer des symlinks vers les vrais fichiers de registre pour accès simultané
    # Les modifications au registre seront persistantes entre les instances
    local reg_files=("system.reg" "user.reg" "userdef.reg")
    for reg_file in "${reg_files[@]}"; do
        local real_reg="$real_prefix/$reg_file"
        local overlay_reg="$_ISOLATED_PREFIX_MOUNT/$reg_file"
        
        if [ -f "$real_reg" ]; then
            # Supprimer le fichier de l'upperdir s'il existe (pour ne pas cacher le lower)
            rm -f "$_ISOLATED_PREFIX_UPPER/$reg_file" 2>/dev/null || true
            # Créer un symlink vers le vrai fichier de registre
            rm -f "$overlay_reg" 2>/dev/null || true
            ln -s "$real_reg" "$overlay_reg" 2>/dev/null || true
            echo "  Registre partagé: $reg_file" >&2
        fi
    done
    
    echo "$_ISOLATED_PREFIX_MOUNT"
    return 0
}

# Nettoie l'overlay du préfixe isolé (utilise les variables globales)
cleanup_isolated_prefix() {
    if [ -z "$_ISOLATED_PREFIX_MOUNT" ]; then
        return 0
    fi
    
    cleanup_isolated_prefix_instance "$_ISOLATED_PREFIX_MOUNT" "$_ISOLATED_PREFIX_UPPER" "$_ISOLATED_PREFIX_WORK"
    
    _ISOLATED_PREFIX_MOUNT=""
    _ISOLATED_PREFIX_UPPER=""
    _ISOLATED_PREFIX_WORK=""
    _ISOLATED_PREFIX_REAL=""
}

# Nettoie une instance spécifique d'overlay (pour les traps)
cleanup_isolated_prefix_instance() {
    local mount_point="$1"
    local upper_dir="$2"
    local work_dir="$3"
    
    if [ -z "$mount_point" ]; then
        return 0
    fi
    
    echo "Nettoyage du préfixe isolé: $mount_point" >&2
    
    # Attendre que wineserver sauvegarde le registre avant de démonter
    if mountpoint -q "$mount_point" 2>/dev/null; then
        if command -v wineserver &>/dev/null; then
            WINEPREFIX="$mount_point" wineserver -w 2>/dev/null || true
        fi
    fi
    
    # Démonter l'overlay (fuse-overlayfs utilise fusermount)
    unmount_fuse_overlay "$mount_point"
    
    # Supprimer les dossiers
    local overlay_base
    overlay_base="$(dirname "$mount_point")"
    if [ -d "$overlay_base" ]; then
        rm -rf "$overlay_base" 2>/dev/null || true
    fi
    
    echo "Préfixe isolé nettoyé: $mount_point" >&2
}

# =============================================================================
# Module: sandbox.sh
# =============================================================================


################################################################################
# sandbox.sh - Sandboxing avec bubblewrap
################################################################################

build_bwrap_args() {
    local exe_dir="${1:-}"
    local access_mode="${2:-rw}"  # "ro" ou "rw"
    local bwrap_args=""
    
    bwrap_args="$bwrap_args --unshare-all"
    bwrap_args="$bwrap_args --share-net"
    
    # Système de fichiers - lecture seule partout sauf exceptions
    bwrap_args="$bwrap_args --ro-bind / /"
    bwrap_args="$bwrap_args --proc /proc"
    
    # Cacher /home et /var (seront remplacés par les bindings autorisés)
    bwrap_args="$bwrap_args --tmpfs /home"
    bwrap_args="$bwrap_args --tmpfs /var"
    
    # Réseau - accès complet
    bwrap_args="$bwrap_args --bind-try /etc/resolv.conf /etc/resolv.conf"
    bwrap_args="$bwrap_args --bind-try /etc/hosts /etc/hosts"
    bwrap_args="$bwrap_args --bind-try /etc/ssl /etc/ssl"
    bwrap_args="$bwrap_args --bind-try /etc/ca-certificates /etc/ca-certificates"
    bwrap_args="$bwrap_args --bind-try /etc/pki /etc/pki"
    bwrap_args="$bwrap_args --bind-try /etc/localtime /etc/localtime"
    bwrap_args="$bwrap_args --bind-try /etc/machine-id /etc/machine-id"
    
    if [ -d "/dev/shm" ]; then
        bwrap_args="$bwrap_args --bind /dev/shm /dev/shm"
    fi
    
    if [ -d "/dev/dri" ]; then
        bwrap_args="$bwrap_args --dev-bind /dev/dri /dev/dri"
    fi
    
    if [ -d "/dev/input" ]; then
        bwrap_args="$bwrap_args --dev-bind /dev/input /dev/input"
    fi
    
    if [ "$fix_mode" = true ]; then
        for hidraw in /dev/hidraw*; do
            if [ -e "$hidraw" ]; then
                bwrap_args="$bwrap_args --dev-bind-try $hidraw $hidraw"
            fi
        done
    fi
    
    for dev in null zero random urandom full tty; do
        if [ -e "/dev/$dev" ]; then
            bwrap_args="$bwrap_args --dev-bind-try /dev/$dev /dev/$dev"
        fi
    done
    
    if [ -e "/dev/ntsync" ]; then
        bwrap_args="$bwrap_args --dev-bind /dev/ntsync /dev/ntsync"
    fi
    
    if [ -n "${XDG_RUNTIME_DIR:-}" ] && [ -d "$XDG_RUNTIME_DIR" ]; then
        bwrap_args="$bwrap_args --bind-try \"$XDG_RUNTIME_DIR\" \"$XDG_RUNTIME_DIR\""
    else
        local user_id
        user_id=$(id -u)
        if [ -d "/run/user/$user_id" ]; then
            bwrap_args="$bwrap_args --bind-try /run/user/$user_id /run/user/$user_id"
        fi
    fi
    
    if [ -d "/run/dbus" ]; then
        bwrap_args="$bwrap_args --bind /run/dbus /run/dbus"
    fi
    
    if [ -n "${MANGOHUD_BIN:-}" ] && [ -f "$MANGOHUD_BIN" ]; then
        bwrap_args="$bwrap_args --ro-bind-try $MANGOHUD_BIN $MANGOHUD_BIN"
    fi
    
    if [ -d "/usr/lib/mangohud" ]; then
        bwrap_args="$bwrap_args --ro-bind-try /usr/lib/mangohud /usr/lib/mangohud"
    fi
    if [ -d "/usr/lib64/mangohud" ]; then
        bwrap_args="$bwrap_args --ro-bind-try /usr/lib64/mangohud /usr/lib64/mangohud"
    fi
    if [ -d "/usr/share/mangohud" ]; then
        bwrap_args="$bwrap_args --ro-bind-try /usr/share/mangohud /usr/share/mangohud"
    fi
    
    # MangoHud config - utiliser HOME_REAL car HOME est dans tmpfs
    local mangohud_config_dir="$HOME_REAL/.config/MangoHud"
    if [ -d "$mangohud_config_dir" ]; then
        bwrap_args="$bwrap_args --ro-bind-try "$mangohud_config_dir" "$mangohud_config_dir""
    fi
    
    if [ -d "$HOME_REAL/Windows" ]; then
        bwrap_args="$bwrap_args --bind \"$HOME_REAL/Windows\" \"$HOME_REAL/Windows\""
        # Si SteamData ou UserData sont des symlinks, autoriser aussi leurs destinations
        for subdir in SteamData UserData; do
            local subdir_path="$HOME_REAL/Windows/$subdir"
            if [ -L "$subdir_path" ]; then
                local real_path
                real_path=$(readlink -f "$subdir_path")
                if [ -n "$real_path" ] && [ "$real_path" != "$subdir_path" ]; then
                    bwrap_args="$bwrap_args --bind \"$real_path\" \"$real_path\""
                fi
            fi
        done
    fi
    
    if [ -d "$CACHE_DIR" ]; then
        bwrap_args="$bwrap_args --bind \"$CACHE_DIR\" \"$CACHE_DIR\""
    fi
    
    # Dossier des extras WGP (wgp-extra)
    if [ -d "$EXTRA_REAL" ]; then
        bwrap_args="$bwrap_args --bind \"$EXTRA_REAL\" \"$EXTRA_REAL\""
    fi
    
    # Gwine installation - nécessaire pour Wine
    if [ -d "$GWINE_DIR" ]; then
        bwrap_args="$bwrap_args --bind \"$GWINE_DIR\" \"$GWINE_DIR\""
    fi
    
    bwrap_args="$bwrap_args --bind /tmp /tmp"
    
    if [ -d "/run/media" ]; then
        bwrap_args="$bwrap_args --bind /run/media /run/media"
    fi
    
    local download_dir
    download_dir=$(xdg-user-dir DOWNLOAD 2>/dev/null)
    if [ -z "$download_dir" ] || [ ! -d "$download_dir" ]; then
        download_dir="$HOME_REAL/Téléchargements"
        [ ! -d "$download_dir" ] && download_dir="$HOME_REAL/Downloads"
    fi
    
    if [ -n "$download_dir" ] && [ -d "$download_dir" ]; then
        bwrap_args="$bwrap_args --bind \"$download_dir\" \"$download_dir\""
    fi
    
    # Dossier du jeu/exe - accès configurable
    if [ -n "$exe_dir" ] && [ -d "$exe_dir" ]; then
        if [ "$access_mode" = "ro" ]; then
            bwrap_args="$bwrap_args --ro-bind \"$exe_dir\" \"$exe_dir\""
        else
            bwrap_args="$bwrap_args --bind \"$exe_dir\" \"$exe_dir\""
        fi
    fi
    
    bwrap_args="$bwrap_args --setenv HOME \"$HOME\""
    bwrap_args="$bwrap_args --setenv WINEPREFIX \"$WINEPREFIX\""
    bwrap_args="$bwrap_args --setenv WINEARCH \"$WINEARCH\""
    bwrap_args="$bwrap_args --setenv WINE \"$WINE_BIN\""
    bwrap_args="$bwrap_args --setenv PATH \"$PATH\""
    
    if [ -n "${XDG_RUNTIME_DIR:-}" ]; then
        bwrap_args="$bwrap_args --setenv XDG_RUNTIME_DIR \"$XDG_RUNTIME_DIR\""
    fi
    
    local PRELOAD_LIBS=""
    
    if [ -n "${MANGOHUD_BIN:-}" ]; then
        local MANGOHUD_LIBS="/usr/lib/mangohud/libMangoHud_shim.so:/usr/lib64/mangohud/libMangoHud_shim.so"
        PRELOAD_LIBS="$MANGOHUD_LIBS"
    fi
    
    if [ -n "$PRELOAD_LIBS" ]; then
        bwrap_args="$bwrap_args --setenv LD_PRELOAD \"$PRELOAD_LIBS\""
    elif [ -n "${LD_PRELOAD:-}" ]; then
        bwrap_args="$bwrap_args --setenv LD_PRELOAD \"$LD_PRELOAD\""
    else
        bwrap_args="$bwrap_args --setenv LD_PRELOAD \"\""
    fi
    
    [ -n "${WINE_LARGE_ADDRESS_AWARE:-}" ] && bwrap_args="$bwrap_args --setenv WINE_LARGE_ADDRESS_AWARE \"$WINE_LARGE_ADDRESS_AWARE\""
    [ -n "${STAGING_SHARED_MEMORY:-}" ] && bwrap_args="$bwrap_args --setenv STAGING_SHARED_MEMORY \"$STAGING_SHARED_MEMORY\""
    [ -n "${WINEFSYNC:-}" ] && bwrap_args="$bwrap_args --setenv WINEFSYNC \"$WINEFSYNC\""
    [ -n "${PULSE_LATENCY_MSEC:-}" ] && bwrap_args="$bwrap_args --setenv PULSE_LATENCY_MSEC \"$PULSE_LATENCY_MSEC\""
    [ -n "${WINEDEBUG:-}" ] && bwrap_args="$bwrap_args --setenv WINEDEBUG \"$WINEDEBUG\""
    [ -n "${WINEDLLOVERRIDES:-}" ] && bwrap_args="$bwrap_args --setenv WINEDLLOVERRIDES \"$WINEDLLOVERRIDES\""
    [ -n "${LD_LIBRARY_PATH:-}" ] && bwrap_args="$bwrap_args --setenv LD_LIBRARY_PATH \"$LD_LIBRARY_PATH\""
    [ -n "${VK_ICD_FILENAMES:-}" ] && bwrap_args="$bwrap_args --setenv VK_ICD_FILENAMES \"$VK_ICD_FILENAMES\""
    [ -n "${DXVK_STATE_CACHE_PATH:-}" ] && bwrap_args="$bwrap_args --setenv DXVK_STATE_CACHE_PATH \"$DXVK_STATE_CACHE_PATH\""
    [ -n "${VKD3D_SHADER_CACHE_PATH:-}" ] && bwrap_args="$bwrap_args --setenv VKD3D_SHADER_CACHE_PATH \"$VKD3D_SHADER_CACHE_PATH\""
    [ -n "${__GL_SHADER_DISK_CACHE:-}" ] && bwrap_args="$bwrap_args --setenv __GL_SHADER_DISK_CACHE \"$__GL_SHADER_DISK_CACHE\""
    [ -n "${__GL_SHADER_DISK_CACHE_SKIP_CLEANUP:-}" ] && bwrap_args="$bwrap_args --setenv __GL_SHADER_DISK_CACHE_SKIP_CLEANUP \"$__GL_SHADER_DISK_CACHE_SKIP_CLEANUP\""
    [ -n "${__GL_SHADER_DISK_CACHE_PATH:-}" ] && bwrap_args="$bwrap_args --setenv __GL_SHADER_DISK_CACHE_PATH \"$__GL_SHADER_DISK_CACHE_PATH\""
    [ -n "${MESA_SHADER_CACHE_DIR:-}" ] && bwrap_args="$bwrap_args --setenv MESA_SHADER_CACHE_DIR \"$MESA_SHADER_CACHE_DIR\""
    [ -n "${MANGOHUD:-}" ] && bwrap_args="$bwrap_args --setenv MANGOHUD \"$MANGOHUD\""
    [ -n "${MANGOHUD_DLSYM:-}" ] && bwrap_args="$bwrap_args --setenv MANGOHUD_DLSYM \"$MANGOHUD_DLSYM\""
    [ -n "${DBUS_SESSION_BUS_ADDRESS:-}" ] && bwrap_args="$bwrap_args --setenv DBUS_SESSION_BUS_ADDRESS \"$DBUS_SESSION_BUS_ADDRESS\""
    
    echo "$bwrap_args"
}

# =============================================================================
# Module: wgp-core.sh
# =============================================================================


################################################################################
# wgp-core.sh - Variables globales et fonctions utilitaires WGP
################################################################################

# Variables globales WGP
WGPACK_FILE=""
WGPACK_NAME=""
FULL_EXE_PATH=""

# =============================================================================
# Initialisation des variables WGP
# =============================================================================

init_wgp_variables() {
    WGPACK_FILE="$(realpath "$fullpath")"
    GAME_INTERNAL_NAME=""

    local GAMENAME_CONTENT
    local UNSQUASHFS_BIN
    UNSQUASHFS_BIN=$(get_system_tool unsquashfs)
    GAMENAME_CONTENT=$("$UNSQUASHFS_BIN" -cat "$WGPACK_FILE" ".gamename" 2>/dev/null)
    if [ -n "$GAMENAME_CONTENT" ]; then
        GAME_INTERNAL_NAME="$GAMENAME_CONTENT"
        GAME_INTERNAL_NAME="${GAME_INTERNAL_NAME%.}"
    fi

    if [ -z "$GAME_INTERNAL_NAME" ]; then
        GAME_INTERNAL_NAME="$(basename "$WGPACK_FILE" .wgp)"
        GAME_INTERNAL_NAME="${GAME_INTERNAL_NAME%.}"
    fi

    WGPACK_NAME="$GAME_INTERNAL_NAME"

    MOUNT_BASE="/tmp/wgpackmount"
    MOUNT_DIR="$MOUNT_BASE/$WGPACK_NAME"
    EXTRA_BASE="/tmp/wgp-extra"
    EXTRA_DIR="$EXTRA_BASE/$WGPACK_NAME"
}

# =============================================================================
# Lecture de la configuration du WGP
# =============================================================================

read_wgp_config() {
    local LAUNCH_FILE="$MOUNT_DIR/.launch"
    if [ ! -f "$LAUNCH_FILE" ]; then
        echo "Erreur: fichier .launch introuvable dans le pack" >&2
        cleanup_wgp
        exit 1
    fi

    local launch_content
    launch_content="$(cat "$LAUNCH_FILE" | tr -d '\n\r')"
    FULL_EXE_PATH="$MOUNT_DIR/$launch_content"

    if [ ! -e "$FULL_EXE_PATH" ]; then
        echo "Erreur: exécutable introuvable: $(cat "$LAUNCH_FILE")" >&2
        cleanup_wgp
        exit 1
    fi

    local ARGS_FILE="$MOUNT_DIR/.args"
    if [ -f "$ARGS_FILE" ]; then
        local wgp_args
        wgp_args=$(cat "$ARGS_FILE")
        if [ -n "$wgp_args" ]; then
            args="$wgp_args"
        fi
    fi

    local FIX_FILE="$MOUNT_DIR/.fix"
    if [ -f "$FIX_FILE" ]; then
        fix_mode=true
    fi
}

# =============================================================================
# Fonctions utilitaires pour la copie avec symlinks
# =============================================================================

_copy_symlink_as_abs() {
    local src_symlink="$1"
    local dst_symlink="$2"
    local src_base_dir="${3:-}"
    local dst_base_dir="${4:-}"

    local target
    target=$(readlink "$src_symlink")
    [ -z "$target" ] && return 1

    local abs_target
    if [[ "$target" == /* ]]; then
        abs_target="$target"
    else
        abs_target=$(realpath -m "$(dirname "$src_symlink")/$target" 2>/dev/null)
    fi

    if [[ "$abs_target" == */.save/* ]]; then
        abs_target=$(echo "$abs_target" | sed 's|/.save/|/|g')
    elif [[ "$abs_target" == */.extra/* ]]; then
        abs_target=$(echo "$abs_target" | sed 's|/.extra/|/|g')
    elif [[ "$abs_target" == */.temp/* ]]; then
        abs_target=$(echo "$abs_target" | sed 's|/.temp/|/|g')
    fi

    if [ -n "$src_base_dir" ] && [ -n "$dst_base_dir" ]; then
        if [[ "$abs_target" == "$src_base_dir"* ]]; then
            local rel_path="${abs_target#$src_base_dir/}"
            abs_target="$dst_base_dir/$rel_path"
        fi
    fi

    if [ -n "$abs_target" ]; then
        ln -s "$abs_target" "$dst_symlink"
    else
        ln -s "$target" "$dst_symlink"
    fi
}

_copy_dir_with_symlinks() {
    local src_dir="$1"
    local dst_dir="$2"
    local src_base_dir="${3:-}"
    local dst_base_dir="${4:-}"

    ensure_dir -s "$dst_dir"

    for item in "$src_dir"/*; do
        [ -e "$item" ] || [ -L "$item" ] || continue
        local name
        name=$(basename "$item")
        local dst_item="$dst_dir/$name"

        if [ -L "$item" ]; then
            _copy_symlink_as_abs "$item" "$dst_item" "$src_base_dir" "$dst_base_dir"
        elif [ -f "$item" ]; then
            cp -n "$item" "$dst_item"
        elif [ -d "$item" ]; then
            _copy_dir_with_symlinks "$item" "$dst_item" "$src_base_dir" "$dst_base_dir"
        fi
    done
}

_copy_dir_rewrite_symlinks() {
    local src_dir="$1"
    local dst_dir="$2"

    ensure_dir -s "$dst_dir"

    for item in "$src_dir"/*; do
        [ -e "$item" ] || [ -L "$item" ] || continue
        local name
        name=$(basename "$item")
        local dst_item="$dst_dir/$name"

        if [ -L "$item" ]; then
            _copy_symlink_rewrite "$item" "$dst_item"
        elif [ -f "$item" ]; then
            cp -n "$item" "$dst_item"
        elif [ -d "$item" ]; then
            _copy_dir_rewrite_symlinks "$item" "$dst_item"
        fi
    done
}

_copy_symlink_rewrite() {
    local src_symlink="$1"
    local dst_symlink="$2"

    local target
    target=$(readlink "$src_symlink")
    local abs_target

    if [[ "$target" == /* ]]; then
        abs_target="$target"
    else
        abs_target=$(realpath -m "$(dirname "$src_symlink")/$target" 2>/dev/null)
    fi

    if [[ -n "$abs_target" ]] && [[ "$abs_target" != "$MOUNT_DIR"* ]]; then
        local game_name="$GAME_INTERNAL_NAME"
        local rewritten_target="$MOUNT_DIR"

        if [[ "$abs_target" == */lgp/"$game_name"/* ]]; then
            local rel_path="${abs_target##*/lgp/$game_name/}"
            rewritten_target="$MOUNT_DIR/$rel_path"
        elif [[ "$abs_target" == */"$game_name"/* ]]; then
            local rel_path="${abs_target##*/$game_name/}"
            rewritten_target="$MOUNT_DIR/$rel_path"
        fi

        if [ -e "$rewritten_target" ]; then
            ln -s "$rewritten_target" "$dst_symlink"
            echo "Symlink réécrit: $dst_symlink -> $rewritten_target"
        else
            local real_target
            real_target=$(realpath "$src_symlink" 2>/dev/null)
            if [ -f "$real_target" ]; then
                cp -n "$real_target" "$dst_symlink"
            fi
        fi
    else
        ln -s "$target" "$dst_symlink"
    fi
}

# =============================================================================
# Module: wgp-symlinks.sh
# =============================================================================


################################################################################
# wgp-symlinks.sh - Gestion des symlinks pour saves, extras et données de jeu
################################################################################

# =============================================================================
# Préparation des sauvegardes
# =============================================================================

prepare_saves() {
    local SAVE_FILE="$MOUNT_DIR/.savepath"
    local SAVE_WGP_DIR="$MOUNT_DIR/.save"
    local SAVES_DIR="$SAVES_REAL/$GAME_INTERNAL_NAME"

    [ -f "$SAVE_FILE" ] || return 0

    if [ -d "$SAVES_DIR" ]; then
        if [ -n "$(find "$SAVES_DIR" -mindepth 1 -maxdepth 1 2>/dev/null)" ]; then
            return 0
        fi
    fi

    echo "Copie des sauvegardes depuis .save..."

    while IFS= read -r SAVE_REL_PATH; do
        [ -z "$SAVE_REL_PATH" ] && continue

        local SAVE_WGP_ITEM="$SAVE_WGP_DIR/$SAVE_REL_PATH"
        local FINAL_SAVE_ITEM="$SAVES_DIR/$SAVE_REL_PATH"

        if [ -d "$SAVE_WGP_ITEM" ]; then
            _copy_dir_with_symlinks "$SAVE_WGP_ITEM" "$FINAL_SAVE_ITEM" "$SAVE_WGP_DIR" "$SAVES_DIR"
        elif [ -e "$SAVE_WGP_ITEM" ]; then
            mkdir -p "$(dirname "$FINAL_SAVE_ITEM")"
            if [ -L "$SAVE_WGP_ITEM" ]; then
                _copy_symlink_as_abs "$SAVE_WGP_ITEM" "$FINAL_SAVE_ITEM" "$SAVE_WGP_DIR" "$SAVES_DIR"
            else
                cp -n "$SAVE_WGP_ITEM" "$FINAL_SAVE_ITEM"
            fi
        fi
    done < "$SAVE_FILE"
}

# =============================================================================
# Préparation des extras
# =============================================================================

prepare_extras() {
    local EXTRAPATH_FILE="$MOUNT_DIR/.extrapath"
    local EXTRA_WGP_DIR="$MOUNT_DIR/.extra"
    local EXTRA_CACHE_DIR="$EXTRA_REAL/$GAME_INTERNAL_NAME"
    local EXTRA_BASE="/tmp/wgp-extra"
    local EXTRA_DIR="$EXTRA_BASE/$GAME_INTERNAL_NAME"

    [ -f "$EXTRAPATH_FILE" ] || return 0

    if [ -d "$EXTRA_DIR" ] && [ ! -L "$EXTRA_DIR" ]; then
        rm -rf "$EXTRA_DIR"
    fi

    if [ -d "$EXTRA_CACHE_DIR" ] && [ -n "$(find "$EXTRA_CACHE_DIR" -mindepth 1 -maxdepth 1 2>/dev/null)" ]; then
        ensure_dir -s "$EXTRA_BASE"
        rm -f "$EXTRA_DIR"
        ln -s "$EXTRA_CACHE_DIR" "$EXTRA_DIR"
        return 0
    fi

    echo "Copie des extras depuis .extra..."

    while IFS= read -r EXTRA_REL_PATH; do
        [ -z "$EXTRA_REL_PATH" ] && continue

        local EXTRA_WGP_ITEM="$EXTRA_WGP_DIR/$EXTRA_REL_PATH"
        local FINAL_EXTRA_ITEM="$EXTRA_CACHE_DIR/$EXTRA_REL_PATH"

        if [ -d "$EXTRA_WGP_ITEM" ]; then
            _copy_dir_with_symlinks "$EXTRA_WGP_ITEM" "$FINAL_EXTRA_ITEM" "$EXTRA_WGP_DIR" "$EXTRA_CACHE_DIR"
        elif [ -e "$EXTRA_WGP_ITEM" ]; then
            mkdir -p "$(dirname "$FINAL_EXTRA_ITEM")"
            if [ -L "$EXTRA_WGP_ITEM" ]; then
                _copy_symlink_as_abs "$EXTRA_WGP_ITEM" "$FINAL_EXTRA_ITEM" "$EXTRA_WGP_DIR" "$EXTRA_CACHE_DIR"
            else
                cp -n "$EXTRA_WGP_ITEM" "$FINAL_EXTRA_ITEM"
            fi
        fi
    done < "$EXTRAPATH_FILE"

    local EXTRA_BASE="/tmp/wgp-extra"
    local EXTRA_DIR="$EXTRA_BASE/$GAME_INTERNAL_NAME"
    ensure_dir -s "$EXTRA_BASE"
    rm -f "$EXTRA_DIR"
    ln -s "$EXTRA_CACHE_DIR" "$EXTRA_DIR"
}

# =============================================================================
# Fonctions utilitaires pour la gestion des symlinks
# =============================================================================

# Vérifie si un fichier de config existe
# Usage: has_config_file <filename>
has_config_file() {
    [ -f "$MOUNT_DIR/$1" ]
}

# Crée un symlink pour un type de données (saves, extras, etc.)
# Usage: setup_game_symlink <type> <real_dir> <symlink_dir>
setup_game_symlink() {
    local type_name="$1"
    local real_dir="$2"
    local symlink_dir="$3"
    local game_dir="$real_dir/$GAME_INTERNAL_NAME"
    local game_symlink="$symlink_dir/$GAME_INTERNAL_NAME"

    ensure_dirs -s "$game_dir" "$symlink_dir"

    if [ -L "$game_symlink" ]; then
        rm -f "$game_symlink"
    fi

    ln -s "$game_dir" "$game_symlink"
    echo "Symlink créé: $game_symlink -> $game_dir"
}

# Nettoie un symlink de jeu
# Usage: cleanup_game_symlink <symlink_dir>
cleanup_game_symlink() {
    local game_symlink="$1/$GAME_INTERNAL_NAME"
    [ -L "$game_symlink" ] && rm -f "$game_symlink"
    return 0
}

# Gère un symlink de jeu (création ou suppression)
# Usage: manage_game_symlink <action> <type>
#   action: "setup" ou "cleanup"
#   type: "saves" ou "extras"
manage_game_symlink() {
    local action="$1"
    local type="$2"
    local real_dir symlink_dir
    
    case "$type" in
        saves)
            [ "$action" = "setup" ] && ! has_config_file ".savepath" && return 0
            real_dir="$SAVES_REAL"
            symlink_dir="$SAVES_SYMLINK"
            ;;
        extras)
            [ "$action" = "setup" ] && ! has_config_file ".extrapath" && return 0
            real_dir="$EXTRA_REAL"
            symlink_dir="$EXTRA_SYMLINK"
            ;;
        *)
            return 1
            ;;
    esac
    
    case "$action" in
        setup)
            setup_game_symlink "$type" "$real_dir" "$symlink_dir"
            ;;
        cleanup)
            cleanup_game_symlink "$symlink_dir"
            ;;
    esac
}

# Wrappers pour compatibilité (déléguent vers manage_game_symlink)
setup_saves_symlink() { manage_game_symlink setup saves; }
cleanup_saves_symlink() { manage_game_symlink cleanup saves; }
setup_extras_symlink() { manage_game_symlink setup extras; }
cleanup_extras_symlink() { manage_game_symlink cleanup extras; }

# =============================================================================
# Module: wgp-overlay.sh
# =============================================================================


################################################################################
# wgp-overlay.sh - Gestion des overlays mergerfs pour fichiers temporaires
################################################################################

# =============================================================================
# Préparation des dossiers temporaires
# =============================================================================

prepare_temps() {
    local TEMPPATH_FILE="$MOUNT_DIR/.temppath"
    
    [ -f "$TEMPPATH_FILE" ] || return 0
    
    if grep -q "^\*$" "$TEMPPATH_FILE" 2>/dev/null; then
        echo "Mode overlay complet détecté (* dans .temppath)"
        prepare_full_overlay
        return 0
    fi
    
    prepare_temp_folders
}

prepare_temp_folders() {
    local TEMPPATH_FILE="$MOUNT_DIR/.temppath"
    local TEMP_WGP_DIR="$MOUNT_DIR/.temp"
    local TEMP_GAME_DIR="$TEMP_REAL/$GAME_INTERNAL_NAME"
    local GAME_ID="${_GAME_TEMP_ID:-wgp-$(echo "$GAME_INTERNAL_NAME" | tr -cd '[:alnum:]-')}"
    local TEMP_UPPER="/tmp/wgp-temp-upper/$GAME_ID"

    if [ ! -d "$TEMP_WGP_DIR" ]; then
        echo "Dossier .temp non trouvé dans le WGP, skip overlay"
        return 0
    fi

    echo "Montage de l'overlay mergerfs pour les dossiers temporaires..."

    if [ ! -d "$TEMP_GAME_DIR" ] || [ ! -d "$TEMP_UPPER" ]; then
        error_exit "Dossiers overlay manquants pour les fichiers temporaires"
    fi

    if [ -n "$(ls -A "$TEMP_GAME_DIR" 2>/dev/null)" ]; then
        echo "Nettoyage du point de montage non vide..."
        rm -rf "$TEMP_GAME_DIR"/* "$TEMP_GAME_DIR"/.* 2>/dev/null || true
    fi

    if mountpoint -q "$TEMP_GAME_DIR" 2>/dev/null; then
        echo "Démontage de l'overlay existant..."
        unmount_fuse_overlay "$TEMP_GAME_DIR"
    fi

    local MERGERFS_BIN
    MERGERFS_BIN=$(get_system_tool mergerfs)

    echo "  lowerdir: $TEMP_WGP_DIR"
    echo "  upperdir: $TEMP_UPPER"
    echo "  mountpoint: $TEMP_GAME_DIR"
    
    if ! "$MERGERFS_BIN" -o defaults,allow_other,use_ino,category.create=mfs \
        "$TEMP_UPPER:$TEMP_WGP_DIR" "$TEMP_GAME_DIR" 2>&1; then
        error_exit "Échec du montage mergerfs pour les fichiers temporaires"
    fi

    export _TEMP_FOLDERS_MOUNT="$TEMP_GAME_DIR"
    export _TEMP_FOLDERS_UPPER="$TEMP_UPPER"

    echo "Overlay mergerfs monté avec succès: $TEMP_GAME_DIR"
}

# =============================================================================
# Overlay complet (mode *)
# =============================================================================

prepare_full_overlay() {
    local GAME_ID="wgp-$(echo "$GAME_INTERNAL_NAME" | tr -cd '[:alnum:]-')"
    local FULL_OVERLAY_BASE="/tmp/wgp-full-overlay"
    local MOUNT_OVERLAY="$FULL_OVERLAY_BASE/$GAME_ID"
    local TEMP_UPPER="$FULL_OVERLAY_BASE-upper/$GAME_ID"
    
    if [ -d "$MOUNT_OVERLAY" ]; then
        echo "Nettoyage de l'overlay précédent..."
        unmount_fuse_overlay "$MOUNT_OVERLAY" -f -l
        rm -rf "$MOUNT_OVERLAY" 2>/dev/null || true
    fi
    
    rm -rf "$TEMP_UPPER" 2>/dev/null || true
    
    ensure_dirs -s "$MOUNT_OVERLAY" "$TEMP_UPPER"
    
    echo "Montage de l'overlay complet avec mergerfs..."
    echo "  lowerdir: $MOUNT_DIR (WGP entier - lecture seule)"
    echo "  upperdir: $TEMP_UPPER (writable)"
    echo "  mountpoint: $MOUNT_OVERLAY"
    
    local MERGERFS_BIN
    MERGERFS_BIN=$(get_system_tool mergerfs)
    
    if ! "$MERGERFS_BIN" -o defaults,allow_other,use_ino,category.create=mfs \
        "$TEMP_UPPER:$MOUNT_DIR" "$MOUNT_OVERLAY" 2>&1; then
        error_exit "Échec du montage mergerfs pour l'overlay complet"
    fi
    
    local REL_EXE="${FULL_EXE_PATH#$MOUNT_DIR/}"
    FULL_EXE_PATH="$MOUNT_OVERLAY/$REL_EXE"
    
    export _FULL_OVERLAY_MOUNT="$MOUNT_OVERLAY"
    export _FULL_OVERLAY_UPPER="$TEMP_UPPER"
    
    echo "Overlay complet monté avec succès: $MOUNT_OVERLAY"
    echo "  Exécutable redirigé: $FULL_EXE_PATH"
}

# =============================================================================
# Nettoyage des overlays temporaires
# =============================================================================

cleanup_temp_symlink() {
    local GAME_ID=""
    
    if [ -n "${_FULL_OVERLAY_MOUNT:-}" ] || [ -n "${_FULL_OVERLAY_UPPER:-}" ]; then
        local MOUNT_OVERLAY="${_FULL_OVERLAY_MOUNT:-}"
        local TEMP_UPPER="${_FULL_OVERLAY_UPPER:-}"
        
        if [ -n "$GAME_INTERNAL_NAME" ] && [ -z "$GAME_ID" ]; then
            GAME_ID="wgp-$(echo "$GAME_INTERNAL_NAME" | tr -cd '[:alnum:]-')"
        fi
        
        if [ -n "$MOUNT_OVERLAY" ]; then
            echo "Nettoyage de l'overlay complet..."
            unmount_fuse_overlay "$MOUNT_OVERLAY" -f -l
            
            if [ -d "$MOUNT_OVERLAY" ]; then
                rm -rf "$MOUNT_OVERLAY" 2>/dev/null || true
            fi
            
            if [ -n "$TEMP_UPPER" ] && [ -d "$TEMP_UPPER" ]; then
                rm -rf "$TEMP_UPPER" 2>/dev/null || true
            fi
        fi
        
        unset _FULL_OVERLAY_MOUNT _FULL_OVERLAY_UPPER
    fi
    
    if [ -n "${_TEMP_FOLDERS_MOUNT:-}" ] || [ -n "${_TEMP_FOLDERS_UPPER:-}" ]; then
        local TEMP_MOUNT="${_TEMP_FOLDERS_MOUNT:-}"
        local TEMP_UPPER="${_TEMP_FOLDERS_UPPER:-}"
        
        if [ -n "$GAME_INTERNAL_NAME" ] && [ -z "$GAME_ID" ]; then
            GAME_ID="wgp-$(echo "$GAME_INTERNAL_NAME" | tr -cd '[:alnum:]-')"
        fi
        
        if [ -n "$TEMP_MOUNT" ]; then
            echo "Nettoyage de l'overlay temp folders..."
            unmount_fuse_overlay "$TEMP_MOUNT" -f -l
            
            if [ -d "$TEMP_MOUNT" ]; then
                rm -rf "$TEMP_MOUNT" 2>/dev/null || true
            fi
            
            if [ -n "$TEMP_UPPER" ] && [ -d "$TEMP_UPPER" ]; then
                rm -rf "$TEMP_UPPER" 2>/dev/null || true
            fi
        fi
        
        unset _TEMP_FOLDERS_MOUNT _TEMP_FOLDERS_UPPER
    fi
    
    if [ -n "$GAME_INTERNAL_NAME" ] && [ -z "$GAME_ID" ]; then
        GAME_ID="wgp-$(echo "$GAME_INTERNAL_NAME" | tr -cd '[:alnum:]-')"
    fi
    
    if [ -n "$GAME_ID" ]; then
        local default_full_mount="/tmp/wgp-full-overlay/$GAME_ID"
        local default_full_upper="/tmp/wgp-full-overlay-upper/$GAME_ID"
        
        if mountpoint -q "$default_full_mount" 2>/dev/null; then
            unmount_fuse_overlay "$default_full_mount" -f
            rm -rf "$default_full_mount" 2>/dev/null || true
            rm -rf "$default_full_upper" 2>/dev/null || true
        fi
        
        local default_temp_mount="/tmp/wgp-temp/$GAME_ID"
        local default_temp_upper="/tmp/wgp-temp-upper/$GAME_ID"
        
        if mountpoint -q "$default_temp_mount" 2>/dev/null; then
            unmount_fuse_overlay "$default_temp_mount" -f
            rm -rf "$default_temp_mount" 2>/dev/null || true
            rm -rf "$default_temp_upper" 2>/dev/null || true
        fi
    fi
}

# =============================================================================
# Préparation des dossiers overlay (appelé avant le montage)
# =============================================================================

setup_temp_symlink() {
    local TEMPPATH_FILE="$MOUNT_DIR/.temppath"
    local GAME_ID="wgp-$(echo "$GAME_INTERNAL_NAME" | tr -cd '[:alnum:]-')"
    
    export _GAME_TEMP_ID="$GAME_ID"

    if [ ! -f "$TEMPPATH_FILE" ]; then
        return 0
    fi
    
    if grep -q "^\*$" "$TEMPPATH_FILE" 2>/dev/null; then
        local FULL_OVERLAY_BASE="/tmp/wgp-full-overlay"
        local MOUNT_OVERLAY="$FULL_OVERLAY_BASE/$GAME_ID"
        local TEMP_UPPER="$FULL_OVERLAY_BASE-upper/$GAME_ID"
        
        if mountpoint -q "$MOUNT_OVERLAY" 2>/dev/null; then
            echo "Démontage de l'overlay existant..."
            unmount_fuse_overlay "$MOUNT_OVERLAY"
            sleep 0.5
        fi
        
        if [ -d "$MOUNT_OVERLAY" ]; then
            rmdir "$MOUNT_OVERLAY" 2>/dev/null || rm -rf "$MOUNT_OVERLAY" 2>/dev/null || true
        fi
        rm -rf "$TEMP_UPPER" 2>/dev/null || true
        
        ensure_dirs -s "$MOUNT_OVERLAY" "$TEMP_UPPER"
        
        chmod 777 "$TEMP_UPPER"
        
        echo "Dossiers overlay préparés pour mergerfs (mode full): $GAME_ID"
    else
        local TEMP_GAME_DIR="$TEMP_REAL/$GAME_INTERNAL_NAME"
        local TEMP_UPPER="/tmp/wgp-temp-upper/$GAME_ID"
        
        if mountpoint -q "$TEMP_GAME_DIR" 2>/dev/null; then
            echo "Démontage de l'overlay temp existant..."
            unmount_fuse_overlay "$TEMP_GAME_DIR"
            sleep 0.5
        fi
        
        if [ -d "$TEMP_GAME_DIR" ]; then
            rm -rf "$TEMP_GAME_DIR"
        fi
        if [ -d "$TEMP_UPPER" ]; then
            rm -rf "$TEMP_UPPER"
        fi
        
        ensure_dirs -s "$TEMP_GAME_DIR" "$TEMP_UPPER"
        
        chmod 777 "$TEMP_UPPER"
        
        echo "Dossiers overlay préparés pour mergerfs (mode temp folders): $GAME_ID"
    fi
}

# =============================================================================
# Module: wgp-mount.sh
# =============================================================================


################################################################################
# wgp-mount.sh - Montage et démontage des packs WGP (squashfuse)
################################################################################

# =============================================================================
# Montage du pack WGP
# =============================================================================

mount_wgp() {
    ensure_dir -s "$MOUNT_BASE"
    
    local LOCK_FILE="/tmp/wgp-lock-$WGPACK_NAME"
    
    if [ -f "$LOCK_FILE" ]; then
        local LOCK_PID
        LOCK_PID=$(cat "$LOCK_FILE" 2>/dev/null | cut -d: -f1)
        if [ -n "$LOCK_PID" ] && kill -0 "$LOCK_PID" 2>/dev/null; then
            local RELAUNCH=false
            local QUESTION="$WGPACK_NAME est déjà lancé.\n\nVoulez-vous arrêter l'instance en cours et relancer le jeu ?"
            
            if command -v kdialog &> /dev/null; then
                kdialog --warningyesno "$QUESTION" --yes-label "Oui, relancer" --no-label "Non, annuler" && RELAUNCH=true
            else
                read -p "$QUESTION (o/N): " -r
                [[ "$REPLY" =~ ^[oOyY]$ ]] && RELAUNCH=true
            fi
            
            if [ "$RELAUNCH" = true ]; then
                echo "Arrêt de l'instance en cours..."
                # Créer un marqueur de relancement pour empêcher le démontage par l'ancienne instance
                local RELAUNCH_MARKER="/tmp/wgp-relaunch-$WGPACK_NAME"
                touch "$RELAUNCH_MARKER"
                # Tuer le processus principal
                kill -9 "$LOCK_PID" 2>/dev/null
                # Tuer tous les processus enfants du groupe de processus
                kill -9 -- -"$LOCK_PID" 2>/dev/null || true
                # Tuer spécifiquement tous les processus bwrap associés à ce WGP
                local mount_escape
                mount_escape=$(printf '%s' "$MOUNT_DIR" | sed 's/[[\.*^$()+?{|\\]/\\&/g')
                pkill -9 -f "bwrap.*$mount_escape" 2>/dev/null || true
                # Tuer tous les processus wine associés à ce préfixe
                pkill -9 -f "wine.*$WINEPREFIX" 2>/dev/null || true
                # Attendre que tous les processus se terminent
                sleep 1
                # Nettoyer nous-mêmes les montages si nécessaire (l'ancien cleanup ne le fera pas à cause du marqueur)
                unmount_fuse_overlay "$MOUNT_DIR" -f
                local OVERLAY_DIR="/tmp/wgp-full-overlay/wgp-$(echo "$WGPACK_NAME" | tr -cd '[:alnum:]-')"
                unmount_fuse_overlay "$OVERLAY_DIR" -f
                rm -f "$LOCK_FILE"
                # Le marqueur sera supprimé après le montage réussi
            else
                error_exit "$WGPACK_NAME est déjà en cours d'exécution"
            fi
        else
            rm -f "$LOCK_FILE"
        fi
    fi

    if mountpoint -q "$MOUNT_DIR"; then
        echo "Montage orphelin détecté pour $WGPACK_NAME, nettoyage..."
        unmount_fuse_overlay "$MOUNT_DIR" -f
    fi

    local SQUASHFUSE_BIN
    SQUASHFUSE_BIN=$(get_system_tool squashfuse)

    ensure_dir -s "$MOUNT_DIR"
    echo "Montage de $WGPACK_FILE sur $MOUNT_DIR..."
    "$SQUASHFUSE_BIN" -r "$WGPACK_FILE" "$MOUNT_DIR"

    if [ $? -ne 0 ]; then
        rmdir "$MOUNT_DIR"
        error_exit "Erreur lors du montage du squashfs"
    fi
    
    echo "$$:$(date +%s)" > "$LOCK_FILE"
    
    # Supprimer le marqueur de relancement après montage réussi
    rm -f "/tmp/wgp-relaunch-$WGPACK_NAME" 2>/dev/null || true
}

# =============================================================================
# Démontage et nettoyage du pack WGP
# =============================================================================

cleanup_wgp() {
    # Vérifier si un relancement est en cours - si oui, ne pas démonter
    local RELAUNCH_MARKER="/tmp/wgp-relaunch-$WGPACK_NAME"
    if [ -f "$RELAUNCH_MARKER" ]; then
        return 0
    fi
    
    if mountpoint -q "$MOUNT_DIR"; then
        sleep 0.3
        
        local mount_escape
        mount_escape=$(printf '%s' "$MOUNT_DIR" | sed 's/[[\.*^$()+?{|\\]/\\&/g')
        
        # Les processus devraient déjà être terminés à ce point
        # (attente faite dans launch_wine_game)
        sleep 0.5
    fi

    echo "Démontage de $WGPACK_NAME..."

    cleanup_saves_symlink
    cleanup_extras_symlink
    cleanup_temp_symlink
    
    # Nettoyer l'overlay du préfixe isolé si présent
    # Utiliser les variables globales si définies, sinon chercher dans /tmp
    if [ -n "$_ISOLATED_PREFIX_MOUNT" ]; then
        cleanup_isolated_prefix
    else
        # Chercher et nettoyer les overlays vraiment orphelins (pas utilisés par un autre jeu)
        for overlay_dir in /tmp/gwine-prefix-overlay-*; do
            [ -d "$overlay_dir" ] || continue
            if mountpoint -q "$overlay_dir/merged" 2>/dev/null; then
                # Vérifier si l'overlay est encore utilisé (des processus y accèdent)
                local still_used=false
                if command -v fuser &>/dev/null; then
                    # Utiliser fuser pour voir si des processus ont ouvert des fichiers
                    if fuser "$overlay_dir/merged" 2>/dev/null | grep -q '[0-9]'; then
                        still_used=true
                    fi
                fi
                
                if [ "$still_used" = true ]; then
                    echo "Overlay encore utilisé par un autre jeu: $overlay_dir"
                else
                    echo "Nettoyage d'un overlay orphelin: $overlay_dir"
                    unmount_fuse_overlay "$overlay_dir/merged"
                    rm -rf "$overlay_dir" 2>/dev/null || true
                fi
            fi
        done
    fi

    unmount_fuse_overlay "$MOUNT_DIR" -f
    
    if mountpoint -q "$MOUNT_DIR" 2>/dev/null; then
        umount -f "$MOUNT_DIR" 2>/dev/null || umount -f -l "$MOUNT_DIR" 2>/dev/null || true
        sleep 0.2
    fi
    
    if [ -d "$MOUNT_DIR" ]; then
        rm -rf "$MOUNT_DIR" 2>/dev/null || true
    fi
    
    rm -f "/tmp/wgp-lock-$WGPACK_NAME" 2>/dev/null || true
}

# =============================================================================
# Module: wgp-modes.sh
# =============================================================================


################################################################################
# wgp-modes.sh - Modes d'exécution WGP (sélection exécutable, etc.)
################################################################################

# =============================================================================
# Mode interactif de sélection d'exécutable dans un WGP
# =============================================================================

select_exe_from_wgp() {
    echo "Recherche des exécutables dans le pack..."

    local found=0
    local exe_array=()

    while IFS= read -r -d '' exe; do
        exe_array+=("$exe")
        found=$((found + 1))
    done < <(find "$MOUNT_DIR" -type f -iname "*.exe" -print0 | head -z -n 20)

    if [ $found -eq 0 ]; then
        echo "Aucun fichier .exe trouvé dans le pack"
        cleanup_wgp
        exit 1
    fi

    local menu_args=("Choisissez un exécutable à lancer :")

    for exe in "${exe_array[@]}"; do
        local rel_path="${exe#$MOUNT_DIR/}"
        menu_args+=("$rel_path" "$rel_path")
    done

    local EXE_REL_PATH
    if command -v kdialog &> /dev/null; then
        EXE_REL_PATH=$(kdialog --menu "${menu_args[@]}")
    else
        echo ""
        echo "Exécutables disponibles:"
        for i in "${!exe_array[@]}"; do
            local rel_path="${exe_array[$i]#$MOUNT_DIR/}"
            echo "  $((i+1)). $rel_path"
        done
        echo ""
        read -p "Entrez le numéro de l'exécutable: " choice
        if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le ${#exe_array[@]} ]; then
            EXE_REL_PATH="${exe_array[$((choice-1))]#$MOUNT_DIR/}"
        fi
    fi
    
    local exit_status=$?

    if [ $exit_status -ne 0 ] || [ -z "$EXE_REL_PATH" ]; then
        echo "Annulé par l'utilisateur"
        cleanup_wgp
        exit 0
    fi

    FULL_EXE_PATH="$MOUNT_DIR/$EXE_REL_PATH"

    if [ ! -f "$FULL_EXE_PATH" ]; then
        echo "Erreur: exécutable introuvable: $FULL_EXE_PATH"
        cleanup_wgp
        exit 1
    fi

    echo "Exécutable sélectionné: $EXE_REL_PATH"
}

# =============================================================================
# Module: launcher.sh
# =============================================================================


################################################################################
# launcher.sh - Lancement des jeux Wine
################################################################################

load_env_file() {
    local env_file="$1"
    
    [ -f "$env_file" ] || return 0
    
    local env_vars=""
    local line
    
    while IFS= read -r line || [ -n "$line" ]; do
        [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
        line="$(echo "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
        [[ "$line" =~ ^[[:space:]]*$ ]] && continue
        
        if [ -n "$env_vars" ]; then
            env_vars="$env_vars $line"
        else
            env_vars="$line"
        fi
    done < "$env_file"
    
    echo "$env_vars"
}

load_env_files() {
    local mount_dir="$1"
    local exe_dir="$2"
    
    local env_vars=""
    local exe_env="$exe_dir/.env"
    
    if [ -f "$exe_env" ]; then
        env_vars=$(load_env_file "$exe_env")
    fi
    
    echo "$env_vars"
}

launch_wine_game() {
    local exe_path="$1"
    local game_args="${2:-}"
    local display_name="${3:-$(basename "$exe_path")}"
    local env_vars="${4:-}"
    local wgp_mode="${5:-false}"  # true si lancement depuis WGP
    local wgp_file_dir="${6:-}"   # dossier contenant le .wgp (pour mode WGP)
    
    echo "Lancement de $display_name avec Wine (gwine-proton)..."
    
    local real_prefix="$HOME_REAL/Windows/Prefix"
    local effective_prefix="$real_prefix"
    
    # Configurer le préfixe isolé si demandé
    if [ "$isolated_prefix_mode" = "true" ]; then
        effective_prefix=$(setup_isolated_prefix "$real_prefix")
        # Le nettoyage est géré par cleanup_wgp() ou le trap EXIT existant
    fi
    
    export WINEPREFIX="$effective_prefix"
    
    mkdir -p "$WINEPREFIX"
    
    apply_padfix_setting
    
    require_wine
    
    local user_winedlloverrides=""
    if [ -n "$env_vars" ]; then
        user_winedlloverrides=$(echo "$env_vars" | grep -o 'WINEDLLOVERRIDES="[^"]*"' | sed 's/WINEDLLOVERRIDES="\(.*\)"/\1/' || true)
    fi
    
    if [ -n "$env_vars" ]; then
        echo "Variables d'environnement: $env_vars"
        # Export des variables d'environnement
        # Utiliser eval pour interpréter correctement les valeurs avec guillemets
        eval "export $env_vars"
        
        # Capturer WINEDLLOVERRIDES pour combinaison avec les overrides par défaut
        user_winedlloverrides=$(echo "$env_vars" | grep -o 'WINEDLLOVERRIDES="[^"]*"' | sed 's/WINEDLLOVERRIDES="\(.*\)"/\1/' || true)
    fi
    
    if [ "${_NEEDS_WINETRICKS_INIT:-0}" = "1" ]; then
        install_winetricks_components
        install_dxvk_vkd3d
        unset _NEEDS_WINETRICKS_INIT
    fi
    
    setup_windows_directories "$WINEPREFIX"
    
    echo "Exécutable: $exe_path"
    echo "Arguments: $game_args"
    echo "WINEPREFIX: $WINEPREFIX"
    
    export WINE_LARGE_ADDRESS_AWARE=1
    export STAGING_SHARED_MEMORY=1
    export WINEFSYNC=1
    export WINENTSYNC=1
    export PULSE_LATENCY_MSEC=60
    export WINEDEBUG=fixme-all
    
    if [ -n "$user_winedlloverrides" ]; then
        export WINEDLLOVERRIDES="${user_winedlloverrides};winemenubuilder=''"
    else
        export WINEDLLOVERRIDES="winemenubuilder=''"
    fi
    
    export WINEARCH="win64"
    
    setup_gpu_vulkan
    
    local WINE_LIBS="$WINE_DIR/lib:$WINE_DIR/lib32"
    if [ -d "$WINE_DIR/lib/wine/x86_64-unix" ]; then
        WINE_LIBS="$WINE_LIBS:$WINE_DIR/lib/wine/x86_64-unix"
    fi
    if [ -d "$WINE_DIR/lib32/wine/i386-unix" ]; then
        WINE_LIBS="$WINE_LIBS:$WINE_DIR/lib32/wine/i386-unix"
    fi
    export LD_LIBRARY_PATH="$WINE_LIBS:$LD_LIBRARY_PATH"
    
    export DXVK_STATE_CACHE_PATH="$SHADER_CACHE_DIR/dxvk"
    export VKD3D_SHADER_CACHE_PATH="$SHADER_CACHE_DIR/vkd3d"
    export __GL_SHADER_DISK_CACHE=1
    export __GL_SHADER_DISK_CACHE_SKIP_CLEANUP=1
    export __GL_SHADER_DISK_CACHE_PATH="$SHADER_CACHE_DIR/nvidia"
    export MESA_SHADER_CACHE_DIR="$SHADER_CACHE_DIR/mesa"
    
    ensure_dirs -s "$CACHE_DIR" "$COMPONENTS_DIR" "$SHADER_CACHE_DIR" "$DXVK_STATE_CACHE_PATH" "$VKD3D_SHADER_CACHE_PATH" "$__GL_SHADER_DISK_CACHE_PATH" "$MESA_SHADER_CACHE_DIR"
    
    if [ "${MANGOHUD:-1}" != "0" ]; then
        export MANGOHUD_BIN=$(command -v mangohud 2>/dev/null)
    else
        export MANGOHUD_BIN=""
    fi
    # Activer gamemode (lance un processus qui maintient gamemode actif)
    gamemode_start
    
    local exe_dir
    exe_dir="$(dirname "$exe_path")"
    echo "Working directory: $exe_dir"
    cd "$exe_dir" || error_exit "Impossible de changer le répertoire vers $exe_dir"
    
    local CMD="$WINE_BIN"
    
    if [ "$nosandbox_mode" != true ]; then
        if command -v bwrap &>/dev/null; then
            echo "Sandbox activé (bwrap)"
            local bwrap_args
            local bwrap_access_dir=""
            local bwrap_access_mode="rw"
            
            # Déterminer le dossier et le mode d'accès
            if [ "$wgp_mode" = "true" ] && [ -n "$wgp_file_dir" ]; then
                # Mode WGP : accès RO au dossier contenant le .wgp
                bwrap_access_dir="$wgp_file_dir"
                bwrap_access_mode="ro"
            else
                # Mode EXE direct : accès RW au dossier contenant l'exe
                bwrap_access_dir="$(dirname "$exe_path")"
                bwrap_access_mode="rw"
            fi
            
            bwrap_args=$(build_bwrap_args "$bwrap_access_dir" "$bwrap_access_mode")
            CMD="bwrap $bwrap_args -- $CMD"
        else
            echo "Warning: bwrap (bubblewrap) non disponible, sandbox désactivé"
            echo "         Installez bubblewrap pour activer le sandboxing"
        fi
    else
        echo "Sandbox désactivé (--nosandbox)"
    fi
    
    if [ -n "$MANGOHUD_BIN" ]; then
        export MANGOHUD=1
        export MANGOHUD_DLSYM=1
        echo "MangoHud activé (système)"
    fi
    
    # Lancer le jeu (synchrone pour garantir le retour à la fin)
    # Rediriger stdin pour éviter que le jeu ne bloque le terminal
    local exit_code=0
    # Construire la commande complète
    local full_cmd="$CMD"
    if [ -n "$game_args" ]; then
        # Échapper les guillemets dans game_args pour l'eval
        full_cmd="$full_cmd \"$exe_path\" $game_args"
    else
        full_cmd="$full_cmd \"$exe_path\""
    fi
    
    WINEPREFIX="$WINEPREFIX" eval "$full_cmd" </dev/null || exit_code=$?
    
    # Attendre que tous les processus wine/bwrap de ce jeu se terminent
    echo "Attente de la fin du jeu..."
    local game_basename
    game_basename=$(basename "$exe_path" | tr -cd '[:alnum:]')
    local wait_count=0
    local still_running=true
    
    while [ "$still_running" = true ] && [ $wait_count -lt 600 ]; do
        # Compter les processus wine/bwrap associés à ce WINEPREFIX
        local wine_procs
        wine_procs=$(pgrep -f "wine.*$game_basename" 2>/dev/null | wc -l)
        local bwrap_procs
        bwrap_procs=$(pgrep -f "bwrap.*$exe_path" 2>/dev/null | wc -l)
        
        if [ "$wine_procs" = "0" ] && [ "$bwrap_procs" = "0" ]; then
            still_running=false
            echo "Jeu terminé"
        else
            wait_count=$((wait_count + 1))
            if [ $((wait_count % 30)) -eq 0 ]; then
                echo "Jeu toujours en cours (${wine_procs} wine, ${bwrap_procs} bwrap)..."
            fi
            sleep 1
        fi
    done
    
    if [ "$still_running" = true ]; then
        echo "Timeout après 10 minutes, forçage..."
    fi
    
    # Nettoyer l'overlay du préfixe isolé après la fin du jeu
    if [ -n "$_ISOLATED_PREFIX_MOUNT" ]; then
        cleanup_isolated_prefix
    fi
    
    restore_padfix_setting
    
    # Désactiver gamemode (en tuant le processus gamemoded -r)
    gamemode_stop
    
    return $exit_code
}

install_registry_files() {
    local reg_dir="$1"
    local reg_files

    local real_reg_dir
    real_reg_dir="$(realpath "$reg_dir" 2>/dev/null || echo "$reg_dir")"

    reg_files=()
    while IFS= read -r -d '' file; do
        reg_files+=("$file")
    done < <(find "$real_reg_dir" -maxdepth 1 -name '*.reg' -print0 2>/dev/null)

    [ ${#reg_files[@]} -eq 0 ] && return 0

    echo "Installation des fichiers de registre..."
    
    local bottle_c="$WINEPREFIX/drive_c"
    local temp_dir="$bottle_c/windows/temp"
    ensure_dir -s "$temp_dir"
    
    for reg_file in "${reg_files[@]}"; do
        local reg_name
        reg_name=$(basename "$reg_file")
        
        local reg_hash
        reg_hash=$(md5sum "$reg_file" | cut -d' ' -f1)
        
        local dest_file="$temp_dir/${reg_hash}_${reg_name}"
        
        if [ -f "$dest_file" ]; then
            local existing_hash
            existing_hash=$(md5sum "$dest_file" | cut -d' ' -f1)
            if [ "$reg_hash" = "$existing_hash" ]; then
                echo "  - $reg_name (déjà installé)"
                continue
            fi
        fi
        
        echo "  - $reg_name"
        
        cp "$reg_file" "$dest_file"
        
        local win_path="C:\\windows\\temp\\$(basename "$dest_file")"
        
        WINEPREFIX="$WINEPREFIX" "$WINE_BIN" regedit.exe /S "$win_path" 2>/dev/null || true
    done
}

setup_pds_symlink() {
    local exe_dir="$1"
    local PDS_FILE="$exe_dir/.pds"

    [ -f "$PDS_FILE" ] || return 0

    local game_name
    game_name=$(cat "$PDS_FILE" 2>/dev/null)
    [ -n "$game_name" ] || return 0

    echo "Configuration ProgramData pour: $game_name"

    local progdata_saves_dir="$WINDOWS_HOME/$USER/ProgramDataSaves/$game_name"
    local progdata_symlink="$HOME_REAL/Windows/WinDrive/ProgramData/$game_name"

    if [ ! -d "$progdata_saves_dir" ]; then
        mkdir -p "$progdata_saves_dir"
        echo "Dossier créé: $progdata_saves_dir"
    fi

    mkdir -p "$(dirname "$progdata_symlink")"

    if [ -e "$progdata_symlink" ]; then
        if [ -d "$progdata_symlink" ] && [ ! -L "$progdata_symlink" ]; then
            echo "Dossier existant dans ProgramData: $progdata_symlink (pas de modification)"
            return 0
        elif [ -L "$progdata_symlink" ]; then
            local current_target
            current_target=$(readlink "$progdata_symlink")
            if [ "$current_target" = "$progdata_saves_dir" ]; then
                echo "Symlink déjà existant et correct: $progdata_symlink -> $progdata_saves_dir"
                return 0
            else
                echo "Symlink existant mais incorrect, remplacement..."
                rm -f "$progdata_symlink"
            fi
        fi
    fi

    ln -s "$progdata_saves_dir" "$progdata_symlink"
    echo "Symlink créé: $progdata_symlink -> $progdata_saves_dir"
}

transliterate() {
    local input="$1"
    echo "$input" | iconv -f UTF-8 -t ASCII//TRANSLIT | sed 's/[^a-zA-Z0-9_-]/_/g'
}

create_temp_path() {
    local path="$1"
    local temp_base="/tmp/game_launcher_$(date +%s)"
    local new_path="$temp_base"
    local current_path=""
    local IFS='/'

    read -ra segments <<< "$path"
    for segment in "${segments[@]}"; do
        if [ -n "$segment" ]; then
            current_path="$current_path/$segment"
            local clean_segment
            clean_segment=$(transliterate "$segment")
            new_path="$new_path/$clean_segment"
            mkdir -p "$new_path"
        fi
    done

    local real_path
    real_path="$(realpath "$path")"
    for item in "$real_path"/* "$real_path"/.*; do
        [[ "$(basename "$item")" == "." ]] && continue
        [[ "$(basename "$item")" == ".." ]] && continue
        [ -e "$item" ] || [ -L "$item" ] && ln -sf "$item" "$new_path/" 2>/dev/null
    done

    echo "$new_path"
}

cleanup_stale_overlays() {
    local OVERLAY_BASE="/tmp/wgp-full-overlay"
    
    if [ ! -d "$OVERLAY_BASE" ]; then
        return 0
    fi
    
    for mount_dir in "$OVERLAY_BASE"/wgp-*; do
        [ -d "$mount_dir" ] || continue
        
        if ! ls "$mount_dir" >/dev/null 2>&1; then
            echo "Nettoyage d'un montage orphelin: $mount_dir"
            unmount_fuse_overlay "$mount_dir" -f
            rm -rf "$mount_dir" 2>/dev/null || true
        elif mountpoint -q "$mount_dir" 2>/dev/null; then
            local game_name
            game_name=$(basename "$mount_dir" | sed 's/^wgp-//')
            if ! pgrep -f "mergerfs.*$mount_dir" >/dev/null 2>&1 && \
               ! pgrep -f "wine.*$mount_dir" >/dev/null 2>&1; then
                echo "Montage inactif détecté: $mount_dir"
                unmount_fuse_overlay "$mount_dir"
                rm -rf "$mount_dir" 2>/dev/null || true
            fi
        fi
    done
    
    local UPPER_BASE="/tmp/wgp-full-overlay-upper"
    if [ -d "$UPPER_BASE" ]; then
        for upper_dir in "$UPPER_BASE"/wgp-*; do
            [ -d "$upper_dir" ] || continue
            local game_name
            game_name=$(basename "$upper_dir" | sed 's/^wgp-//')
            local mount_point="$OVERLAY_BASE/wgp-$game_name"
            if [ ! -d "$mount_point" ] || ! mountpoint -q "$mount_point" 2>/dev/null; then
                rm -rf "$upper_dir" 2>/dev/null || true
            fi
        done
    fi
}

# =============================================================================
# Module: mode-init.sh
# =============================================================================


################################################################################
# mode-init.sh - Mode --init : Initialisation du préfixe Wine
################################################################################

# =============================================================================
# Mode --init : Initialisation complète du préfixe
# =============================================================================

init_prefix_only() {
    echo "Initialisation du préfixe Wine..."
    
    # Vérifier le mode offline
    if [ "$OFFLINE_MODE" = "true" ]; then
        echo "Mode offline activé"
        if ! check_wincomponents_cache; then
            echo ""
            echo "Erreur: Mode offline impossible - certains composants sont manquants dans le cache"
            echo "Lancez 'gwine --init' sans l'option --offline pour télécharger les composants manquants"
            exit 1
        fi
        echo "✓ Tous les composants sont présents dans le cache"
    fi
    
    export WINEPREFIX="$HOME_REAL/Windows/Prefix"
    export WINEARCH="win64"
    
    # Nombre total d'étapes pour la barre de progression
    local TOTAL_STEPS=11
    local CURRENT_STEP=0
    local DBUS_REF=""
    
    # Créer la barre de progression si --kdialog est spécifié
    if [ "$_USE_KDIALOG" = "true" ]; then
        DBUS_REF=$(progress_create "Initialisation du préfixe Wine" "$TOTAL_STEPS")
    fi
    
    # Vérifier si gwine-proton est installé
    if [ ! -d "$WINE_DIR" ] || [ ! -f "$WINE_DIR/bin/wine64" ]; then
        ((CURRENT_STEP++))
        progress_update "$DBUS_REF" "$CURRENT_STEP" "Installation de gwine-proton..."
        
        if [ "$OFFLINE_MODE" = "true" ]; then
            # En mode offline, on ne peut pas télécharger gwine-proton
            progress_close "$DBUS_REF"
            error_exit "Mode offline: gwine-proton n'est pas installé. Impossible de continuer."
        fi
        
        # Essayer d'abord d'installer depuis le cache (mode offline)
        if ! install_gwine_proton_from_cache; then
            if [ "$_USE_KDIALOG" = "true" ] && command -v kdialog &>/dev/null; then
                kdialog --passivepopup "Téléchargement de gwine-proton nécessaire..." 5
            fi
            download_gwine_proton "force"
        fi
    fi
    
    require_wine
    
    # Vérifier annulation
    check_progress_cancelled "$DBUS_REF"
    
    # Mettre à jour automatiquement les composants sans interaction
    if [ "$OFFLINE_MODE" != "true" ]; then
        auto_update_components
    fi
    
    # Sauvegarder l'ancien préfixe s'il existe
    if [ -d "$WINEPREFIX" ]; then
        ((CURRENT_STEP++))
        progress_update "$DBUS_REF" "$CURRENT_STEP" "Sauvegarde de l'ancien préfixe..."
        backup_wineprefix || {
            progress_close "$DBUS_REF"
            error_exit "Échec de la sauvegarde du préfixe"
        }
    fi
    
    # Fonction pour restaurer l'ancien préfixe en cas d'erreur/annulation
    restore_backup() {
        restore_wineprefix
    }
    
    # Créer le préfixe avec wineboot INIT
    ((CURRENT_STEP++))
    progress_update "$DBUS_REF" "$CURRENT_STEP" "Création du préfixe Wine..."
    
    if ! wineboot_init_prefix; then
        restore_backup
        progress_close "$DBUS_REF"
        error_exit "Échec de l'initialisation du préfixe (wineboot)"
    fi
    
    # Vérifier annulation
    check_progress_cancelled "$DBUS_REF" --with-backup
    
    # Installer Mono/Gecko APRES création du préfixe
    ((CURRENT_STEP++))
    progress_update "$DBUS_REF" "$CURRENT_STEP" "Installation de Wine Mono et Gecko..."
    
    if ! install_wine_mono_gecko; then
        restore_backup
        progress_close "$DBUS_REF"
        error_exit "Échec de l'installation de Mono/Gecko"
    fi
    
    # Vérifier annulation
    check_progress_cancelled "$DBUS_REF"
    
    # Préparer le cache des composants Windows
    if [ "$OFFLINE_MODE" != "true" ]; then
        ((CURRENT_STEP++))
        progress_update "$DBUS_REF" "$CURRENT_STEP" "Téléchargement des composants Windows..."
        
        if ! prepare_wincomponents_cache; then
            restore_backup
            progress_close "$DBUS_REF"
            error_exit "Échec de la préparation des composants Windows"
        fi
    fi
    
    # Vérifier annulation
    check_progress_cancelled "$DBUS_REF"
    
    # Installer les composants Windows (nouveau système)
    ((CURRENT_STEP++))
    
    if ! install_winetricks_components; then
        restore_backup
        progress_close "$DBUS_REF"
        error_exit "Échec de l'installation des composants Windows"
    fi
    
    # Vérifier annulation
    check_progress_cancelled "$DBUS_REF"
    
    # Installer DXVK et VKD3D-Proton depuis le cache
    ((CURRENT_STEP++))
    progress_update "$DBUS_REF" "$CURRENT_STEP" "Installation de DXVK et VKD3D..."
    
    if ! install_dxvk_vkd3d; then
        restore_backup
        progress_close "$DBUS_REF"
        error_exit "Échec de l'installation de DXVK/VKD3D"
    fi
    
    # Vérifier annulation
    check_progress_cancelled "$DBUS_REF"
    
    # Installer DXVK-NVAPI (NVIDIA) ou FakeNVAPI (non-NVIDIA)
    ((CURRENT_STEP++))
    if is_nvidia_gpu; then
        progress_update "$DBUS_REF" "$CURRENT_STEP" "Installation de DXVK-NVAPI (NVIDIA)..."
        
        # Télécharger si nécessaire
        local latest_nvapi
        latest_nvapi=$(get_latest_dxvk_nvapi_version)
        local current_nvapi=""
        local nvapi_folder
        nvapi_folder=$(find "$DXVK_NVAPI_CACHE_DIR" -maxdepth 1 -type d -name "dxvk-nvapi-*" 2>/dev/null | head -1)
        [ -n "$nvapi_folder" ] && current_nvapi=$(basename "$nvapi_folder" | sed 's/^dxvk-nvapi-v//; s/^dxvk-nvapi-//')
        
        if [ -z "$current_nvapi" ] || { [ -n "$latest_nvapi" ] && compare_versions "$latest_nvapi" "$current_nvapi"; }; then
            download_dxvk_nvapi --no-confirm 2>/dev/null || true
        fi
        
        # Installer dans le préfixe
        install_dxvk_nvapi 2>/dev/null || true
    else
        progress_update "$DBUS_REF" "$CURRENT_STEP" "Installation de FakeNVAPI (non-NVIDIA)..."
        
        # Télécharger si nécessaire
        local latest_fakenvapi
        latest_fakenvapi=$(get_latest_fakenvapi_version)
        local current_fakenvapi=""
        local fakenvapi_folder
        fakenvapi_folder=$(find "$FAKENVAPI_CACHE_DIR" -maxdepth 1 -type d -name "fakenvapi-*" 2>/dev/null | head -1)
        [ -n "$fakenvapi_folder" ] && current_fakenvapi=$(basename "$fakenvapi_folder" | sed 's/^fakenvapi-v//; s/^fakenvapi-//')
        
        if [ -z "$current_fakenvapi" ] || { [ -n "$latest_fakenvapi" ] && compare_versions "$latest_fakenvapi" "$current_fakenvapi"; }; then
            download_fakenvapi --no-confirm 2>/dev/null || true
        fi
        
        # Note: install_fakenvapi est déjà appelé par install_dxvk_vkd3d
    fi
    
    # Vérifier annulation
    check_progress_cancelled "$DBUS_REF"
    
    # Copier la config MangoHud
    ((CURRENT_STEP++))
    progress_update "$DBUS_REF" "$CURRENT_STEP" "Configuration de MangoHud..."
    
    if ! copy_mangohud_config; then
        restore_backup
        progress_close "$DBUS_REF"
        error_exit "Échec de la copie de la config MangoHud"
    fi
    
    # Vérifier annulation
    check_progress_cancelled "$DBUS_REF"
    
    # Configurer la structure des dossiers Windows
    ((CURRENT_STEP++))
    progress_update "$DBUS_REF" "$CURRENT_STEP" "Configuration des dossiers Windows..."
    
    if ! setup_windows_directories "$WINEPREFIX"; then
        restore_backup
        progress_close "$DBUS_REF"
        error_exit "Échec de la configuration des dossiers Windows"
    fi
    
    # Vérifier annulation
    check_progress_cancelled "$DBUS_REF"
    
    # Créer les dossiers de cache pour shaders
    ((CURRENT_STEP++))
    progress_update "$DBUS_REF" "$CURRENT_STEP" "Configuration des caches..."
    ensure_dirs -s "$SHADER_CACHE_DIR/dxvk" "$SHADER_CACHE_DIR/vkd3d" "$SHADER_CACHE_DIR/nvidia" "$SHADER_CACHE_DIR/mesa"
    
    # Vérifier annulation finale
    if progress_is_cancelled "$DBUS_REF"; then
        restore_backup
        progress_close "$DBUS_REF"
        echo "Initialisation annulée par l'utilisateur"
        if [ "$_USE_KDIALOG" = "true" ] && command -v kdialog &>/dev/null; then
            kdialog --title "Initialisation annulée" --msgbox "L'initialisation du préfixe a été annulée.\n\nL'ancien préfixe a été restauré."
        fi
        exit 0
    fi
    
    # Finaliser la barre de progression
    progress_update "$DBUS_REF" "$TOTAL_STEPS" "Finalisation..."
    
    # Succès - supprimer l'ancien préfixe sauvegardé
    if [ -d "$BACKUP_PREFIX" ]; then
        rm -rf "$BACKUP_PREFIX"
    fi
    
    # Fermer la barre de progression
    progress_close "$DBUS_REF"
    
    echo ""
    echo "Préfixe Wine initialisé avec succès !"
    echo ""
    echo "Configuration effectuée :"
    echo "  ✓ Préfixe Wine créé"
    echo "  ✓ Wine Mono et Gecko installés"
    echo "  ✓ Composants Windows (winetricks) installés"
    echo "  ✓ DXVK et VKD3D-Proton configurés"
    echo "  ✓ Configuration MangoHud copiée"
    echo "  ✓ Dossiers Windows configurés"
    echo "  ✓ Caches shaders initialisés"
    echo ""
    echo "Emplacement: $WINEPREFIX"
}

# Gère l'option --init
init_wineprefix() {
    local needs_init=false
    
    if [ "$init_mode" = true ]; then
        echo "Mode --init: réinitialisation du préfixe demandée"
        if [ -d "$WINEPREFIX" ]; then
            echo "Suppression de l'ancien préfixe..."
            rm -rf "$WINEPREFIX"
        fi
        needs_init=true
    elif [ ! -d "$WINEPREFIX" ] || [ ! -f "$WINEPREFIX/system.reg" ]; then
        echo "Préfixe Wine non trouvé, création automatique..."
        needs_init=true
    fi
    
    if [ "$needs_init" = true ]; then
        # Préparer le cache avec les composants
        prepare_local_cache
        
        # Créer le préfixe avec wineboot en désactivant mscoree/mshtml pour éviter les demandes
        echo "Création du préfixe Wine..."
        wineboot_init_prefix
        
        # Installer Mono/Gecko APRES création du préfixe (sans la boîte de dialogue)
        install_wine_mono_gecko
        
        # Marquer qu'on doit installer les composants winetricks et DXVK
        export _NEEDS_WINETRICKS_INIT=1
    fi
    
    # Configurer la structure des dossiers Windows
    if [ -d "$WINEPREFIX" ] && [ -f "$WINEPREFIX/system.reg" ]; then
        setup_windows_directories "$WINEPREFIX"
    fi
}

# Vérifie et crée le préfixe Wine si nécessaire (version simple)
ensure_wineprefix() {
    if [ ! -d "$WINEPREFIX" ] || [ ! -f "$WINEPREFIX/system.reg" ]; then
        echo "Préfixe Wine non trouvé, création automatique..."
        
        # Créer la barre de progression (toujours pour création auto du préfixe)
        local DBUS_REF=""
        if command -v kdialog &>/dev/null && command -v qdbus &>/dev/null; then
            DBUS_REF=$(progress_create "Création du préfixe Wine" 3 "true" "true")
        fi
        
        # Étape 1: Préparation
        progress_update "$DBUS_REF" 1 "Préparation..."
        prepare_local_cache
        
        # Vérifier annulation
        check_progress_cancelled "$DBUS_REF"
        
        # Étape 2: Création du préfixe (sans demandes Mono/Gecko)
        progress_update "$DBUS_REF" 2 "Création du préfixe..."
        wineboot_init_prefix
        
        # Vérifier annulation
        check_progress_cancelled "$DBUS_REF"
        
        # Étape 3: Mono/Gecko
        progress_update "$DBUS_REF" 3 "Installation de Mono et Gecko..."
        install_wine_mono_gecko
        
        # Vérifier annulation
        check_progress_cancelled "$DBUS_REF"
        
        progress_close "$DBUS_REF"
    fi
}

# Crée le préfixe Wine complet avec tous les composants
ensure_wineprefix_full() {
    if [ ! -d "$WINEPREFIX" ] || [ ! -f "$WINEPREFIX/system.reg" ]; then
        echo "Préfixe Wine non trouvé, création automatique..."
        
        # Nombre d'étapes pour la barre de progression (6 si NVIDIA)
        local TOTAL_STEPS=5
        if is_nvidia_gpu; then
            TOTAL_STEPS=6
        fi
        local CURRENT_STEP=0
        local DBUS_REF=""
        
        # Créer la barre de progression (toujours pour création auto du préfixe)
        if command -v kdialog &>/dev/null && command -v qdbus &>/dev/null; then
            DBUS_REF=$(progress_create "Création du préfixe Wine" "$TOTAL_STEPS" "true" "true")
        fi
        
        # Vérifier annulation
        check_progress_cancelled "$DBUS_REF"
        
        # Étape 1: Préparation du cache
        ((CURRENT_STEP++))
        progress_update "$DBUS_REF" "$CURRENT_STEP" "Préparation des composants..."
        prepare_local_cache
        
        # Vérifier annulation
        check_progress_cancelled "$DBUS_REF"
        
        # Étape 2: Création du préfixe (sans demandes Mono/Gecko)
        ((CURRENT_STEP++))
        progress_update "$DBUS_REF" "$CURRENT_STEP" "Création du préfixe..."
        wineboot_init_prefix
        
        # Vérifier annulation
        check_progress_cancelled "$DBUS_REF"
        
        # Étape 3: Mono/Gecko
        ((CURRENT_STEP++))
        progress_update "$DBUS_REF" "$CURRENT_STEP" "Installation de Mono et Gecko..."
        install_wine_mono_gecko
        
        # Vérifier annulation
        check_progress_cancelled "$DBUS_REF"
        
        # Étape 4: Composants winetricks
        ((CURRENT_STEP++))
        progress_update "$DBUS_REF" "$CURRENT_STEP" "Installation des composants Windows..."
        install_winetricks_components
        
        # Vérifier annulation
        check_progress_cancelled "$DBUS_REF"
        
        # Étape 5: DXVK/VKD3D
        ((CURRENT_STEP++))
        progress_update "$DBUS_REF" "$CURRENT_STEP" "Installation de DXVK/VKD3D..."
        install_dxvk_vkd3d
        
        # Vérifier annulation
        check_progress_cancelled "$DBUS_REF"
        
        # Étape 6: DXVK-NVAPI (si NVIDIA)
        if is_nvidia_gpu; then
            ((CURRENT_STEP++))
            progress_update "$DBUS_REF" "$CURRENT_STEP" "Installation de DXVK-NVAPI (NVIDIA)..."
            
            # Télécharger si nécessaire
            local latest_nvapi
            latest_nvapi=$(get_latest_dxvk_nvapi_version)
            local current_nvapi=""
            local nvapi_folder
            nvapi_folder=$(find "$DXVK_NVAPI_CACHE_DIR" -maxdepth 1 -type d -name "dxvk-nvapi-*" 2>/dev/null | head -1)
            [ -n "$nvapi_folder" ] && current_nvapi=$(basename "$nvapi_folder" | sed 's/^dxvk-nvapi-v//; s/^dxvk-nvapi-//')
            
            if [ -z "$current_nvapi" ] || { [ -n "$latest_nvapi" ] && compare_versions "$latest_nvapi" "$current_nvapi"; }; then
                download_dxvk_nvapi --no-confirm 2>/dev/null || true
            fi
            
            # Installer dans le préfixe
            install_dxvk_nvapi 2>/dev/null || true
            
            # Vérifier annulation
            check_progress_cancelled "$DBUS_REF"
        fi
        
        # Fermer la barre de progression
        progress_close "$DBUS_REF"
        
        echo "Préfixe créé avec succès"
    fi
}

# =============================================================================
# Module: mode-update.sh
# =============================================================================


################################################################################
# mode-update.sh - Mode --update : Mise à jour des composants
################################################################################

# =============================================================================
# Mode --update : Mise à jour des composants
# =============================================================================

update_components() {
    echo "Mise à jour des composants..."
    echo ""
    
    # Vérifier la connexion réseau
    if ! curl -s --max-time 5 https://github.com > /dev/null 2>&1; then
        error_exit "Pas de connexion internet - mise à jour impossible"
    fi
    
    local has_updates=false
    local needs_reinstall_dlls=false
    local CURRENT_STEP=0
    local DBUS_REF=""
    
    # Variables pour stocker les mises à jour effectuées
    local updated_gwine=""
    local updated_dxvk=""
    local updated_vkd3d=""
    local updated_dlls=false
    
    # Vérifier gwine-proton
    local latest_gwine
    latest_gwine=$(get_latest_gwine_version)
    local current_gwine
    current_gwine=$(cat "$GWINE_DIR/.version" 2>/dev/null || echo "")
    
    echo "gwine-proton:"
    echo "  Version actuelle: ${current_gwine:-Aucune}"
    echo "  Dernière version: ${latest_gwine:-Inconnue}"
    
    if [ -n "$latest_gwine" ] && [ -n "$current_gwine" ]; then
        if compare_versions "$latest_gwine" "$current_gwine"; then
            has_updates=true
            echo "  → Mise à jour disponible"
        else
            echo "  → Déjà à jour"
        fi
    elif [ -n "$latest_gwine" ]; then
        has_updates=true
        echo "  → Installation nécessaire"
    fi
    
    # Vérifier DXVK/VKD3D
    local latest_dxvk
    latest_dxvk=$(get_latest_dxvk_version)
    local latest_vkd3d
    latest_vkd3d=$(get_latest_vkd3d_version)
    local current_dxvk=""
    local current_vkd3d=""
    
    local dxvk_folder
    dxvk_folder=$(find "$DXVK_CACHE_DIR" -maxdepth 1 -type d -name "dxvk-*" 2>/dev/null | grep -v "gplasync\|nvapi" | head -1)
    [ -n "$dxvk_folder" ] && current_dxvk=$(basename "$dxvk_folder" | sed 's/^dxvk-//')
    
    local vkd3d_folder
    vkd3d_folder=$(find "$VKD3D_CACHE_DIR" -maxdepth 1 -type d -name "vkd3d-proton-*" 2>/dev/null | head -1)
    [ -n "$vkd3d_folder" ] && current_vkd3d=$(basename "$vkd3d_folder" | sed 's/^vkd3d-proton-//')
    
    echo ""
    echo "DXVK:"
    echo "  Version actuelle: ${current_dxvk:-Aucune}"
    echo "  Dernière version: ${latest_dxvk:-Inconnue}"
    
    if [ -n "$latest_dxvk" ]; then
        if [ -z "$current_dxvk" ] || compare_versions "$latest_dxvk" "$current_dxvk"; then
            has_updates=true
            needs_reinstall_dlls=true
            echo "  → Mise à jour disponible"
        else
            echo "  → Déjà à jour"
        fi
    fi
    
    echo ""
    echo "VKD3D-Proton:"
    echo "  Version actuelle: ${current_vkd3d:-Aucune}"
    echo "  Dernière version: ${latest_vkd3d:-Inconnue}"
    
    if [ -n "$latest_vkd3d" ]; then
        if [ -z "$current_vkd3d" ] || compare_versions "$latest_vkd3d" "$current_vkd3d"; then
            has_updates=true
            needs_reinstall_dlls=true
            echo "  → Mise à jour disponible"
        else
            echo "  → Déjà à jour"
        fi
    fi
    
    # Vérifier DXVK-NVAPI (NVIDIA) ou FakeNVAPI (non-NVIDIA)
    local needs_nvapi_update=false
    local needs_fakenvapi_update=false
    local updated_nvapi=""
    local updated_fakenvapi=""
    local latest_nvapi=""
    local latest_fakenvapi=""
    
    if is_nvidia_gpu; then
        echo ""
        echo "DXVK-NVAPI (NVIDIA):"
        latest_nvapi=$(get_latest_dxvk_nvapi_version)
        local current_nvapi=""
        local nvapi_folder
        nvapi_folder=$(find "$DXVK_NVAPI_CACHE_DIR" -maxdepth 1 -type d -name "dxvk-nvapi-*" 2>/dev/null | head -1)
        [ -n "$nvapi_folder" ] && current_nvapi=$(basename "$nvapi_folder" | sed 's/^dxvk-nvapi-v//; s/^dxvk-nvapi-//')
        
        echo "  Version actuelle: ${current_nvapi:-Aucune}"
        echo "  Dernière version: ${latest_nvapi:-Inconnue}"
        
        if [ -n "$latest_nvapi" ]; then
            if [ -z "$current_nvapi" ] || compare_versions "$latest_nvapi" "$current_nvapi"; then
                has_updates=true
                needs_nvapi_update=true
                echo "  → Mise à jour disponible"
            else
                echo "  → Déjà à jour"
            fi
        fi
    else
        echo ""
        echo "FakeNVAPI (non-NVIDIA):"
        latest_fakenvapi=$(get_latest_fakenvapi_version)
        local current_fakenvapi=""
        local fakenvapi_folder
        fakenvapi_folder=$(find "$FAKENVAPI_CACHE_DIR" -maxdepth 1 -type d -name "fakenvapi-*" 2>/dev/null | head -1)
        [ -n "$fakenvapi_folder" ] && current_fakenvapi=$(basename "$fakenvapi_folder" | sed 's/^fakenvapi-v//; s/^fakenvapi-//')
        
        echo "  Version actuelle: ${current_fakenvapi:-Aucune}"
        echo "  Dernière version: ${latest_fakenvapi:-Inconnue}"
        
        if [ -n "$latest_fakenvapi" ]; then
            if [ -z "$current_fakenvapi" ] || compare_versions "$latest_fakenvapi" "$current_fakenvapi"; then
                has_updates=true
                needs_fakenvapi_update=true
                echo "  → Mise à jour disponible"
            else
                echo "  → Déjà à jour"
            fi
        fi
    fi
    
    echo ""
    
    # Si pas de mises à jour disponibles
    if [ "$has_updates" = false ]; then
        echo "Tous les composants sont déjà à jour !"
        echo ""
        echo "Versions installées :"
        echo "  - gwine-proton: ${current_gwine:-Inconnue}"
        echo "  - DXVK: ${current_dxvk:-Inconnue}"
        echo "  - VKD3D-Proton: ${current_vkd3d:-Inconnue}"
        if is_nvidia_gpu; then
            echo "  - DXVK-NVAPI: ${current_nvapi:-Inconnue}"
        else
            echo "  - FakeNVAPI: ${current_fakenvapi:-Inconnue}"
        fi
        echo ""
        exit 0
    fi
    
    # Compter le nombre total d'étapes
    local TOTAL_STEPS=0
    [ -n "$latest_gwine" ] && ((TOTAL_STEPS++))
    [ -n "$latest_dxvk" ] || [ -n "$latest_vkd3d" ] && ((TOTAL_STEPS++))
    [ "$needs_nvapi_update" = true ] && ((TOTAL_STEPS++))
    [ "$needs_fakenvapi_update" = true ] && ((TOTAL_STEPS++))
    [ "$needs_reinstall_dlls" = true ] && ((TOTAL_STEPS++))
    
    # Créer la barre de progression (sans bouton Annuler pour --update, uniquement avec --kdialog)
    if [ "$_USE_KDIALOG" = "true" ] && [ $TOTAL_STEPS -gt 0 ] && command -v kdialog &>/dev/null && command -v qdbus &>/dev/null; then
        DBUS_REF=$(progress_create "Mise à jour des composants" "$TOTAL_STEPS" "false")
    fi
    
    # Effectuer les mises à jour
    echo "Installation des mises à jour..."
    
    # Mettre à jour gwine-proton
    if [ -n "$latest_gwine" ]; then
        if [ -z "$current_gwine" ] || compare_versions "$latest_gwine" "$current_gwine"; then
            ((CURRENT_STEP++))
            progress_update "$DBUS_REF" "$CURRENT_STEP" "Téléchargement de gwine-proton..."
            
            if progress_is_cancelled "$DBUS_REF"; then
                progress_close "$DBUS_REF"
                echo "Mise à jour annulée par l'utilisateur"
                exit 0
            fi
            
            if ! download_gwine_proton; then
                progress_close "$DBUS_REF"
                error_exit "Échec de la mise à jour de gwine-proton"
            fi
            
            # Marquer comme mis à jour
            updated_gwine="$latest_gwine"
            
            # Vérifier annulation après téléchargement
            if progress_is_cancelled "$DBUS_REF"; then
                progress_close "$DBUS_REF"
                echo "Mise à jour annulée par l'utilisateur"
                exit 0
            fi
        fi
    fi
    
    # Mettre à jour DXVK/VKD3D
    if [ -n "$latest_dxvk" ] || [ -n "$latest_vkd3d" ]; then
        ((CURRENT_STEP++))
        progress_update "$DBUS_REF" "$CURRENT_STEP" "Téléchargement de DXVK/VKD3D-Proton..."
        
        if progress_is_cancelled "$DBUS_REF"; then
            progress_close "$DBUS_REF"
            echo "Mise à jour annulée par l'utilisateur"
            exit 0
        fi
        
        if ! download_updated_dxvk_vkd3d --no-confirm; then
            progress_close "$DBUS_REF"
            error_exit "Échec de la mise à jour de DXVK/VKD3D"
        fi
        
        # Marquer comme mis à jour
        [ -n "$latest_dxvk" ] && updated_dxvk="$latest_dxvk"
        [ -n "$latest_vkd3d" ] && updated_vkd3d="$latest_vkd3d"
        
        # Vérifier annulation après téléchargement
        if progress_is_cancelled "$DBUS_REF"; then
            progress_close "$DBUS_REF"
            echo "Mise à jour annulée par l'utilisateur"
            exit 0
        fi
    fi
    
    # Mettre à jour DXVK-NVAPI si nécessaire (NVIDIA)
    if [ "$needs_nvapi_update" = true ]; then
        ((CURRENT_STEP++))
        progress_update "$DBUS_REF" "$CURRENT_STEP" "Téléchargement de DXVK-NVAPI..."
        
        if progress_is_cancelled "$DBUS_REF"; then
            progress_close "$DBUS_REF"
            echo "Mise à jour annulée par l'utilisateur"
            exit 0
        fi
        
        if ! download_dxvk_nvapi --no-confirm; then
            progress_close "$DBUS_REF"
            echo "Warning: Échec de la mise à jour de DXVK-NVAPI"
        else
            updated_nvapi="$latest_nvapi"
        fi
        
        # Vérifier annulation après téléchargement
        if progress_is_cancelled "$DBUS_REF"; then
            progress_close "$DBUS_REF"
            echo "Mise à jour annulée par l'utilisateur"
            exit 0
        fi
    fi
    
    # Mettre à jour FakeNVAPI si nécessaire (non-NVIDIA)
    if [ "$needs_fakenvapi_update" = true ]; then
        ((CURRENT_STEP++))
        progress_update "$DBUS_REF" "$CURRENT_STEP" "Téléchargement de FakeNVAPI..."
        
        if progress_is_cancelled "$DBUS_REF"; then
            progress_close "$DBUS_REF"
            echo "Mise à jour annulée par l'utilisateur"
            exit 0
        fi
        
        if ! download_fakenvapi --no-confirm; then
            progress_close "$DBUS_REF"
            echo "Warning: Échec de la mise à jour de FakeNVAPI"
        else
            updated_fakenvapi="$latest_fakenvapi"
        fi
        
        # Vérifier annulation après téléchargement
        if progress_is_cancelled "$DBUS_REF"; then
            progress_close "$DBUS_REF"
            echo "Mise à jour annulée par l'utilisateur"
            exit 0
        fi
    fi
    
    # Réinstaller les DLLs dans le préfixe si nécessaire
    if [ "$needs_reinstall_dlls" = true ] && [ -d "$HOME_REAL/Windows/Prefix" ]; then
        ((CURRENT_STEP++))
        progress_update "$DBUS_REF" "$CURRENT_STEP" "Réinstallation des DLLs..."
        
        if progress_is_cancelled "$DBUS_REF"; then
            progress_close "$DBUS_REF"
            echo "Mise à jour annulée par l'utilisateur"
            exit 0
        fi
        
        export WINEPREFIX="$HOME_REAL/Windows/Prefix"
        if ! install_dxvk_vkd3d; then
            progress_close "$DBUS_REF"
            error_exit "Échec de la réinstallation des DLLs"
        fi
        
        updated_dlls=true
    fi
    
    # Finaliser
    progress_update "$DBUS_REF" "$TOTAL_STEPS" "Finalisation..."
    progress_close "$DBUS_REF"
    
    # Afficher le résumé des mises à jour
    echo ""
    echo "Mise à jour terminée avec succès !"
    echo ""
    echo "Résumé des mises à jour effectuées :"
    if [ -n "$updated_gwine" ]; then
        echo "  ✓ gwine-proton mis à jour vers $updated_gwine"
    fi
    if [ -n "$updated_dxvk" ]; then
        echo "  ✓ DXVK mis à jour vers $updated_dxvk"
    fi
    if [ -n "$updated_vkd3d" ]; then
        echo "  ✓ VKD3D-Proton mis à jour vers $updated_vkd3d"
    fi
    if [ -n "$updated_nvapi" ]; then
        echo "  ✓ DXVK-NVAPI mis à jour vers $updated_nvapi"
    fi
    if [ -n "$updated_fakenvapi" ]; then
        echo "  ✓ FakeNVAPI mis à jour vers $updated_fakenvapi"
    fi
    if [ "$updated_dlls" = true ]; then
        echo "  ✓ DLLs réinstallés dans le préfixe Wine"
    fi
    echo ""
}

# =============================================================================
# Module: mode-tools.sh
# =============================================================================


################################################################################
# mode-tools.sh - Outils Wine (regedit, winecfg, winetricks, cmd)
################################################################################

# =============================================================================
# Outils Wine
# =============================================================================

# Lance regedit avec le préfixe Wine
launch_regedit() {
    echo "Lancement de regedit..."
    
    export WINEPREFIX="$HOME_REAL/Windows/Prefix"
    
    require_wine
    
    ensure_wineprefix
    
    echo "WINEPREFIX: $WINEPREFIX"
    WINEPREFIX="$WINEPREFIX" "$WINE_BIN" regedit
    exit $?
}

# Installe un fichier .reg dans le préfixe Wine
install_reg_file() {
    local reg_file_path="$1"
    
    if [ -z "$reg_file_path" ]; then
        error_exit "Aucun fichier .reg spécifié"
    fi
    
    if [ ! -f "$reg_file_path" ]; then
        error_exit "Fichier .reg introuvable: $reg_file_path"
    fi
    
    echo "Installation du fichier de registre: $reg_file_path"
    
    export WINEPREFIX="$HOME_REAL/Windows/Prefix"
    
    require_wine
    
    ensure_wineprefix_full
    
    # Convertir le chemin en chemin Windows
    local win_path
    win_path=$(WINEPREFIX="$WINEPREFIX" "$WINE_BIN" winepath -w "$reg_file_path" 2>/dev/null | tr -d '\r')
    
    if [ -z "$win_path" ]; then
        error_exit "Impossible de convertir le chemin du fichier .reg"
    fi
    
    echo "Chemin Windows: $win_path"
    echo "WINEPREFIX: $WINEPREFIX"
    
    # Installer le fichier .reg
    if ! WINEPREFIX="$WINEPREFIX" "$WINE_BIN" regedit.exe /S "$win_path" 2>/dev/null; then
        # Afficher un message d'erreur avec kdialog si --kdialog est spécifié
        if [ "$_USE_KDIALOG" = "true" ] && command -v kdialog &>/dev/null; then
            kdialog --title "Erreur" --error "Échec de l'installation du fichier de registre:\n$reg_file_path"
        fi
        error_exit "Échec de l'installation du fichier de registre"
    fi
    
    echo "Fichier de registre installé avec succès"
    
    # Afficher un kdialog de confirmation si --kdialog est spécifié
    if [ "$_USE_KDIALOG" = "true" ] && command -v kdialog &>/dev/null; then
        kdialog --title "Succès" --msgbox "Le fichier de registre a été installé avec succès:\n$reg_file_path"
    fi
    
    exit 0
}

# Lance winecfg avec le préfixe Wine
launch_winecfg() {
    echo "Lancement de winecfg..."
    
    export WINEPREFIX="$HOME_REAL/Windows/Prefix"
    
    require_wine
    
    ensure_wineprefix
    
    echo "WINEPREFIX: $WINEPREFIX"
    WINEPREFIX="$WINEPREFIX" "$WINE_BIN" winecfg
    exit $?
}

# Lance cmd.exe (terminal Wine) dans le dossier courant
launch_wine_cmd() {
    echo "Lancement du terminal Wine (cmd)..."
    
    export WINEPREFIX="$HOME_REAL/Windows/Prefix"
    
    require_wine
    
    ensure_wineprefix
    
    # Déterminer le dossier de travail
    local work_dir
    if [ -n "$fullpath" ]; then
        if [ -d "$fullpath" ]; then
            work_dir="$fullpath"
        else
            work_dir="$(dirname "$fullpath")"
        fi
    else
        work_dir="$(pwd)"
    fi
    
    echo "WINEPREFIX: $WINEPREFIX"
    echo "Dossier: $work_dir"
    
    cd "$work_dir" || error_exit "Impossible d'accéder au dossier: $work_dir"
    WINEPREFIX="$WINEPREFIX" "$WINE_BIN" cmd
    exit $?
}

# Lance winetricks avec le préfixe Wine
launch_winetricks() {
    echo "Lancement de winetricks..."
    
    export WINEPREFIX="$HOME_REAL/Windows/Prefix"
    
    ensure_winetricks
    local WINETRICKS_BIN
    WINETRICKS_BIN=$(get_winetricks_bin)
    
    require_wine
    
    ensure_wineprefix_full
    
    export WINE="$WINE_BIN"
    
    local WINETRICKS_CACHE="$COMPONENTS_DIR/winetricks-cache"
    if [ -d "$WINETRICKS_CACHE" ]; then
        export W_CACHE="$WINETRICKS_CACHE"
    fi
    
    echo "WINEPREFIX: $WINEPREFIX"
    if [ -n "$winetricks_args" ]; then
        echo "Commande: winetricks $winetricks_args"
        WINEPREFIX="$WINEPREFIX" "$WINETRICKS_BIN" $winetricks_args
    else
        echo "Aucun argument spécifié, lancement de winetricks en mode interactif..."
        WINEPREFIX="$WINEPREFIX" "$WINETRICKS_BIN"
    fi
    exit $?
}

# =============================================================================
# Module: mode-uninstall.sh
# =============================================================================


################################################################################
# mode-uninstall.sh - Mode --uninstall : Désinstallation de Gwine
################################################################################

# =============================================================================
# Mode --uninstall : Désinstallation
# =============================================================================

uninstall_gwine() {
    local SYMLINK="$HOME/.local/bin/gwine"
    
    echo ""
    echo "========================================"
    echo "   Désinstallation de Gwine"
    echo "========================================"
    echo ""
    echo "Cela va supprimer :"
    echo "  - $GWINE_DIR/"
    echo "  - $SYMLINK"
    echo ""
    echo "⚠️  Vos données dans ~/Windows/ ne seront PAS supprimées."
    echo ""
    
    read -p "Voulez-vous vraiment désinstaller Gwine ? [o/N]: " -r
    echo ""
    
    if [[ "$REPLY" =~ ^[oOyY]$ ]]; then
        echo "Suppression de l'installation..."
        rm -rf "$GWINE_DIR"
        rm -f "$SYMLINK"
        echo ""
        echo "========================================"
        echo "   Gwine a été désinstallé"
        echo "========================================"
        echo ""
        echo "Vos données utilisateur dans ~/Windows/ ont été préservées."
        echo ""
    else
        echo "Désinstallation annulée."
    fi
    
    exit 0
}

# =============================================================================
# Code principal
# =============================================================================


################################################################################
# gwine - Lanceur de jeux Windows avec Wine pur (gwine-proton)
#
# Script standalone pour lancer des jeux Windows via Wine.
# Supporte les paquets WGP (.wgp) et les exécutables directs (.exe)
#
# Gwine: Wine TKG modifié avec Proton
# https://github.com/elgabo86/gwine
################################################################################

# Déterminer le répertoire du script
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Sourcer tous les modules

# =============================================================================
# Fonctions d'analyse des paramètres
# =============================================================================

show_help() {
    echo "Gwine - Lanceur de jeux Windows avec Wine"
    echo ""
    echo "Usage: gwine [OPTION] [CHEMIN]"
    echo ""
    echo "Options:"
    echo "  --help            Afficher cette aide"
    echo "  --init            Initialiser/réinitialiser le préfixe Wine"
    echo "  --offline         Mode offline pour --init (vérifie que les composants sont en cache)"
    echo "  --update          Mettre à jour les composants (DXVK, VKD3D, gwine-proton)"
    echo "  --kdialog         Activer les dialogues graphiques kdialog pour --init et --update"
    echo "  --uninstall       Désinstaller Gwine"
    echo "  --fix             Activer le mode fix manette"
    echo "  --exewgp          Mode interactif pour choisir l'exécutable dans un WGP"
    echo "  --nosandbox       Désactiver le sandboxing"
    echo "  --noprefixoverlay Désactiver l'overlay du préfixe (utilise le préfixe directement)"
    echo "  --regedit         Lancer l'éditeur de registre"
    echo "  --reg fichier.reg Installer un fichier de registre"
    echo "  --winecfg         Lancer la configuration Wine"
    echo "  --winetricks      Lancer winetricks"
    echo "  --download-components  Télécharger tous les composants pour le mode offline"
    echo "  --cachepack       Créer un pack du cache pour installation offline"
    echo "  --cmd             Ouvrir un terminal Wine"
    echo "  --args            Arguments à passer au jeu"
    echo ""
    echo "Exemples:"
    echo "  gwine ~/Jeux/monjeu.wgp"
    echo "  gwine ~/Jeux/monjeu.exe"
    echo "  gwine --init"
    echo "  gwine --fix ~/Jeux/monjeu.wgp"
    echo "  gwine --reg config.reg"
}

# Options valides reconnues par gwine
VALID_OPTIONS=("--help" "-h" "--fix" "--exewgp" "--init" "--offline" "--update" "--kdialog" "--cmd" "--regedit" "--reg" "--winecfg" "--winetricks" "--winetrick" "--download-components" "--cachepack" "--nosandbox" "--noprefixoverlay" "--uninstall" "--args" "--gameid")

# Vérifie si une option est valide
is_valid_option() {
    local opt="$1"
    for valid_opt in "${VALID_OPTIONS[@]}"; do
        if [ "$opt" = "$valid_opt" ]; then
            return 0
        fi
    done
    return 1
}

parse_arguments() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h)
                show_help
                exit 0
                ;;
            --fix)
                fix_mode=true
                shift
                ;;
            --exewgp)
                exewgp_mode=true
                shift
                ;;
            --init)
                init_mode=true
                shift
                ;;
            --offline)
                OFFLINE_MODE=true
                shift
                ;;
            --update)
                update_mode=true
                shift
                ;;
            --kdialog)
                _USE_KDIALOG=true
                shift
                ;;
            --cmd)
                cmd_mode=true
                shift
                ;;
            --regedit)
                regedit_mode=true
                shift
                ;;
            --reg)
                reg_mode=true
                reg_file="$2"
                shift 2
                ;;
            --winecfg)
                winecfg_mode=true
                shift
                ;;
            --winetricks|--winetrick)
                winetricks_mode=true
                shift
                winetricks_args="$*"
                shift $#
                ;;
            --download-components)
                download_wincomponents_mode=true
                shift
                ;;
            --cachepack)
                cachepack_mode=true
                shift
                ;;
            --nosandbox)
                nosandbox_mode=true
                shift
                ;;
            --noprefixoverlay)
                isolated_prefix_mode=false
                shift
                ;;
            --uninstall)
                uninstall_mode=true
                shift
                ;;
            --args)
                args="$2"
                shift 2
                ;;
            --gameid)
                shift 2
                ;;
            *)
                # Vérifier si c'est une option invalide (commence par -- mais n'est pas reconnu)
                if [[ "$1" == --* ]]; then
                    if ! is_valid_option "$1"; then
                        echo "Erreur: Option invalide '$1'" >&2
                        echo "Utilisez --help pour voir les options disponibles" >&2
                        exit 1
                    fi
                fi
                fullpath="$1"
                # Convertir en chemin absolu si c'est un chemin relatif
                if [ -n "$fullpath" ] && [[ "$fullpath" != /* ]]; then
                    fullpath="$(pwd)/$fullpath"
                fi
                shift
                ;;
        esac
    done

    if [ "$init_mode" = true ] && [ -z "$fullpath" ]; then
        init_prefix_only
        exit 0
    fi

    if [ "$regedit_mode" = true ]; then
        return 0
    fi

    if [ "$reg_mode" = true ]; then
        return 0
    fi

    if [ "$winecfg_mode" = true ]; then
        return 0
    fi

    if [ "$winetricks_mode" = true ]; then
        return 0
    fi

    if [ "$cmd_mode" = true ]; then
        return 0
    fi

    if [ "$uninstall_mode" = true ]; then
        return 0
    fi

    if [ "$update_mode" = true ]; then
        update_components
        exit 0
    fi

    if [ "$download_wincomponents_mode" = true ]; then
        prepare_full_offline_cache
        exit $?
    fi

    if [ "$cachepack_mode" = true ]; then
        create_cachepack
        exit $?
    fi

    [ -z "$fullpath" ] && error_exit "Aucun fichier spécifié"
}

# =============================================================================
# Modes de lancement
# =============================================================================

run_wgp_mode() {
    export WINEPREFIX="$HOME_REAL/Windows/Prefix"
    
    init_wgp_variables
    mount_wgp

    init_wineprefix

    setup_saves_symlink
    setup_extras_symlink
    setup_temp_symlink

    prepare_saves
    prepare_extras
    
    if [ "$exewgp_mode" = true ]; then
        select_exe_from_wgp
    else
        read_wgp_config
    fi
    
    prepare_temps

    local exe_dir
    exe_dir="$(dirname "$FULL_EXE_PATH")"
    setup_pds_symlink "$exe_dir"
    
    install_registry_files "$exe_dir"
    if [ -L "$FULL_EXE_PATH" ]; then
        local real_exe_path
        real_exe_path="$(realpath "$FULL_EXE_PATH")"
        local real_exe_dir
        real_exe_dir="$(dirname "$real_exe_path")"
        if [ "$real_exe_dir" != "$exe_dir" ]; then
            install_registry_files "$real_exe_dir"
        fi
    fi
    
    local env_vars
    env_vars=$(load_env_files "$MOUNT_DIR" "$exe_dir")

    local lock_file="/tmp/wgp-lock-$WGPACK_NAME"
    echo "$$:$(date +%s)" > "$lock_file"
    
    # Récupérer le dossier contenant le fichier .wgp
    local wgp_dir
    wgp_dir="$(dirname "$WGPACK_FILE")"
    
    launch_wine_game "$FULL_EXE_PATH" "$args" "$WGPACK_NAME" "$env_vars" "true" "$wgp_dir"
    
    # Nettoyage après la fin du jeu
    cleanup_wgp
    rm -f "$lock_file" 2>/dev/null

    cleanup_saves_symlink
    cleanup_extras_symlink
}

run_classic_mode() {
    export WINEPREFIX="$HOME_REAL/Windows/Prefix"
    
    local dirpath
    local filename

    dirpath=$(dirname "$fullpath")
    filename=$(basename "$fullpath")

    local new_fullpath="$fullpath"
    local temp_base=""

    if echo "$dirpath" | grep -P '[^\x00-\x7F]' > /dev/null; then
        local new_dirpath
        new_dirpath=$(create_temp_path "$dirpath")
        new_fullpath="$new_dirpath/$filename"
        temp_base=$(echo "$new_dirpath" | grep -o "/tmp/game_launcher_[0-9]*")
    fi

    [ -n "$temp_base" ] && trap 'rm -rf "$temp_base"' EXIT
    
    init_wineprefix

    mkdir -p "$WINEPREFIX"
    
    local exe_dir
    exe_dir="$(dirname "$new_fullpath")"
    setup_pds_symlink "$exe_dir"
    
    install_registry_files "$exe_dir"
    if [ -L "$new_fullpath" ]; then
        local real_exe_path
        real_exe_path="$(realpath "$new_fullpath")"
        local real_exe_dir
        real_exe_dir="$(dirname "$real_exe_path")"
        if [ "$real_exe_dir" != "$exe_dir" ]; then
            install_registry_files "$real_exe_dir"
        fi
    fi
    
    local env_vars=""
    local dir_env
    dir_env="$(dirname "$fullpath")/.env"
    if [ -f "$dir_env" ]; then
        env_vars=$(load_env_file "$dir_env")
    fi

    local lock_file="/tmp/wgp-lock-$filename"
    echo "$$:$(date +%s)" > "$lock_file"
    trap 'rm -f "$lock_file"; cleanup_isolated_prefix' EXIT

    launch_wine_game "$new_fullpath" "$args" "$filename" "$env_vars" "false"
}

# =============================================================================
# Point d'entrée principal
# =============================================================================

main() {
    cleanup_stale_overlays
    
    parse_arguments "$@"

    if [ "$uninstall_mode" = true ]; then
        uninstall_gwine
    fi

    if [ "$regedit_mode" = true ]; then
        launch_regedit
    fi

    if [ "$reg_mode" = true ]; then
        install_reg_file "$reg_file"
    fi

    if [ "$winecfg_mode" = true ]; then
        launch_winecfg
    fi

    if [ "$winetricks_mode" = true ]; then
        launch_winetricks
    fi

    if [ "$cmd_mode" = true ]; then
        launch_wine_cmd
    fi

    if [ "$init_mode" = true ]; then
        local SYMLINK="$HOME/.local/bin/gwine"
        if [ ! -L "$SYMLINK" ]; then
            mkdir -p "$HOME/.local/bin"
            ln -sf "$(realpath "$0")" "$SYMLINK"
            echo "Symlink créé: $SYMLINK"
        fi
    fi

    if [[ "$fullpath" == *.wgp ]]; then
        run_wgp_mode
    else
        run_classic_mode
    fi
}

main "$@"
