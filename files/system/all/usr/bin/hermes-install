#!/bin/bash

# Script pour télécharger et installer/mettre à jour l'AppImage Hermes Desktop avec GearLever
# Source : GitHub elgabo86/hermes-desktop releases

# Dépendances : curl, jq, flatpak (GearLever installé comme it.mijorus.gearlever), yes

set -e

REPO="elgabo86/hermes-desktop"
CACHE_DIR="$HOME/.cache/hermes-desktop"
APPIMAGES_DIR="$HOME/AppImages"
mkdir -p "$CACHE_DIR"

# Obtenir les infos de la dernière release via GitHub API
RELEASE_JSON=$(curl -sL "https://api.github.com/repos/$REPO/releases/latest")

# Extraire l'URL de téléchargement pour l'AppImage x86_64 (exclure .zsync)
DOWNLOAD_URL=$(echo "$RELEASE_JSON" | jq -r '.assets[] | select(.name | contains("x86_64.AppImage") and (contains(".zsync") | not)) | .browser_download_url')

if [ -z "$DOWNLOAD_URL" ]; then
    echo "Erreur : AppImage x86_64 non trouvée dans la dernière release."
    exit 1
fi

# Extraire le nom du fichier
ASSET_NAME=$(basename "$DOWNLOAD_URL")

# Chemin du fichier à télécharger
NEW_APPIMAGE_PATH="$CACHE_DIR/$ASSET_NAME"

# Télécharger la nouvelle AppImage
echo "Téléchargement de $ASSET_NAME..."
curl -L -o "$NEW_APPIMAGE_PATH" "$DOWNLOAD_URL"

# Installer avec GearLever sans confirmation
echo "Installation/Mise à jour avec GearLever..."

# Vérifier et supprimer les anciennes versions de Hermes Desktop
if find "$APPIMAGES_DIR" -iname "*hermes*.appimage" | grep -q .; then
    echo "Suppression des anciennes versions pour forcer la mise à jour..."

    for OLD_APPIMAGE in $(find "$APPIMAGES_DIR" -iname "*hermes*.appimage"); do
        echo "Suppression de $OLD_APPIMAGE (peut prendre 30-60 secondes)..."
        echo -n "GearLever en cours de désintégration"

        if timeout 120s bash -c "yes | flatpak run it.mijorus.gearlever --remove '$OLD_APPIMAGE'" 2>/dev/null;
        then
            echo -e "\nAncienne version supprimée avec succès via GearLever."
        else
            echo -e "\nErreur lors de la suppression via GearLever, nettoyage manuel..."
            rm -f "$OLD_APPIMAGE"

            echo "Nettoyage manuel des fichiers desktop et icônes..."
            find "$HOME/.local/share/applications" -iname "*hermes*desktop*.desktop" -delete 2>/dev/null || true
            find "$HOME/.local/share/icons/hicolor" -iname "*hermes*desktop*" -delete 2>/dev/null || true
            find "$HOME/.local/share/icons" -iname "*hermes*desktop*" -delete 2>/dev/null || true

            if command -v update-desktop-database &> /dev/null; then
                update-desktop-database "$HOME/.local/share/applications" 2>/dev/null || true
            fi

            echo "Fichiers supprimés manuellement."
        fi
    done

else
    echo "Aucune ancienne version trouvée, installation directe..."
fi

yes | flatpak run it.mijorus.gearlever --integrate "$NEW_APPIMAGE_PATH" 2>/dev/null || true

# Corriger le .desktop créé par GearLever pour enlever le versionning
DESKTOP_DIR="$HOME/.local/share/applications"
DESKTOP_FILE=$(find "$DESKTOP_DIR" -maxdepth 1 -iname "*hermes*.desktop" | head -n1)
NEW_DESKTOP_FILE="$DESKTOP_DIR/hermes-desktop.desktop"

if [ -f "$DESKTOP_FILE" ]; then
    # Supprimer la version entre parenthèses dans Name=/Name[xx]=
    sed -i 's/^Name\(\[[^]]*\]\)\?=\(Hermes\|hermes\)\( Desktop\|\) (.*)$/Name\1=Hermes/' "$DESKTOP_FILE"
    sed -i 's/^Name\(\[[^]]*\]\)\?=hermes-desktop (.*)$/Name\1=Hermes/' "$DESKTOP_FILE"

    mv "$DESKTOP_FILE" "$NEW_DESKTOP_FILE"
fi

# Nettoyer le cache si le fichier existe encore (GearLever le déplace normalement)
if [ -f "$NEW_APPIMAGE_PATH" ]; then
    rm "$NEW_APPIMAGE_PATH"
fi
rmdir --ignore-fail-on-non-empty "$CACHE_DIR"

# Rafraîchir les fichiers .desktop si la commande est disponible
if command -v kbuildsycoca6 &> /dev/null; then
    kbuildsycoca6
fi

echo "Opération terminée pour Hermes Desktop."
