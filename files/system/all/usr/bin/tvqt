class FlowLayout(QLayout):
    """Layout qui arrange les widgets en lignes, retour à la ligne automatique."""

    def __init__(self, parent=None, margin=0, spacing=4):
        super().__init__(parent)
        self._items = []
        self._hspacing = spacing
        self._vspacing = spacing
        self.setContentsMargins(margin, margin, margin, margin)

    def addItem(self, item):
        self._items.append(item)

    def count(self):
        return len(self._items)

    def itemAt(self, index):
        if 0 <= index < len(self._items):
            return self._items[index]
        return None

    def takeAt(self, index):
        if 0 <= index < len(self._items):
            return self._items.pop(index)
        return None

    def expandingDirections(self):
        return Qt.Orientations(0)

    def hasHeightForWidth(self):
        return True

    def heightForWidth(self, width):
        return self._do_layout(QRect(0, 0, width, 0), True)

    def setGeometry(self, rect):
        super().setGeometry(rect)
        self._do_layout(rect, False)

    def sizeHint(self):
        return QSize(200, self.heightForWidth(200))

    def minimumSize(self):
        return QSize(0, self.heightForWidth(0))

    def _do_layout(self, rect, test_only):
        m = self.contentsMargins()
        available = rect.width() - m.left() - m.right()
        x = m.left()
        y = m.top()
        line_height = 0

        for item in self._items:
            w = item.widget()
            if w and w.property("_full_width"):
                if x > m.left():
                    y += line_height + self._vspacing
                    x = m.left()
                    line_height = 0
                if not test_only:
                    w.setGeometry(QRect(m.left(), y, available, w.sizeHint().height()))
                y += w.sizeHint().height() + self._vspacing
                x = m.left()
                line_height = 0
                continue

            size = item.sizeHint()
            if x + size.width() > m.left() + available and x > m.left():
                x = m.left()
                y += line_height + self._vspacing
                line_height = 0

            if not test_only:
                item.setGeometry(QRect(x, y, size.width(), size.height()))

            x += size.width() + self._hspacing
            line_height = max(line_height, size.height())

        return y + line_height - rect.y() + self._vspacing


class TVLauncher(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("Gablue TV")
        self.setWindowIcon(QIcon.fromTheme("video-display"))
        self.resize(900, 650)
        self._settings = self._load_settings()
        os.makedirs(LOGO_DIR, exist_ok=True)
        self._net = QNetworkAccessManager(self)
        self._net.finished.connect(self._on_logo_downloaded)
        self._logo_buttons = {}
        self._setup_ui()

    def _load_settings(self):
        try:
            os.makedirs(CONFIG_DIR, exist_ok=True)
            with open(CONFIG_FILE) as f:
                return json.load(f)
        except (FileNotFoundError, json.JSONDecodeError):
            return {"fullscreen": False}

    def _save_settings(self):
        os.makedirs(CONFIG_DIR, exist_ok=True)
        with open(CONFIG_FILE, "w") as f:
            json.dump(self._settings, f)

    def _setup_ui(self):
        central = QWidget()
        self.setCentralWidget(central)
        root = QVBoxLayout(central)
        root.setContentsMargins(8, 8, 8, 8)
        root.setSpacing(6)

        self._country_btns = {}
        country_container = QWidget()
        country_container.setSizePolicy(QSizePolicy.Preferred, QSizePolicy.Fixed)
        country_layout = FlowLayout(country_container, margin=0, spacing=3)

        self.cb_fs = QCheckBox("Lancement plein écran")
        self.cb_fs.setChecked(self._settings.get("fullscreen", False))
        self.cb_fs.setStyleSheet("color: #ccc; font-size: 12px; font-weight: bold;")
        self.cb_fs.toggled.connect(lambda v: self._settings.update({"fullscreen": v}) or self._save_settings())

        country_bar = QHBoxLayout()
        country_bar.addWidget(country_container, 1)
        country_bar.addWidget(self.cb_fs)
        root.addLayout(country_bar)

        all_btn = QPushButton("Tous")
        all_btn.setCheckable(True)
        all_btn.setChecked(True)
        all_btn.setFixedHeight(24)
        all_btn.clicked.connect(lambda: self._set_country(None))
        country_layout.addWidget(all_btn)
        self._country_btns[None] = all_btn

        seen = set()
        for _, _, country in CHANNELS:
            if country in seen:
                continue
            seen.add(country)
            flag = country.split()[0]
            btn = QPushButton(flag)
            btn.setCheckable(True)
            btn.setFixedHeight(24)
            btn.setMaximumWidth(60)
            btn.setToolTip(country)
            btn.clicked.connect(lambda checked, c=country: self._set_country(c))
            country_layout.addWidget(btn)
            self._country_btns[country] = btn

        scroll = QScrollArea()
        scroll.setWidgetResizable(True)
        scroll.setFrameShape(QFrame.NoFrame)
        root.addWidget(scroll, 1)

        self._container = QWidget()
        self._flow = FlowLayout(self._container, margin=0, spacing=4)
        scroll.setWidget(self._container)

        self._selected_country = None
        self._build()

    def _set_country(self, country):
        self._selected_country = country
        for c, btn in self._country_btns.items():
            btn.setChecked(c == country)
        self._build()

    def _build(self):
        while self._flow.count():
            item = self._flow.takeAt(0)
            if item.widget():
                item.widget().setParent(None)

        last_country = None

        for ch_id, label, country in CHANNELS:
            if self._selected_country and country != self._selected_country:
                continue

            if country != last_country:
                header = QLabel(country)
                header.setProperty("_full_width", True)
                header.setStyleSheet("""
                    color: #e6b800; font-size: 13px; font-weight: bold;
                    padding: 8px 4px 2px 4px; border-bottom: 1px solid #0f3460;
                """)
                header.setFixedHeight(28)
                self._flow.addWidget(header)
                last_country = country

            btn = QToolButton()
            btn.setText(label)
            btn.setToolButtonStyle(Qt.ToolButtonTextUnderIcon)
            btn.setIconSize(QSize(56, 56))
            btn.setFixedSize(120, 76)
            btn.setCursor(Qt.PointingHandCursor)
            btn.setSizePolicy(QSizePolicy.Fixed, QSizePolicy.Fixed)
            url = f"{BASE}/{ch_id}{SUFFIX}/{ch_id}.m3u8"
            btn.clicked.connect(lambda checked, u=url: self._play(u))
            self._flow.addWidget(btn)
            self._load_logo(ch_id, btn)

    def _load_logo(self, ch_id, btn):
        cache_path = os.path.join(LOGO_DIR, f"{ch_id}.png")
        if os.path.exists(cache_path):
            btn.setIcon(QIcon(cache_path))
            return
        self._logo_buttons[ch_id] = btn
        url = f"{LOGO_BASE}/{ch_id}.png"
        self._net.get(QNetworkRequest(QUrl(url)))

    def _on_logo_downloaded(self, reply):
        url_path = reply.url().path()
        ch_id = os.path.splitext(os.path.basename(url_path))[0]
        err = reply.error()
        if err != QNetworkReply.NetworkError.NoError:
            print(f"[LOGO] Erreur {ch_id}: {reply.errorString()}", file=sys.stderr)
            return
        cache_path = os.path.join(LOGO_DIR, f"{ch_id}.png")
        data = reply.readAll().data()
        print(f"[LOGO] OK {ch_id}: {len(data)} bytes", file=sys.stderr)
        with open(cache_path, "wb") as f:
            f.write(data)
        btn = self._logo_buttons.pop(ch_id, None)
        if btn and not shiboken6.isValid(btn):
            btn = None
        if btn:
            btn.setIcon(QIcon(cache_path))

    def _play(self, url):
        cmd = [MPV_BIN, "--no-terminal", "--profile=fast",
               "--alang=fr,eng,ita,deu,spa,jpn,und", "--slang=fr,eng"]
        if self.cb_fs.isChecked():
            cmd.append("--fs")
        cmd.append(url)
        subprocess.Popen(cmd, start_new_session=True)

    def keyPressEvent(self, event):
        if event.key() == Qt.Key_Escape:
            self.close()
        else:
            super().keyPressEvent(event)


def main():
    app = QApplication(sys.argv)
    app.setApplicationName("Gablue TV")
    app.setStyle("Fusion")
    app.setStyleSheet("""
        QMainWindow { background-color: #1a1a2e; }
        QPushButton, QToolButton { background-color: #16213e; color: #e0e0e0; border: 1px solid #0f3460;
                      border-radius: 6px; font-size: 13px; }
        QPushButton { padding: 4px 10px; }
        QToolButton { padding: 6px 2px 1px 2px; font-size: 11px; }
        QPushButton:hover, QToolButton:hover { background-color: #0f3460; border-color: #e6b800; }
        QPushButton:pressed, QToolButton:pressed { background-color: #0a2350; }
        QPushButton:checked { background-color: #0f3460; border-color: #e6b800; color: #e6b800; }
        QCheckBox { color: #ddd; font-size: 12px; font-weight: bold; }
        QCheckBox::indicator { width: 16px; height: 16px; }
        QScrollArea { background-color: transparent; border: none; }
    """)
    player = TVLauncher()
    player.show()
    sys.exit(app.exec())


if __name__ == "__main__":
    main()
