# =============================================================================
# WIDGET MPV EMBARQUÉ (libmpv + OpenGL)
# =============================================================================

class _MpvOpenGLInitParams(Structure):
    _fields_ = [("get_proc_address", c_void_p), ("get_proc_address_ctx", c_void_p)]


class _MpvOpenGLFBO(Structure):
    _fields_ = [("fbo", c_int), ("w", c_int), ("h", c_int), ("internal_format", c_int)]


class _MpvRenderParam(Structure):
    _fields_ = [("type", c_int), ("data", c_void_p)]


_GetProcAddrFn = CFUNCTYPE(c_void_p, c_void_p, c_char_p)
_UpdateCallbackFn = CFUNCTYPE(None, c_void_p)


class MpvWidget(QOpenGLWidget):
    """Widget vidéo embarquant mpv via libmpv et OpenGL."""

    # Signal émis depuis le thread mpv, reçu dans le thread GUI (QueuedConnection).
    # mpv appelle le callback de mise à jour depuis un thread interne : on ne
    # doit JAMAIS toucher à Qt directement depuis ce thread (deadlock/freeze,
    # visible surtout sous QEMU/virgl où le rendu GL est plus lent).
    _mpv_updated = Signal()

    def __init__(self, parent=None):
        super().__init__(parent)
        self.setUpdateBehavior(QOpenGLWidget.UpdateBehavior.PartialUpdate)
        self._mpv_updated.connect(self.update, Qt.QueuedConnection)

        locale.setlocale(locale.LC_NUMERIC, "C")
        self._lib = ctypes.CDLL(_LIBMPV_PATH)
        self._setup_libmpv_api()

        self._handle = self._lib_mpv_create()
        # Python 3.14 : c_void_p devient int, wrapper explicite requis
        self._handle = c_void_p(self._handle)
        if not self._handle:
            raise RuntimeError("libmpv: mpv_create() failed")

        self._lib_mpv_set_option_string(self._handle, b"vo", b"libmpv")
        self._lib_mpv_set_option_string(self._handle, b"gpu-api", b"opengl")
        # En VM : décodage logiciel (VDPAU/virgl échoue et fige virtio-gpu)
        self._lib_mpv_set_option_string(
            self._handle, b"hwdec", b"no" if _IS_VM else b"auto-safe"
        )
        self._lib_mpv_set_option_string(self._handle, b"profile", b"fast")
        self._lib_mpv_set_option_string(self._handle, b"alang", b"fr,eng,ita,deu,spa,jpn,und")
        self._lib_mpv_set_option_string(self._handle, b"slang", b"fr,eng")
        self._lib_mpv_set_option_string(self._handle, b"keep-open", b"yes")
        self._lib_mpv_set_option_string(self._handle, b"stop-screensaver", b"yes")

        if self._lib_mpv_initialize(self._handle) < 0:
            raise RuntimeError("libmpv: mpv_initialize() failed")

        self._gl_ctx = None
        self._get_proc_addr_cb = _GetProcAddrFn(self._get_proc_address)
        self._update_cb = _UpdateCallbackFn(self._on_mpv_update)
        self._playing = False
        self._right_click_cb = None

    def _setup_libmpv_api(self):
        L = self._lib
        self._lib_mpv_create = L.mpv_create
        self._lib_mpv_create.restype = c_void_p
        self._lib_mpv_initialize = L.mpv_initialize
        self._lib_mpv_initialize.argtypes = [c_void_p]
        self._lib_mpv_initialize.restype = c_int
        self._lib_mpv_set_option_string = L.mpv_set_option_string
        self._lib_mpv_set_option_string.argtypes = [c_void_p, c_char_p, c_char_p]
        self._lib_mpv_set_option_string.restype = c_int
        self._lib_mpv_command_string = L.mpv_command_string
        self._lib_mpv_command_string.argtypes = [c_void_p, c_char_p]
        self._lib_mpv_command_string.restype = c_int
        self._lib_mpv_get_property = L.mpv_get_property
        self._lib_mpv_get_property.restype = c_int
        self._lib_mpv_terminate_destroy = L.mpv_terminate_destroy
        self._lib_mpv_terminate_destroy.argtypes = [c_void_p]
        self._lib_mpv_render_context_create = L.mpv_render_context_create
        self._lib_mpv_render_context_create.restype = c_int
        self._lib_mpv_render_context_set_update_callback = L.mpv_render_context_set_update_callback
        self._lib_mpv_render_context_set_update_callback.argtypes = [c_void_p, _UpdateCallbackFn, c_void_p]
        self._lib_mpv_render_context_render = L.mpv_render_context_render
        self._lib_mpv_render_context_render.restype = c_int
        self._lib_mpv_render_context_free = L.mpv_render_context_free
        self._lib_mpv_render_context_free.argtypes = [c_void_p]

    @staticmethod
    def _get_proc_address(_ctx, name):
        """Callback de résolution des fonctions OpenGL pour libmpv."""
        glctx = QOpenGLContext.currentContext()
        if not glctx:
            return 0
        try:
            fn = name.decode() if isinstance(name, bytes) else str(name)
            addr = glctx.getProcAddress(fn)
            return int(addr) if addr else 0
        except Exception:
            return 0

    def initializeGL(self):
        init_params = _MpvOpenGLInitParams(
            ctypes.cast(self._get_proc_addr_cb, c_void_p),
            c_void_p(0),
        )

        params = (_MpvRenderParam * 4)()
        params[0] = _MpvRenderParam(
            _MPV_RENDER_PARAM_API_TYPE,
            ctypes.cast(ctypes.c_char_p(b"opengl"), c_void_p),
        )
        params[1] = _MpvRenderParam(
            _MPV_RENDER_PARAM_OPENGL_INIT_PARAMS,
            ctypes.cast(ctypes.byref(init_params), c_void_p),
        )
        params[2] = _MpvRenderParam(_MPV_RENDER_PARAM_INVALID, c_void_p(0))

        gl_ctx = c_void_p()
        if self._lib_mpv_render_context_create(
            ctypes.byref(gl_ctx), self._handle, params
        ) < 0:
            raise RuntimeError("libmpv: render_context_create() failed")
        self._gl_ctx = gl_ctx
        self._lib_mpv_render_context_set_update_callback(
            self._gl_ctx, self._update_cb, c_void_p(0)
        )

    def paintGL(self):
        if not self._gl_ctx:
            return
        rect = self.rect()
        fbo_data = _MpvOpenGLFBO(
            self.defaultFramebufferObject(), rect.width(), rect.height(), 0
        )
        flip_y = c_int(1)

        params = (_MpvRenderParam * 3)()
        params[0] = _MpvRenderParam(
            _MPV_RENDER_PARAM_OPENGL_FBO, ctypes.cast(ctypes.byref(fbo_data), c_void_p)
        )
        params[1] = _MpvRenderParam(
            _MPV_RENDER_PARAM_FLIP_Y, ctypes.cast(ctypes.byref(flip_y), c_void_p)
        )
        params[2] = _MpvRenderParam(_MPV_RENDER_PARAM_INVALID, c_void_p(0))

        self._lib_mpv_render_context_render(self._gl_ctx, params)

    def _on_mpv_update(self, _ctx):
        self._mpv_updated.emit()

    def play(self, url):
        self._lib_mpv_command_string(self._handle, f"loadfile {url}".encode())
        self._playing = True

    def is_rendering(self):
        """Retourne True si la vidéo est effectivement en train de jouer."""
        if not self._playing:
            return False
        val = ctypes.c_double()
        fmt = c_int(5)  # MPV_FORMAT_DOUBLE
        ret = self._lib_mpv_get_property(
            self._handle, b"time-pos", fmt, ctypes.byref(val)
        )
        return ret >= 0

    def command(self, *args):
        cmd = " ".join(str(a) for a in args).encode()
        self._lib_mpv_command_string(self._handle, cmd)

    def stop(self):
        if self._gl_ctx:
            self._lib_mpv_render_context_free(self._gl_ctx)
            self._gl_ctx = None
        if self._handle:
            self._lib_mpv_terminate_destroy(self._handle)
            self._handle = None
        self._playing = False

    def mouseDoubleClickEvent(self, event):
        """Double-clic gauche : bascule plein écran sur l'écran contenant le curseur."""
        if event.button() == Qt.LeftButton:
            win = self.window()
            if win.isFullScreen():
                win.showNormal()
            else:
                screen = QApplication.screenAt(QCursor.pos())
                if screen:
                    win.setGeometry(screen.geometry())
                win.showFullScreen()

    def mouseReleaseEvent(self, event):
        """Clic droit : retour au menu."""
        if event.button() == Qt.RightButton:
            if self._right_click_cb:
                self._right_click_cb()
            return
        super().mouseReleaseEvent(event)

    def contextMenuEvent(self, event):
        """Empêche le menu contextuel par défaut."""
        pass

    def closeEvent(self, event):
        self.stop()
        super().closeEvent(event)


# =============================================================================
# FENÊTRE PRINCIPALE
# =============================================================================

class TVWindow(QMainWindow):
    """Interface TV Gablue avec navigation manette complète."""

    def __init__(self):
        super().__init__()
        self.setWindowTitle("Gablue TV")
        self.setWindowIcon(QIcon.fromTheme("video-display"))
        self.resize(1120, 720)
        self.setMinimumSize(540, 400)

        # --- Paramètres persistants ---
        self._settings = self._load_settings()
        os.makedirs(LOGO_DIR, exist_ok=True)

        # --- Réseau (logos) ---
        self._net = QNetworkAccessManager(self)
        self._net.finished.connect(self._on_logo_downloaded)
        self._logo_buttons = {}
        self._fallback_icon = QIcon.fromTheme("video-display")

        # --- Navigation ---
        self._cursor = 0
        self._cols = 5
        self._filtered = []
        self._buttons = []
        self._country_idx = 0
        self._country_pills = []

        # --- MPV embarqué (libmpv + OpenGL) ---
        # (MpvWidget créé dans _setup_ui)
        self._loading_dots = 0
        self._loading_timer = QTimer(self)
        self._loading_timer.setSingleShot(True)
        self._loading_timer.timeout.connect(self._hide_loading)

        # --- Manette ---
        self._gamepad = None
        self._last_scan = 0.0
        self._last_input = 0
        self._last_hat_x = 0
        self._last_hat_y = 0
        self._last_cross = False
        self._last_circle = False
        self._last_l1 = False
        self._last_r1 = False
        self._last_select = False
        self._had_gamepad = False

        # --- État courant du stick/hat (persiste entre les polls) ---
        self._hat_x = 0
        self._hat_y = 0
        self._axis_x = 0.0
        self._axis_y = 0.0

        # --- Accélération navigation (maintien direction) ---
        self._hold_dir = None          # None, 'up', 'down', 'left', 'right'
        self._hold_start = 0.0         # timestamp ms début du maintien
        self._last_repeat = 0.0        # timestamp ms dernière répétition auto

        # --- Inhibition veille écran (portail freedesktop, D-Bus) ---
        self._inhibit_handle = None

        # --- Construction de l'interface ---
        self._setup_ui()
        self._build_country_pills()
        self._filter_channels()
        self._find_gamepad()

        # --- Timers ---
        self._pad_timer = QTimer(self)
        self._pad_timer.timeout.connect(self._poll_gamepad)
        self._pad_timer.start(16)

        self._load_anim = QTimer(self)
        self._load_anim.timeout.connect(self._animate_loading)

    # =========================================================================
    # PERSISTANCE
    # =========================================================================

    def _load_settings(self):
        try:
            os.makedirs(CONFIG_DIR, exist_ok=True)
            with open(CONFIG_FILE) as f:
                return json.load(f)
        except (FileNotFoundError, json.JSONDecodeError):
            return {}

    def _save_settings(self):
        os.makedirs(CONFIG_DIR, exist_ok=True)
        with open(CONFIG_FILE, "w") as f:
            json.dump(self._settings, f)

    # =========================================================================
    # CONSTRUCTION DE L'INTERFACE
    # =========================================================================

    def _setup_ui(self):
        """Construit toute l'arborescence de widgets."""
        central = QWidget()
        self.setCentralWidget(central)
        root = QVBoxLayout(central)
        root.setContentsMargins(0, 0, 0, 0)
        root.setSpacing(0)

        # --- Barre supérieure ---
        self._top_bar = QFrame()
        self._top_bar.setObjectName("topBar")
        self._top_bar.setFixedHeight(54)
        top_layout = QHBoxLayout(self._top_bar)
        top_layout.setContentsMargins(18, 0, 18, 0)
        top_layout.setSpacing(14)

        title = QLabel("GABLUE  TV")
        title.setObjectName("titleLabel")
        top_layout.addWidget(title)

        # Conteneur scrollable des pastilles
        self._pills_scroll = QScrollArea()
        self._pills_scroll.setFixedHeight(44)
        self._pills_scroll.setWidgetResizable(True)
        self._pills_scroll.setHorizontalScrollBarPolicy(Qt.ScrollBarAsNeeded)
        self._pills_scroll.setVerticalScrollBarPolicy(Qt.ScrollBarAlwaysOff)
        self._pills_scroll.setFrameShape(QFrame.NoFrame)
        self._pills_scroll.setStyleSheet("QScrollArea { background: transparent; border: none; }")

        pills_widget = QWidget()
        self._pills_layout = QHBoxLayout(pills_widget)
        self._pills_layout.setContentsMargins(0, 0, 0, 0)
        self._pills_layout.setSpacing(8)
        self._pills_layout.addStretch()
        self._pills_scroll.setWidget(pills_widget)
        top_layout.addWidget(self._pills_scroll, 1)

        self._count_label = QLabel()
        self._count_label.setObjectName("countLabel")
        top_layout.addWidget(self._count_label)

        root.addWidget(self._top_bar)

        # --- Stack : alterne entre grille et vidéo intégrée ---
        self._stack = QStackedWidget()
        self._stack.setStyleSheet("background-color: #080818;")

        # --- Zone de contenu (grille) ---
        self._scroll = QScrollArea()
        self._scroll.setWidgetResizable(True)
        self._scroll.setFrameShape(QFrame.NoFrame)
        self._scroll.setHorizontalScrollBarPolicy(Qt.ScrollBarAlwaysOff)

        self._grid_container = QWidget()
        self._grid = QGridLayout(self._grid_container)
        self._grid.setSpacing(GRID_SPACING)
        self._grid.setContentsMargins(GRID_MARGIN, GRID_MARGIN, GRID_MARGIN, GRID_MARGIN)
        self._grid.setAlignment(Qt.AlignTop | Qt.AlignHCenter)
        self._scroll.setWidget(self._grid_container)

        self._stack.addWidget(self._scroll)  # index 0 : grille

        # --- Widget vidéo intégré (libmpv + OpenGL) ---
        self._video_widget = MpvWidget()
        self._video_widget._right_click_cb = self._stop_video
        self._stack.addWidget(self._video_widget)  # index 1 : vidéo

        root.addWidget(self._stack, 1)

        # --- Barre OSD manette ---
        self._osd_bar = QFrame()
        self._osd_bar.setObjectName("osdBar")
        self._osd_bar.setFixedHeight(30)
        self._osd_bar.hide()
        osd_layout = QHBoxLayout(self._osd_bar)
        osd_layout.setContentsMargins(22, 0, 22, 0)
        self._osd_label = QLabel(
            "[A] Lancer/Pause    [B] Retour    [Select] Plein écran    [L1/R1] Pays    "
            "[D-Pad] Naviguer    [Haut/Bas] Vol.    [Gauche/Droite] Seek"
        )
        self._osd_label.setObjectName("osdLabel")
        osd_layout.addWidget(self._osd_label)
        root.addWidget(self._osd_bar)

        # --- Focus Wayland ---
        self._window_active = True  # suivi fiable via changeEvent

        # --- Overlay de chargement ---
        self._loading_overlay = QWidget(central)
        self._loading_overlay.setObjectName("loadingOverlay")
        self._loading_overlay.hide()
        load_layout = QVBoxLayout(self._loading_overlay)
        load_layout.setAlignment(Qt.AlignCenter)
        load_layout.setSpacing(8)

        self._loading_title = QLabel()
        self._loading_title.setObjectName("loadingTitle")
        self._loading_title.setAlignment(Qt.AlignCenter)
        load_layout.addWidget(self._loading_title)

        self._loading_subtitle = QLabel("Connexion au flux...")
        self._loading_subtitle.setObjectName("loadingSubtitle")
        self._loading_subtitle.setAlignment(Qt.AlignCenter)
        load_layout.addWidget(self._loading_subtitle)

    def _build_country_pills(self):
        """Crée les pastilles de filtrage par pays."""
        # Nettoie tout sauf le stretch final
        while self._pills_layout.count() > 1:
            item = self._pills_layout.takeAt(0)
            if item.widget():
                item.widget().deleteLater()

        self._country_pills = []

        # Pastille "Toutes"
        pill_all = QPushButton("Toutes")
        pill_all.setObjectName("countryPill")
        pill_all.setCursor(Qt.PointingHandCursor)
        pill_all.setFocusPolicy(Qt.NoFocus)
        pill_all.clicked.connect(lambda: self._select_country(0))
        self._pills_layout.insertWidget(0, pill_all)
        self._country_pills.append(pill_all)

        for i, country in enumerate(COUNTRIES_ORDER):
            pill = QPushButton(country)
            pill.setObjectName("countryPill")
            pill.setCursor(Qt.PointingHandCursor)
            pill.setFocusPolicy(Qt.NoFocus)
            idx = i + 1
            pill.clicked.connect(lambda checked, n=idx: self._select_country(n))
            self._pills_layout.insertWidget(self._pills_layout.count() - 1, pill)
            self._country_pills.append(pill)

    def _select_country(self, idx):
        """Change le filtre pays."""
        self._country_idx = idx
        self._filter_channels()

    def _refresh_pills(self):
        """Met à jour le style actif/inactif des pastilles."""
        target_pill = (
            self._country_pills[self._country_idx]
            if self._country_idx < len(self._country_pills)
            else None
        )
        for i, pill in enumerate(self._country_pills):
            active = (i == self._country_idx)
            pill.setProperty("active", active)
            pill.style().unpolish(pill)
            pill.style().polish(pill)
        # Scroll horizontal pour rendre visible la pastille active
        # (l'utilisateur peut aussi scroller manuellement avec la souris)
        if target_pill:
            self._pills_scroll.ensureWidgetVisible(target_pill, 8, 4)

    # =========================================================================
    # GRILLE DE CHAÎNES
    # =========================================================================

    def _filter_channels(self):
        """Applique le filtre pays et reconstruit la grille."""
        if self._country_idx == 0:
            self._filtered = list(enumerate(CHANNELS))
        else:
            country = COUNTRIES_ORDER[self._country_idx - 1]
            self._filtered = [
                (i, ch) for i, ch in enumerate(CHANNELS) if ch[2] == country
            ]

        self._count_label.setText(f"{len(self._filtered)} chaînes")
        self._cursor = 0
        self._rebuild_grid()
        self._refresh_pills()

    def _rebuild_grid(self):
        """Reconstruit la grille de cartes."""
        # Nettoyage
        while self._grid.count():
            item = self._grid.takeAt(0)
            if item.widget():
                item.widget().setParent(None)

        self._buttons = []

        # Calcul du nombre de colonnes
        vw = self._scroll.viewport().width()
        if vw < 100:
            vw = self.width() - 24
        self._cols = max(1, (vw - GRID_MARGIN * 2 + GRID_SPACING) // (CARD_W + GRID_SPACING))

        for idx, (_, (ch_id, label, country)) in enumerate(self._filtered):
            card = self._make_card(ch_id, label, country)
            row = idx // self._cols
            col = idx % self._cols
            self._grid.addWidget(card, row, col, Qt.AlignCenter)
            self._buttons.append(card)
            self._load_logo(ch_id, card)

        # Espaceur en bas
        if self._buttons:
            last_row = (len(self._buttons) - 1) // self._cols
            self._grid.setRowStretch(last_row + 1, 1)

        self._update_card_focus()

    def _make_card(self, ch_id, label, country):
        """Carte chaîne avec icône centrée verticalement et horizontalement."""
        card = QFrame()
        card.setObjectName("channelCard")
        card.setFixedSize(CARD_W, CARD_H)
        card.setCursor(Qt.PointingHandCursor)

        layout = QVBoxLayout(card)
        layout.setContentsMargins(4, 8, 4, 4)
        layout.setSpacing(2)
        layout.setAlignment(Qt.AlignCenter)

        icon_lbl = QLabel()
        icon_lbl.setFixedSize(84, 84)
        icon_lbl.setAlignment(Qt.AlignCenter)
        icon_lbl.setPixmap(self._fallback_icon.pixmap(LOGO_ICON_SIZE))
        layout.addWidget(icon_lbl, 0, Qt.AlignCenter)

        text_lbl = QLabel(label)
        text_lbl.setAlignment(Qt.AlignCenter)
        text_lbl.setWordWrap(True)
        text_lbl.setStyleSheet("color: #c8c8e0; font-size: 12px; font-weight: 600; background: transparent;")
        layout.addWidget(text_lbl, 0, Qt.AlignCenter)

        card.setToolTip(f"{label}\n{country}")

        def on_click(event=None):
            url = f"{BASE}/{ch_id}{SUFFIX}/{ch_id}.m3u8"
            self._play(url, label)

        card.mousePressEvent = lambda e: on_click() if e.button() == Qt.LeftButton else None
        return card

    def _update_card_focus(self):
        """Met à jour visuellement la carte active."""
        for i, btn in enumerate(self._buttons):
            active = (i == self._cursor)
            btn.setProperty("active", active)
            btn.style().unpolish(btn)
            btn.style().polish(btn)

    def _ensure_visible(self):
        """Scrolle pour rendre visible la carte active."""
        if not self._buttons or self._cursor >= len(self._buttons):
            return
        btn = self._buttons[self._cursor]
        self._scroll.ensureWidgetVisible(btn, 80, 80)

    def _scroll_to_top(self):
        """Remonte tout en haut de la grille."""
        sb = self._scroll.verticalScrollBar()
        if sb:
            sb.setValue(0)

    # =========================================================================
    # ACCÉLÉRATION NAVIGATION
    # =========================================================================

    def _accel_delay(self, hold_ms):
        """Délai entre répétitions selon la durée de maintien (ms).

        La navigation accélère progressivement quand on maintient une direction :
        - 0-300ms   : 180ms (délai initial avant 1ère répétition)
        - 300-600ms : 120ms
        - 600ms-1s  : 70ms
        - 1-2s      : 40ms
        - >2s       : 25ms (très rapide)
        """
        if hold_ms < 300:
            return COOLDOWN_MS
        elif hold_ms < 600:
            return 120
        elif hold_ms < 1000:
            return 70
        elif hold_ms < 2000:
            return 40
        else:
            return 25

    def _try_move_cursor(self, direction):
        """Tente de déplacer le curseur dans la direction donnée.

        Retourne True si le curseur a été déplacé avec succès.
        """
        moved = False
        if direction == "up":
            new = self._cursor - self._cols
            if new >= 0:
                self._cursor = new
                moved = True
        elif direction == "down":
            new = self._cursor + self._cols
            if new < len(self._buttons):
                self._cursor = new
                moved = True
        elif direction == "left":
            if self._cursor % self._cols > 0:
                self._cursor -= 1
                moved = True
        elif direction == "right":
            if (self._cursor % self._cols < self._cols - 1
                    and self._cursor + 1 < len(self._buttons)):
                self._cursor += 1
                moved = True
        if moved:
            self._update_card_focus()
            self._ensure_visible()
        return moved

    # =========================================================================
    # LOGOS
    # =========================================================================

    def _load_logo(self, ch_id, card):
        """Charge un logo (cache ou réseau)."""
        cache_path = os.path.join(LOGO_DIR, f"{ch_id}.png")
        if os.path.exists(cache_path):
            self._set_card_icon(card, QPixmap(cache_path))
            return
        self._logo_buttons[ch_id] = card
        url = f"{LOGO_BASE}/{ch_id}.png"
        self._net.get(QNetworkRequest(QUrl(url)))

    def _set_card_icon(self, card, pixmap):
        """Trouve le QLabel icône dans la carte et met le pixmap."""
        layout = card.layout()
        if layout and layout.count() > 0:
            icon_lbl = layout.itemAt(0).widget()
            if isinstance(icon_lbl, QLabel):
                icon_lbl.setPixmap(pixmap.scaled(84, 84, Qt.KeepAspectRatio, Qt.SmoothTransformation))

    def _on_logo_downloaded(self, reply):
        """Callback de téléchargement d'un logo."""
        url_path = reply.url().path()
        ch_id = os.path.splitext(os.path.basename(url_path))[0]
        if reply.error() != QNetworkReply.NetworkError.NoError:
            return
        cache_path = os.path.join(LOGO_DIR, f"{ch_id}.png")
        data = reply.readAll().data()
        try:
            with open(cache_path, "wb") as f:
                f.write(data)
        except OSError:
            return
        card = self._logo_buttons.pop(ch_id, None)
        if card and shiboken6.isValid(card):
            self._set_card_icon(card, QPixmap(cache_path))

    # =========================================================================
    # LECTURE VIDÉO (libmpv embarqué)
    # =========================================================================

    def _play(self, url, label=""):
        """Lance la lecture (conserve la taille de fenêtre actuelle)."""
        self._video_widget.command("stop")
        self._stack.setCurrentIndex(1)
        self._top_bar.hide()
        self._osd_bar.hide()

        self._loading_title.setText(label)
        self._loading_subtitle.setText("Connexion au flux...")
        self._loading_dots = 0
        self._loading_overlay.setGeometry(self.centralWidget().rect())
        self._loading_overlay.raise_()
        self._loading_overlay.show()
        self._load_anim.start(450)

        self._video_widget.play(url)
        self._loading_timer.start(3000)

        # Empêche l'extinction d'écran pendant la lecture (portail freedesktop)
        self._inhibit_screensaver()

    def _hide_loading(self):
        self._loading_overlay.hide()
        self._load_anim.stop()
        self._loading_timer.stop()

    def _pause_toggle(self):
        self._video_widget.command("cycle", "pause")
        if self._inhibit_handle:
            self._uninhibit_screensaver()
        else:
            self._inhibit_screensaver()

    def _stop_video(self):
        """Arrête la lecture et revient à la grille."""
        self._video_widget.command("stop")
        self._stack.setCurrentIndex(0)
        self._top_bar.show()
        self._hide_loading()
        self._uninhibit_screensaver()

    def _inhibit_screensaver(self):
        """Empêche l'extinction d'écran via org.freedesktop.PowerManagement."""
        if self._inhibit_handle is not None:
            return
        msg = QDBusMessage.createMethodCall(
            "org.freedesktop.PowerManagement",
            "/org/freedesktop/PowerManagement/Inhibit",
            "org.freedesktop.PowerManagement.Inhibit",
            "Inhibit",
        )
        msg.setArguments(["Gablue TV", "Lecture en cours"])
        reply = QDBusConnection.sessionBus().call(msg)
        if reply.type() == QDBusMessage.ReplyMessage and reply.arguments():
            self._inhibit_handle = reply.arguments()[0]

    def _uninhibit_screensaver(self):
        """Lève l'inhibition d'écran."""
        if self._inhibit_handle is None:
            return
        msg = QDBusMessage.createMethodCall(
            "org.freedesktop.PowerManagement",
            "/org/freedesktop/PowerManagement/Inhibit",
            "org.freedesktop.PowerManagement.Inhibit",
            "UnInhibit",
        )
        msg.setArguments([self._inhibit_handle])
        QDBusConnection.sessionBus().call(msg)
        self._inhibit_handle = None

    def _toggle_fullscreen(self):
        """Bascule plein écran / fenêtré (à tout moment), forcé sur l'écran du curseur."""
        if self.isFullScreen():
            self.showNormal()
        else:
            screen = QApplication.screenAt(QCursor.pos())
            if screen:
                self.setGeometry(screen.geometry())
            self.showFullScreen()

    def _volume_up(self):
        self._video_widget.command("add", "volume", "5")

    def _volume_down(self):
        self._video_widget.command("add", "volume", "-5")

    def _seek(self, seconds):
        self._video_widget.command("seek", str(seconds))

    # =========================================================================
    # OVERLAY DE CHARGEMENT
    # =========================================================================

    def _animate_loading(self):
        """Animation de chargement + détection du démarrage vidéo."""
        self._loading_dots = (self._loading_dots + 1) % 4
        dots = "." * self._loading_dots
        self._loading_subtitle.setText(f"Connexion au flux{dots}   ")
        if self._video_widget.is_rendering():
            self._hide_loading()

    # =========================================================================
    # MANETTE DE JEU
    # =========================================================================

    def _find_gamepad(self):
        """Détecte une manette connectée."""
        try:
            devices = [evdev.InputDevice(p) for p in evdev.list_devices()]
        except (FileNotFoundError, PermissionError, OSError):
            self._gamepad = None
            self._update_osd()
            return
        for device in devices:
            try:
                caps = device.capabilities()
            except (OSError, IOError):
                continue
            if ecodes.EV_KEY in caps:
                keys = caps[ecodes.EV_KEY]
                if ecodes.BTN_A in keys or ecodes.BTN_SELECT in keys:
                    self._gamepad = device
                    self._update_osd()
                    return
        self._gamepad = None
        self._update_osd()

    def _update_osd(self):
        """Affiche/masque la barre d'aide manette."""
        connected = self._gamepad is not None
        if connected != self._had_gamepad:
            self._had_gamepad = connected
            watching = self._stack.currentIndex() == 1
            self._osd_bar.setVisible(connected and not watching)

    def _poll_gamepad(self):
        """Boucle principale de lecture manette (appelée toutes les ~16ms).

        L'accélération fonctionne même sans nouveaux événements : l'état
        du stick/hat est mémorisé entre les appels.

        La manette est ignorée quand tvqt n'est pas la fenêtre active
        (focus Wayland géré par changeEvent / ActivationChange).
        """
        if not self._window_active:
            return

        if not self._gamepad:
            now_ms = time.time() * 1000
            if now_ms - self._last_scan >= 2000:
                self._last_scan = now_ms
                self._find_gamepad()
            return

        now = time.time() * 1000
        watching = self._stack.currentIndex() == 1

        # Lecture des événements si disponibles
        try:
            r, _, _ = select.select([self._gamepad], [], [], 0)
        except (OSError, IOError):
            self._gamepad = None
            self._update_osd()
            return

        cross_pressed = False
        circle_pressed = False
        l1_pressed = False
        r1_pressed = False
        select_pressed = False
        if self._gamepad in r:
            try:
                for ev in self._gamepad.read():
                    if ev.type == ecodes.EV_ABS:
                        if ev.code == ecodes.ABS_HAT0X:
                            self._hat_x = ev.value
                        elif ev.code == ecodes.ABS_HAT0Y:
                            self._hat_y = ev.value
                        elif ev.code == ecodes.ABS_X:
                            self._axis_x = (ev.value - 128) / 127.0
                        elif ev.code == ecodes.ABS_Y:
                            self._axis_y = (ev.value - 128) / 127.0
                    elif ev.type == ecodes.EV_KEY:
                        if ev.code == BTN_CROSS and ev.value == 1:
                            cross_pressed = True
                        elif ev.code == BTN_CIRCLE and ev.value == 1:
                            circle_pressed = True
                        elif ev.code == BTN_L1 and ev.value == 1:
                            l1_pressed = True
                        elif ev.code == BTN_R1 and ev.value == 1:
                            r1_pressed = True
                        elif ev.code == BTN_SELECT and ev.value == 1:
                            select_pressed = True
            except (OSError, IOError, BlockingIOError):
                self._gamepad = None
                self._update_osd()
                return

        # Utilise les valeurs persistantes (pas de return quand pas d'événements,
        # ce qui permet à l'accélération de continuer pendant le maintien)
        hat_x = self._hat_x
        hat_y = self._hat_y
        axis_x = self._axis_x
        axis_y = self._axis_y

        up = hat_y == -1 or axis_y < -0.5
        down = hat_y == 1 or axis_y > 0.5
        left = hat_x == -1 or axis_x < -0.5
        right = hat_x == 1 or axis_x > 0.5

        # === Direction actuelle ===
        new_dir = None
        if up:
            new_dir = "up"
        elif down:
            new_dir = "down"
        elif left:
            new_dir = "left"
        elif right:
            new_dir = "right"

        # --- Mode grille : accélération progressive au maintien ---
        if not watching:
            if new_dir is None:
                self._hold_dir = None
            elif new_dir == self._hold_dir:
                hold_ms = now - self._hold_start
                if now - self._last_repeat >= self._accel_delay(hold_ms):
                    self._last_repeat = now
                    self._try_move_cursor(new_dir)
            else:
                self._hold_dir = new_dir
                self._hold_start = now
                self._last_repeat = now
                self._try_move_cursor(new_dir)

        # --- Boutons (tir unique, pas d'accélération) ---
        if now - self._last_input >= COOLDOWN_MS:
            if select_pressed and not self._last_select:
                self._last_input = now
                self._toggle_fullscreen()

            elif cross_pressed and not self._last_cross:
                self._last_input = now
                if watching:
                    self._pause_toggle()
                elif self._buttons and self._cursor < len(self._filtered):
                    _, (ch_id, label, _) = self._filtered[self._cursor]
                    self._play(f"{BASE}/{ch_id}{SUFFIX}/{ch_id}.m3u8", label)
                self._hold_dir = None

            elif circle_pressed and not self._last_circle:
                self._last_input = now
                if watching:
                    self._stop_video()
                else:
                    self.close()
                return

            elif l1_pressed and not self._last_l1:
                self._last_input = now
                if not watching:
                    self._country_idx = (self._country_idx - 1) % (len(COUNTRIES_ORDER) + 1)
                    self._select_country(self._country_idx)
                    self._scroll_to_top()
                self._hold_dir = None

            elif r1_pressed and not self._last_r1:
                self._last_input = now
                if not watching:
                    self._country_idx = (self._country_idx + 1) % (len(COUNTRIES_ORDER) + 1)
                    self._select_country(self._country_idx)
                    self._scroll_to_top()
                self._hold_dir = None

            # --- Mode lecture : directions sans accélération ---
            elif watching and new_dir is not None:
                if new_dir == "up" and self._last_hat_y != -1:
                    self._last_input = now
                    self._volume_up()
                elif new_dir == "down" and self._last_hat_y != 1:
                    self._last_input = now
                    self._volume_down()
                elif new_dir == "left" and self._last_hat_x != -1:
                    self._last_input = now
                    self._seek(-10)
                elif new_dir == "right" and self._last_hat_x != 1:
                    self._last_input = now
                    self._seek(10)

        self._last_hat_x = hat_x
        self._last_hat_y = hat_y
        self._last_cross = cross_pressed
        self._last_circle = circle_pressed
        self._last_l1 = l1_pressed
        self._last_r1 = r1_pressed
        self._last_select = select_pressed

    # =========================================================================
    # FOCUS WAYLAND
    # =========================================================================

    def changeEvent(self, event):
        """Suit l'état d'activation de la fenêtre (fiable sous Wayland)."""
        if event.type() == QEvent.ActivationChange:
            self._window_active = self.isActiveWindow()
        super().changeEvent(event)

    # =========================================================================
    # CLAVIER
    # =========================================================================

    def keyPressEvent(self, event):
        """Raccourcis clavier."""
        key = event.key()
        watching = self._stack.currentIndex() == 1

        if key == Qt.Key_Escape:
            if watching:
                self._stop_video()
            else:
                self.close()

        elif key == Qt.Key_F11:
            self._toggle_fullscreen()

        elif key == Qt.Key_Return or key == Qt.Key_Enter:
            if watching:
                self._pause_toggle()
            elif self._buttons and self._cursor < len(self._buttons):
                self._buttons[self._cursor].click()

        elif key == Qt.Key_Space:
            if watching:
                self._pause_toggle()
            elif self._buttons and self._cursor < len(self._buttons):
                self._buttons[self._cursor].click()

        elif key == Qt.Key_Backspace:
            if watching:
                self._stop_video()

        elif key == Qt.Key_Up:
            if watching:
                self._volume_up()
            else:
                new = self._cursor - self._cols
                if new >= 0:
                    self._cursor = new
                    self._update_card_focus()
                    self._ensure_visible()

        elif key == Qt.Key_Down:
            if watching:
                self._volume_down()
            else:
                new = self._cursor + self._cols
                if new < len(self._buttons):
                    self._cursor = new
                    self._update_card_focus()
                    self._ensure_visible()

        elif key == Qt.Key_Left:
            if watching:
                self._seek(-10)
            elif self._cursor % self._cols > 0:
                self._cursor -= 1
                self._update_card_focus()
                self._ensure_visible()

        elif key == Qt.Key_Right:
            if watching:
                self._seek(10)
            elif (self._cursor % self._cols < self._cols - 1
                  and self._cursor + 1 < len(self._buttons)):
                self._cursor += 1
                self._update_card_focus()
                self._ensure_visible()

        elif key == Qt.Key_PageUp:
            self._country_idx = (self._country_idx - 1) % (len(COUNTRIES_ORDER) + 1)
            self._select_country(self._country_idx)

        elif key == Qt.Key_PageDown:
            self._country_idx = (self._country_idx + 1) % (len(COUNTRIES_ORDER) + 1)
            self._select_country(self._country_idx)

        elif key == Qt.Key_Home:
            self._cursor = 0
            self._update_card_focus()
            self._ensure_visible()

        elif key == Qt.Key_End:
            self._cursor = max(0, len(self._buttons) - 1)
            self._update_card_focus()
            self._ensure_visible()

        else:
            super().keyPressEvent(event)

    # =========================================================================
    # REDIMENSIONNEMENT
    # =========================================================================

    def resizeEvent(self, event):
        """Adapte la grille au redimensionnement."""
        super().resizeEvent(event)
        if self._loading_overlay.isVisible():
            self._loading_overlay.setGeometry(self.centralWidget().rect())
        vw = self._scroll.viewport().width()
        if vw > 100:
            new_cols = max(1, (vw - GRID_MARGIN * 2 + GRID_SPACING) // (CARD_W + GRID_SPACING))
            if new_cols != self._cols and self._buttons:
                self._cols = new_cols
                self._rebuild_grid()

    # =========================================================================
    # FERMETURE
    # =========================================================================

    def closeEvent(self, event):
        """Nettoie les ressources."""
        self._stop_video()
        self._pad_timer.stop()
        self._load_anim.stop()
        if self._gamepad:
            try:
                self._gamepad.close()
            except (OSError, IOError):
                pass
        super().closeEvent(event)


# =============================================================================
# POINT D'ENTRÉE
# =============================================================================

def main():
    # Forcer OpenGL desktop 3.3 core (pas GLES) pour compatibilité mpv
    fmt = QSurfaceFormat()
    fmt.setRenderableType(QSurfaceFormat.OpenGL)
    fmt.setVersion(3, 3)
    fmt.setProfile(QSurfaceFormat.CoreProfile)
    QSurfaceFormat.setDefaultFormat(fmt)

    app = QApplication(sys.argv)
    app.setApplicationName("Gablue TV")
    app.setDesktopFileName("gablue-tv")
    app.setOrganizationName("gablue")
    app.setStyle("Fusion")

    # Police légèrement agrandie pour usage TV
    font = QFont("Noto Sans", 11)
    font.setStyleStrategy(QFont.PreferAntialias)
    app.setFont(font)
    app.setStyleSheet(APP_STYLESHEET)

    win = TVWindow()
    win.show()
    sys.exit(app.exec())


if __name__ == "__main__":
    main()
