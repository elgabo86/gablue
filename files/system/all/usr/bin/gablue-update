#!/usr/bin/python3

"""
Gablue Update — Mise à jour système via bootc (GUI PySide6 ou CLI)
Lancement : gablue-update          → GUI si affichage, sinon CLI
           gablue-update --cli     → CLI forcé
           gablue-update --help    → aide
"""

import sys
import os
import re
import subprocess
import signal

# --- Analyse des arguments ---------------------------------------------------

CLI_MODE = False
for arg in sys.argv[1:]:
    if arg in ("--cli", "--nogui"):
        CLI_MODE = True
    elif arg in ("--help", "-h"):
        print("Usage: gablue-update [OPTIONS]")
        print()
        print("Options:")
        print("  --cli, --nogui  Mode ligne de commande")
        print("  --help, -h      Afficher cette aide")
        print()
        print("Par défaut, l'interface graphique est utilisée si un affichage")
        print("est disponible, sinon le mode CLI est utilisé automatiquement.")
        sys.exit(0)

HAS_DISPLAY = bool(os.environ.get("DISPLAY") or os.environ.get("WAYLAND_DISPLAY"))

# --- Mode CLI ----------------------------------------------------------------

def _run(cmd: list[str]) -> int:
    """Lance une commande et retourne le code de sortie"""
    return subprocess.run(cmd).returncode

def cli_run() -> None:
    print("=== Mise à jour de Gablue ===")
    print()
    print("[1/2] Mise à jour du système (bootc)…")
    rc = _run(["/usr/bin/sudo", "/usr/bin/bootc", "upgrade"])
    if rc != 0:
        print("Erreur lors de la mise à jour système.")
        sys.exit(1)
    print()
    print("[2/2] Mise à jour des applications Flatpak…")
    _run(["/usr/bin/flatpak", "update", "--user", "-y"])
    print()
    print("Terminé.")

    # Redémarrage ?
    try:
        status = subprocess.run(
            ["/usr/bin/sudo", "/usr/bin/bootc", "status"],
            capture_output=True, text=True, timeout=10
        )
        if "staged" in status.stdout:
            rep = input("Un redémarrage est nécessaire. Redémarrer maintenant ? [o/N] ")
            if rep.lower() in ("o", "oui", "y", "yes"):
                subprocess.run(["/usr/bin/systemctl", "reboot"])
    except (subprocess.TimeoutExpired, OSError):
        pass

if CLI_MODE or not HAS_DISPLAY:
    cli_run()
    sys.exit(0)

# --- Mode GUI (imports lourds uniquement si nécessaire) -----------------------

import pty
import select

from PySide6.QtCore import Qt, QThread, QTimer, Signal
from PySide6.QtWidgets import (
    QApplication, QMainWindow, QWidget, QVBoxLayout, QHBoxLayout,
    QPushButton, QLabel, QProgressBar, QPlainTextEdit, QStackedWidget,
)

# =============================================================================
# Thème
# =============================================================================

T = {
    "bg": "#0d0d12", "card": "#18181f", "hover": "#22222c",
    "accent": "#4da6ff", "success": "#32d47e", "warning": "#ffb340",
    "error": "#ff4d5a", "text": "#e8e8f0", "secondary": "#8a8a98",
    "border": "#2a2a36", "log_bg": "#101016", "progress": "#20202a",
}

STYLE = f"""
QMainWindow, QWidget {{ background-color: {T['bg']}; color: {T['text']}; }}
QProgressBar {{
    background-color: {T['progress']}; border: 1px solid {T['border']};
    border-radius: 6px; height: 28px; text-align: center;
    color: {T['text']}; font-size: 12px;
}}
QProgressBar::chunk {{ background-color: {T['accent']}; border-radius: 5px; }}
QPlainTextEdit {{
    background-color: {T['log_bg']}; color: {T['secondary']};
    border: 1px solid {T['border']}; border-radius: 6px;
    padding: 10px; font-family: monospace; font-size: 12px;
}}
QPushButton {{
    background-color: {T['card']}; color: {T['text']};
    border: 1px solid {T['border']}; border-radius: 10px;
    padding: 14px 32px; font-size: 14px; font-weight: bold;
}}
QPushButton:hover {{ background-color: {T['hover']}; border-color: {T['accent']}; }}
QPushButton:pressed {{ background-color: {T['accent']}; color: {T['bg']}; }}
QPushButton:disabled {{ color: {T['secondary']}; }}
QLabel {{ background: transparent; color: {T['text']}; }}
"""

ANSI_RE = re.compile(
    r'\x1b\[[0-9;]*[a-zA-Z]'
    r'|\x1b\][0-9;]*[^\x07]*\x07'
    r'|\x1b\][0-9;]*\x1b\\'
    r'|\x1b\][0-9;]*$'
    r'|\r'
)

PROGRESS_RE = re.compile(r'(\d+\.?\d*\s*\S+)\s*/\s*(\d+\.?\d*\s*\S+)')
SPEED_RE = re.compile(r'(\d+\.?\d*\s*\S+/s)')
LAYER_COUNT_RE = re.compile(r'(\d+)/(\d+)')

def parse_size(s: str) -> float:
    s = s.strip().replace('\xa0', ' ').replace(',', '.')
    m = re.match(r'([\d.]+)\s*(B|KiB|MiB|GiB|TiB|kB|KB|MB|GB|TB)?', s)
    if not m: return 0
    val = float(m.group(1))
    unit = (m.group(2) or 'B').lower()
    mult = {'b': 1, 'kib': 1024, 'mib': 1024**2, 'gib': 1024**3, 'tib': 1024**4,
            'kb': 1000, 'mb': 1000**2, 'gb': 1000**3, 'tb': 1000**4}
    return val * mult.get(unit, 1)

# =============================================================================
# Travailleur PTY
# =============================================================================

class PtyWorker(QThread):
    line_out = Signal(str)
    progress = Signal(int, str)

    def __init__(self, cmd: list[str], parent=None):
        super().__init__(parent)
        self.cmd = cmd
        self._running = False
        self._proc = None
        self._master_fd = None

    def run(self):
        self._running = True
        try:
            master_fd, slave_fd = pty.openpty()
            self._master_fd = master_fd
            self._proc = subprocess.Popen(
                self.cmd, stdin=slave_fd, stdout=slave_fd, stderr=slave_fd,
                close_fds=True, preexec_fn=os.setsid,
            )
            os.close(slave_fd)
            buf = b""
            last_progress = ""
            last_log_line = ""

            while self._running:
                r, _, _ = select.select([master_fd], [], [], 0.15)
                if r:
                    try:
                        data = os.read(master_fd, 8192)
                        if not data: break
                        buf += data
                        while b"\n" in buf:
                            line, buf = buf.split(b"\n", 1)
                            if b"\r" in line:
                                parts = line.split(b"\r")
                                for part in parts:
                                    cl = self._clean(part)
                                    if cl and cl != last_progress:
                                        last_progress = cl
                                        pct, info = self._parse_progress(cl)
                                        if pct >= 0: self.progress.emit(pct, info)
                                final = self._clean(parts[-1])
                                if final and final != last_log_line:
                                    last_log_line = final
                                    if not self._is_progress_line(final):
                                        self.line_out.emit(final)
                            else:
                                cl = self._clean(line)
                                if cl:
                                    if not self._is_progress_line(cl):
                                        self.line_out.emit(cl)
                                    else:
                                        pct, info = self._parse_progress(cl)
                                        if pct >= 0: self.progress.emit(pct, info)
                    except OSError:
                        break
                if self._proc.poll() is not None:
                    try:
                        while True:
                            r2, _, _ = select.select([master_fd], [], [], 0.1)
                            if not r2: break
                            data = os.read(master_fd, 8192)
                            if not data: break
                            buf += data
                    except OSError:
                        pass
                    break
            if buf:
                for part in buf.split(b"\r"):
                    cl = self._clean(part)
                    if cl and not self._is_progress_line(cl):
                        self.line_out.emit(cl)
        except Exception as e:
            self.line_out.emit(f"Erreur: {e}")
        finally:
            if self._master_fd is not None:
                try: os.close(self._master_fd)
                except OSError: pass
            self._running = False

    def stop(self):
        self._running = False
        if self._proc and self._proc.poll() is None:
            try:
                os.killpg(os.getpgid(self._proc.pid), signal.SIGTERM)
                self._proc.wait(timeout=4)
            except (ProcessLookupError, subprocess.TimeoutExpired):
                try:
                    os.killpg(os.getpgid(self._proc.pid), signal.SIGKILL)
                except ProcessLookupError:
                    pass

    @staticmethod
    def _clean(data: bytes) -> str:
        text = data.decode("utf-8", errors="replace")
        text = ANSI_RE.sub('', text)
        text = re.sub(r'^Script (démarré|terminé).*', '', text)
        text = re.sub(r'[ \t]+', ' ', text).strip()
        return text

    @staticmethod
    def _is_progress_line(text: str) -> bool:
        return bool(re.search(r'(Fetching|Downloading|Extracting|Writing|⠋|⠙|⠹|⠸|⠼|⠴|⠦|⠧|⠇|⠏)', text))

    @staticmethod
    def _parse_progress(text: str) -> tuple:
        m = PROGRESS_RE.search(text)
        if m:
            cur = parse_size(m.group(1))
            tot = parse_size(m.group(2))
            if tot > 0:
                return (min(int(cur / tot * 100), 100), f"{m.group(1)} / {m.group(2)}")
        m = LAYER_COUNT_RE.search(text)
        if m:
            cur, tot = int(m.group(1)), int(m.group(2))
            if tot > 0:
                return (int(cur / tot * 100), f"Élément {cur}/{tot}")
        m = SPEED_RE.search(text)
        if m: return (-1, m.group(1))
        return (-1, "")


