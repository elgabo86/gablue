#!/usr/bin/bash

# Wrapper pour gablue-update
# Interface graphique par défaut, mode CLI avec --cli ou --nogui

set -euo pipefail

CLI_MODE=false
AUTO_MODE=false

for arg in "$@"; do
    case $arg in
        --cli|--nogui) CLI_MODE=true ;;
        --auto)        CLI_MODE=true; AUTO_MODE=true ;;
        --help|-h)
            echo "Usage: gablue-update [OPTIONS]"
            echo ""
            echo "Options:"
            echo "  --cli, --nogui  Mode ligne de commande"
            echo "  --auto          Mode automatique non-interactif"
            echo "  --help, -h      Afficher cette aide"
            echo ""
            echo "Par défaut, l'interface graphique est utilisée."
            exit 0
            ;;
    esac
done

# Mode GUI — seulement si un display graphique est disponible
if [ "$CLI_MODE" = false ] && [ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ]; then
    SCRIPT_DIR="/usr/share/ublue-os/gablue/scripts"

    # Support dev (repo git)
    if [ -f "$(dirname "$0")/../share/ublue-os/gablue/scripts/gablue-update-gui.py" ]; then
        SCRIPT_DIR="$(dirname "$0")/../share/ublue-os/gablue/scripts"
    fi

    exec /usr/bin/python3 "$SCRIPT_DIR/gablue-update-gui.py"
fi

# Mode CLI
echo "=== Mise à jour de Gablue ==="
echo ""

# Système
echo "[1/2] Mise à jour du système (bootc)…"
if ! sudo /usr/bin/bootc upgrade; then
    echo "Erreur lors de la mise à jour système."
    exit 1
fi

echo ""

# Flatpak
echo "[2/2] Mise à jour des applications Flatpak…"
flatpak update --user -y 2>/dev/null || true

echo ""
echo "Terminé."

# Vérifier si un redémarrage est nécessaire
if [ "$AUTO_MODE" = true ]; then
    exit 0
fi

if sudo /usr/bin/bootc status 2>/dev/null | grep -q "staged"; then
    echo ""
    read -r -p "Un redémarrage est nécessaire. Redémarrer maintenant ? [o/N] " rep
    if [[ "$rep" =~ ^[oOyY] ]]; then
        systemctl reboot
    fi
fi
