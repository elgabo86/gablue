#!/usr/bin/bash

# Exécuter toutes les commandes en arrière-plan en regroupant les tâches indépendantes
{
  # Recherche et kill tous les processus Windows (xbox360 inclus)
  # Exclure gwine (le wrapper) pour permettre le nettoyage des montages WGP
  pgrep -f -a -i '(.*\.(exe|bat).*|.*(wine|proton).*)' | awk '{pid=$1; $1=""; if ($0 !~ /(.\/gwine| gwine)/) print pid}' | grep -v -E "^($(pgrep -i '^(steam|steamwebhelper|steam-runtime-l)$' | paste -sd '|' -))$" | xargs -r kill -9 &

  # Tuer aussi les bwrap avec WINEPREFIX gwine (pour les jeux qui ont des launchers comme stdrt.exe)
  # On vérifie l'environnement car WINEPREFIX n'est pas dans la ligne de commande
  for pid in $(pgrep bwrap); do
    if grep -q "WINEPREFIX=/tmp/gwine-prefix-overlay" /proc/$pid/environ 2>/dev/null; then
      kill -9 "$pid" 2>/dev/null
    fi
  done &

  # Gestion des processus bottles (spécifique avec vérification bwrap)
  pgrep -f bottles | xargs -I {} sh -c 'ps -p {} -o comm= | grep -q "^bwrap$" && kill -9 {}' &

   # Kill des émulateurs (tous en parallèle)
  for emu in azahar suyu eden sudachi dolphin-emu yuzu retroarch xemu rpcs3 duckstation pcsx2 lime3ds ryujinx Cemu flycast shadps4 PokeMMO PPSSPP; do
    pgrep -f "$emu" | xargs -n1 kill -9 &
  done

  # Commande spécifique pour eden et citron avec fusermount
  (pgrep -f mount_eden | xargs -n1 kill -9 && fusermount -uz /tmp/.mount_eden*) &
  (pgrep -f citron | xargs -n1 kill -9 && fusermount -uz /tmp/.mount_citro*) &

  # Kill des processus sober
  pkill -9 sober &

  # Kill x2go
  pkill -9 x2goclient &

  # Kill uniquement les processus enfants de launchlin.sh (pas le script lui-même)
  # pour permettre le cleanup et démontage du LGP
  pgrep -f "launchlin\.sh" | while read pid; do
      # Liste tous les processus enfants directs et indirects
      local children
      children=$(pgrep -P "$pid")
      if [ -n "$children" ]; then
          # Tuer récursivement tous les enfants
          echo "$children" | while read child_pid; do
              # Tuer le processus enfant et ses propres enfants
              pkill -9 -P "$child_pid" 2>/dev/null
              kill -9 "$child_pid" 2>/dev/null
          done
      fi
  done &
} > /dev/null 2>&1 &

# Attendre que toutes les tâches en arrière-plan soient terminées (optionnel)
wait
