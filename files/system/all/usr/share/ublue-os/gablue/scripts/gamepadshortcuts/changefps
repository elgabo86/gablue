#!/bin/bash

CONFIG_FILE="$HOME/.config/MangoHud/MangoHud.conf"

FPS_CYCLE=(60 90 120 165 0)

ensure_config() {
    if ! grep -q "^show_fps_limit" "$CONFIG_FILE"; then
        echo "show_fps_limit" >> "$CONFIG_FILE"
    fi
    if ! grep -q "^fps_limit_method=late" "$CONFIG_FILE"; then
        echo "fps_limit_method=late" >> "$CONFIG_FILE"
    fi
}

current_fps=$(grep -oP '^fps_limit=\K\d+' "$CONFIG_FILE" 2>/dev/null || echo "0")

next_fps=""
found=false
for fps in "${FPS_CYCLE[@]}"; do
    if $found; then
        next_fps=$fps
        break
    fi
    if [ "$fps" -eq "$current_fps" ]; then
        found=true
    fi
done

if [ -z "$next_fps" ]; then
    next_fps=${FPS_CYCLE[0]}
fi

sed -i '/^fps_limit=/d' "$CONFIG_FILE"

if [ "$next_fps" -eq 0 ]; then
    sed -i '/^show_fps_limit/d' "$CONFIG_FILE"
    echo "FPS maintenant sans limite"
else
    echo "fps_limit=$next_fps" >> "$CONFIG_FILE"
    ensure_config
    echo "Changé à $next_fps FPS"
fi
