#!/usr/bin/bash

set -euo pipefail

LOCKFILE="/tmp/launchgamepadshortcuts.lock"

# Prend le lock (bloquant avec timeout de 3s pour éviter blocage infini)
exec 200>"$LOCKFILE"
if ! flock -w 3 200; then
    echo "Une instance est déjà en cours d'exécution"
    exit 1
fi

# Maintenant qu'on a le lock, tuer proprement l'ancien processus
pkill -f gamepadshortcuts || true
sleep 1

# Boucle pour relancer gamepadshortcuts si ça se termine
while true; do
    /usr/bin/gamepadshortcuts || true
    sleep 1
done
