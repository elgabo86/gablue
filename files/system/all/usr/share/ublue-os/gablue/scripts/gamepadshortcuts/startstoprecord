#!/usr/bin/bash

set -eoux pipefail

LOCKFILE="/tmp/gablue-record-start.lock"
PIDFILE="/tmp/gablue-record.pid"
COOLDOWN_FILE="/tmp/gablue-record-cooldown"
COOLDOWN_SEC=1.5

# =============================================================================
# COOLDOWN apres arret
# =============================================================================

if [ -f "$COOLDOWN_FILE" ]; then
    echo "Cooldown actif, ignore."
    exit 0
fi

# =============================================================================
# ARRET : juste le signal, pas d'attente. Le script start gere la suite.
# =============================================================================

if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
    # Refuser le stop si l'enregistrement a moins de 2s (risque crash init encodeur)
    START_TIME=$(cat /tmp/gablue-record-start-time 2>/dev/null || echo 0)
    NOW=$(date +%s)
    if [ $((NOW - START_TIME)) -lt 2 ]; then
        echo "Enregistrement trop recent, attendez 2s avant d'arreter."
        exit 0
    fi
    echo "Arret de l'enregistrement..."
    killall -SIGINT -q gpu-screen-recorder 2>/dev/null || true
    exit 0
fi

[ -f "$PIDFILE" ] && rm -f "$PIDFILE" /tmp/gablue-record-start-time

# =============================================================================
# DEMARRAGE : lock bref pour l'ecriture du PIDFILE
# =============================================================================

exec 200>"$LOCKFILE"
if ! flock -n 200; then
    echo "Un enregistrement est deja en cours, ignore."
    exit 0
fi

if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
    flock -u 200
    echo "Enregistrement deja en cours."
    exit 0
fi

# =============================================================================
# PREPARATION
# =============================================================================

# Resolution max de sortie (downscale si l'ecran est plus grand). Override possible :
# RECORD_RES=2560x1440 /path/vers/startstoprecord
RECORD_RES="${RECORD_RES:-1920x1080}"

video="$HOME/Vidéos/Captures/$(date +"Video_%Y-%m-%d_%H-%M-%S.mp4")"
mkdir -p "$(dirname "$video")"

# FPS lu depuis MangoHud.conf (fps_limit=N ou format dual N,M). Fallback 60 si absent / 0 (uncapped).
MANGOHUD_CONF="$HOME/.config/MangoHud/MangoHud.conf"

if [ -f "$MANGOHUD_CONF" ]; then
    FPS=$(grep -E '^[[:space:]]*fps_limit[[:space:]]*=' "$MANGOHUD_CONF" | head -1 | awk -F'=' '{print $2}' | awk -F',' '{print $1}' | tr -d '[:space:]')
    if [ -z "$FPS" ] || [ "$FPS" -eq 0 ] 2>/dev/null; then
        FPS=60
    fi
else
    FPS=60
fi

COMMANDE_INTEL="flatpak run --command=gpu-screen-recorder com.dec05eba.gpu_screen_recorder -cursor no -w screen -s $RECORD_RES -f $FPS -a default_output -q medium -o '$video'"
COMMANDE_AUTRE="flatpak run --command=gpu-screen-recorder com.dec05eba.gpu_screen_recorder -cursor no -w screen -s $RECORD_RES -f $FPS -a default_output -o '$video'"

# =============================================================================
# LANCEMENT
# =============================================================================

ffplay -nodisp -autoexit /usr/share/ublue-os/gablue/scripts/gamepadshortcuts/beep.wav

echo "$$" > "$PIDFILE"
date +%s > /tmp/gablue-record-start-time
flock -u 200

if lspci | grep -i "VGA" | grep -i "Intel" > /dev/null; then
    if command -v glxinfo > /dev/null && glxinfo | grep -i "renderer" | grep -i "Intel" > /dev/null; then
        echo "GPU Intel integre actif detecte."
        eval "$COMMANDE_INTEL" || true
    else
        echo "GPU Intel detecte mais non actif (ou glxinfo non installe)."
        eval "$COMMANDE_AUTRE" || true
    fi
else
    echo "Aucun GPU Intel integre detecte."
    eval "$COMMANDE_AUTRE" || true
fi

# =============================================================================
# NETTOYAGE : l'enregistrement est termine (naturel ou kill)
# =============================================================================

# Cooldown EN PREMIER pour eviter toute fenetre sans protection
touch "$COOLDOWN_FILE"
(sleep "$COOLDOWN_SEC" && rm -f "$COOLDOWN_FILE") &

rm -f "$PIDFILE" /tmp/gablue-record-start-time

ffplay -nodisp -autoexit /usr/share/ublue-os/gablue/scripts/gamepadshortcuts/stop.wav
notify-send -t 2000 -u low "Enregistrement sauve dans $video"
