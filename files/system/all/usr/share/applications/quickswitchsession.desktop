#!/usr/bin/env xdg-open
[Desktop Entry]
Type=Application
Name=QuickSwitchSession
Comment=Passe d'une session graphique à l'autre ou ouvre l'écran de login
Icon=system-switch-user
Exec=/usr/share/ublue-os/gablue/scripts/quickswitchsession.sh
Terminal=false
Categories=System;
Keywords=switch;session;login;quickswitch;
